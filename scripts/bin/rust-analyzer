#!/bin/bash
set -euo pipefail

source "$(dirname "${BASH_SOURCE[0]}")/../_common.sh"

#
# This script is used by VS Code to launch Rust Analyzer LSP with the correct toolchain.
# See the 'rust-analyzer.server.path' VS Code setting for more details.
#

(
  # Running "rustup default" will print: "TOOLCHAIN (default)"
  # and we want to extract the "TOOLCHAIN" name only.
  # This splits by spaces and gets the first part:
  rustup_default="$(rustup default)"
  toolchain="${rustup_default%% *}"

  rustup run "${toolchain}" rust-analyzer "$@"
)
