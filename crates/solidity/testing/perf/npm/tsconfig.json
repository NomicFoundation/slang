{
  "extends": "../../../../../tsconfig.json",

  "include": ["./src/**/*.mts"],

  "compilerOptions": {
    "target": "es2017", // for top-level awaits
    /* Projects */
    "composite": true,
    "incremental": true,
    "rootDir": "./src",
    "tsBuildInfoFile": "target/tsc/.tsbuildinfo",

    /* Type acquisition (TS 6 no longer auto-includes @types/*) */
    "types": ["node"]
  }
}
