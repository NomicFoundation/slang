use slang_solidity_v2_ast::ast::lexemes;
use slang_solidity_v2_ast::ast::nodes::*;

grammar<'source>(source: &'source str);

Sep<S, T>: Vec<T> = {
    => Vec::new(),
    SepOne<S, T> => <>,
};

SepOne<S, T>: Vec<T> = {
    <mut v:(<T> S)*> <e:T>  => {
        v.push(e);
        v
    }
};

{% for section in model.parser.sections -%}

// Rules for section {{ section.title }}

{% for topic in section.topics -%}
    // Rules for topic {{ topic.title }}
    {% for item in topic.items -%}

    {% if item.inline %}#[inline]
    {% endif %}{% if item.name == model.parser.root_item -%} pub {% endif -%} {{ item.name }}: {{ item.producing_type }} = {
        {% for option in item.options -%}
            {{ option.attributes }} 
            {% for field in option.fields -%}   
                <{{ field.capturing_name }}: {{ field.rule }}> {{ " " }}
            {%- endfor %}=> {% if option.forward %}<>{% else -%}
            new_{{ item.producing_type | snake_case }}{% if option.name %}_{{ option.name | snake_case }}{% endif %}({% if option.prebuild -%}
            new_{{option.name | snake_case}}(<>)
            {%- else -%}
            <>
            {%- endif %})
            {%- endif %},
        {% endfor %}
    };
    {% endfor %}

{% endfor %}


{% endfor %}

// Lexemes formatting
{% for kind in model.parser.lexer.lexeme_kinds -%}
{% if kind != "Identifier" %}#[inline]{% endif %}
{{ kind }}: {{ kind }} = {
    <l:@L> L_{{ kind }} <r:@L> => new_{{kind | snake_case}}(<>, source),
    {%- if kind == "Identifier" %}
// TODO: The identifier should also consider unreserved keywords
     {% for kw in model.parser.lexer.unreserved_keywords %} 
        <l:@L> L_{{ kw }} <r:@L> => new_{{kind | snake_case}}(<>, source),
    {% endfor %}
// ODOT
    {% endif %}
}
{% endfor %}


extern {
    type Location = usize;
    // TODO error recovery
    type Error = ();

    enum lexemes::LexemeKind {
        {% for kind in model.parser.lexer.lexeme_kinds -%}
            L_{{ kind }} => lexemes::LexemeKind::{{ kind }},
        {% endfor %}
    }
}

