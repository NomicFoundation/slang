// TODO[4] These are the new tuples, we get a prototuple that can be a pattern/declaration
// or a tuple value, we then disambigguate

    // A ProtoTuple can match both a TupleExpression (ie, a tuple with expressions inside, separated by commas)
    // as well as a TuplePattern, which is a tuple with optional patterns or declarations inside, separated by commas.
    // Every Tuple is a TuplePattern, not the other way around, so we also make that distinction with the generics.

    ProtoTuple<Tuple>: String = {
        <_open_paren: OpenParen>  <_elements: ProtoTupleElements<Tuple>>  <_close_paren: CloseParen>  => format!("{{ \"item\": \"Special\", \"name\": \"ProtoTuple\", \"_open_paren\": {}, \"_elements\": {}, \"_close_paren\": {} }}", _open_paren, _elements, _close_paren),
    }

    
    ProtoTupleElements<Tuple>: String = {
        // TODO: empty tuple

        // A single element can be True or False
        // Note that ProtoTupleElement<"False"> allows empty elements, we have to change that
        <_elem: ProtoTupleElement<"True">> if Tuple == "True" => format!("{{ \"item\": \"Special\", \"name\": \"ProtoTupleElements\", \"_elems\": {} }}", format!("[{}]", _elem)),
        <_elem: ProtoTupleElement<"False">> if Tuple == "False" => format!("{{ \"item\": \"Special\", \"name\": \"ProtoTupleElements\", \"_elems\": {} }}", format!("[{}]", _elem)),
        
        // A ProtoTuple only ProtoTupleElements<True> is a Tuple
        <_elems: ProtoTupleElements<"True">> Comma <_elem: ProtoTupleElement<"True">> if Tuple == "True" => format!("{{ \"item\": \"Special\", \"name\": \"ProtoTupleElements\", \"_elems\": {} }}", format!("[{}, {}]", _elems, _elem)),

        // 
        //<_elems: ProtoTupleElements<"True">> Comma if Tuple == "False" => format!("{{ \"item\": \"Special\", \"name\": \"ProtoTupleElements\", \"_elems\": {} }}", format!("[{}]", _elems)),

        <_elems: ProtoTupleElements<"False">> Comma <_elem: ProtoTupleElement<"False">> if Tuple == "False" => format!("{{ \"item\": \"Special\", \"name\": \"ProtoTupleElements\", \"_elems\": {} }}", format!("[{}, {}]", _elems, _elem)),
        <_elems: ProtoTupleElements<"True">> Comma <_elem: ProtoTupleElement<"False">> if Tuple == "False" => format!("{{ \"item\": \"Special\", \"name\": \"ProtoTupleElements\", \"_elems\": {} }}", format!("[{}, {}]", _elems, _elem)),
        <_elems: ProtoTupleElements<"False">> Comma <_elem: ProtoTupleElement<"True">> if Tuple == "False" => format!("{{ \"item\": \"Special\", \"name\": \"ProtoTupleElements\", \"_elems\": {} }}", format!("[{}, {}]", _elems, _elem)),

//        <_elems: ((<ProtoTupleElement<Tuple>> <(Comma <ProtoTupleElement<Tuple>>)*>))> => format!("{{ \"item\": \"Special\", \"name\": \"ProtoTupleElements\", \"_elems\": {} }}", format!("[{}, {}]", _elems.0, _elems.1.iter().join(", "))).unwrap_or("[]".into()),
    };

    ProtoTupleElement<Tuple>: String = {
        // A Tuple expression must be present and only be an identifier
        <_name: Expression> if Tuple == "True" => format!("{{ \"item\": \"Special\", \"name\": \"ProtoTupleElement\", \"_name\": {} }}", _name),

        <_decl: VariableDeclaration> if Tuple == "False" => format!("{{ \"item\": \"Special\", \"name\": \"ProtoTupleElement\", \"_decl\": {} }}", _decl),
        <_storage_location: StorageLocation> <_name: Identifier> if Tuple == "False" => format!("{{ \"item\": \"Special\", \"name\": \"ProtoTupleElement\", \"_storage_location\": {}, \"_name\": {} }}", _storage_location, _name),
        () if Tuple == "False" => format!("{{ \"item\": \"Special\", \"name\": \"ProtoTupleElement\" }}"),
    };
        
