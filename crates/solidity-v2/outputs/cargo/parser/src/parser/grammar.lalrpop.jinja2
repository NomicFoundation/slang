use crate::lexer::lexemes;
use crate::parser::nodes::*;
use itertools::Itertools;

grammar<'source>(source: &'source str);

{% for section in model.parser.sections -%}

// Rules for section {{ section.title }}

{% for topic in section.topics -%}
    // Rules for topic {{ topic.title }}
    {% for item in topic.items -%}

    {% if item.inline %}#[inline]
    {% endif %}{% if item.name == model.parser.root_item -%} pub {% endif -%} {{ item.name }}: {{ item.producing_type }} = {
        {% for option in item.options -%}
            {{ option.attributes }} 
            {% for field in option.fields -%}   
                <{{ field.capturing_name }}: {{ field.rule }}> {{ " " }}
            {%- endfor %}=> {{ option.action }},
        {% endfor %}
    };
    {% endfor %}

{% endfor %}


{% endfor %}

// Lexemes formatting
{% for kind in model.parser.lexer.lexeme_kinds -%}
#[inline]
{{ kind }}: String = {
    <l:@L> L_{{ kind }} <r:@L> => format!("{% raw %} {{ {% endraw %} \"item\": \"Lexeme\", \"name\": \"{{ kind }}\", \"_l\": {}, \"_r\": {}, \"value\": \"{}\" {% raw %} }} {% endraw %}", l, r, &source[l..r]),
}
{% endfor %}


extern {
    type Location = usize;
    // TODO error recovery
    type Error = ();

    enum lexemes::LexemeKind {
        {% for kind in model.parser.lexer.lexeme_kinds -%}
            L_{{ kind }} => lexemes::LexemeKind::{{ kind }},
        {% endfor %}
    }
}
