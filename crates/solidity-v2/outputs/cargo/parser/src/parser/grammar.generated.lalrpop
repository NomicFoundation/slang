// Rules for topic Events
    EventDefinition: C::EventDefinition = {
        <event_keyword: EventKeyword>  <name: Identifier>  <parameters: EventParametersDeclaration>  <anonymous_keyword: (AnonymousKeyword)?>  <semicolon: Semicolon>  => consumer.make_event_definition(<>),
        
