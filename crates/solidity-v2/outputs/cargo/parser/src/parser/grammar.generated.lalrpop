    TypeName0<Func>: TypeName = {
         
            <_FunctionType: FunctionType> if Func == "True" => new_type_name_function_type(<>),
         
            <_MappingType: MappingType>  => new_type_name_mapping_type(<>),
         
            <_ElementaryType: ElementaryType>  => new_type_name_elementary_type(<>),
         
