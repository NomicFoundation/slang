// Rules for topic Errors
    #[inline]
    ErrorDefinition: C::ErrorDefinition = {
        <error_keyword: ErrorKeyword>  <name: Identifier>  <members: ErrorParametersDeclaration>  <semicolon: Semicolon>  => consumer.make_error_definition(<>),
        
