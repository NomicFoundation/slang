        <internal_keyword: InternalKeyword>  => consumer.make_constructor_attribute_internal_keyword(<>),
        <payable_keyword: PayableKeyword>  => consumer.make_constructor_attribute_payable_keyword(<>),
        <public_keyword: PublicKeyword>  => consumer.make_constructor_attribute_public_keyword(<>),
        
    };
    FallbackFunctionDefinition: C::FallbackFunctionDefinition = {
        <fallback_keyword: FallbackKeyword>  <parameters: ParametersDeclaration>  <attributes: FallbackFunctionAttributes>  <returns: (ReturnsDeclaration)?>  <body: FunctionBody>  => consumer.make_fallback_function_definition(<>),
        
    };
    FallbackFunctionAttributes: C::FallbackFunctionAttributes = {
        <fallback_function_attribute: RepeatedAllowEmpty<<FallbackFunctionAttribute>>>  => consumer.make_fallback_function_attributes(<>),
        
    };
    FallbackFunctionAttribute: C::FallbackFunctionAttribute = {
        <modifier_invocation: ModifierInvocation>  => consumer.make_fallback_function_attribute_modifier_invocation(<>),
        <override_specifier: OverrideSpecifier>  => consumer.make_fallback_function_attribute_override_specifier(<>),
        <external_keyword: ExternalKeyword>  => consumer.make_fallback_function_attribute_external_keyword(<>),
        <payable_keyword: PayableKeyword>  => consumer.make_fallback_function_attribute_payable_keyword(<>),
        <pure_keyword: PureKeyword>  => consumer.make_fallback_function_attribute_pure_keyword(<>),
        <view_keyword: ViewKeyword>  => consumer.make_fallback_function_attribute_view_keyword(<>),
        <virtual_keyword: VirtualKeyword>  => consumer.make_fallback_function_attribute_virtual_keyword(<>),
        
    };
    ReceiveFunctionDefinition: C::ReceiveFunctionDefinition = {
        <receive_keyword: ReceiveKeyword>  <parameters: ParametersDeclaration>  <attributes: ReceiveFunctionAttributes>  <body: FunctionBody>  => consumer.make_receive_function_definition(<>),
        
