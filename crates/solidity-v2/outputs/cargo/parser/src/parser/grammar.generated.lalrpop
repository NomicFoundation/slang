        L_YulYearsKeyword_Unreserved => lexemes::LexemeKind::YulYearsKeyword_Unreserved,
        
    }
}


// Added rules

    StateVariableDefinition: StateVariableDefinition = {
// TODO[1] This is an annoying hack, the problem is when we have a function type
// in a variable declaration type, then some attributes (visibility ones) can be both
// at the end of the type, or just after the type.
// Right now I'm trying some strange hack for counting used attributes, but I'm
// leaning towards having the function type take every attribute, and then reparse
// up here, and extract attributes that belong to the variable

            //<_type_name: TypeName>  /*<_attributes: StateVariableAttributes> Removing to test conflicts*/  <_name: Identifier>  <_value: (StateVariableDefinitionValue)?>  <_semicolon: Semicolon>  => format!("{{ \"item\": \"Struct\", \"name\": \"StateVariableDefinition\", \"_type_name\": {}, \"_attributes\": {}, \"_name\": {}, \"_value\": {}, \"_semicolon\": {} }}", _type_name, _attributes, _name, _value.unwrap_or("\"\"".into()), _semicolon),


         // If we're not using functions, then we can have all attributes
            <_type_name: TypeName1<"False">>  <_attributes: StateVariableAttributes<"m">>  <_name: Identifier>  <_value: (StateVariableDefinitionValue)?>  <_semicolon: Semicolon>  => new_state_variable_definition(<>),
            // Otherwise, the fun begins

            // If the there is a return, the visibility doesnt really matter, it's ignored. 
            // So we can either have or not have a vis
            <_type_name: FunctionTypeInternalReturn>  <_attributes: StateVariableAttributes<"m">>  <_name: Identifier>  <_value: (StateVariableDefinitionValue)?>  <_semicolon: Semicolon>  => new_state_variable_definition(new_type_name_function_type(_type_name), _attributes, _name, _value, _semicolon),

            // If there is no return, then we need to check the visibility
            // If there's a Vis then we can have a Vis
            <_type_name: FunctionTypeInternalNoReturn<"1">>  <_attributes: StateVariableAttributes<"m">>  <_name: Identifier>  <_value: (StateVariableDefinitionValue)?>  <_semicolon: Semicolon>  => new_state_variable_definition(new_type_name_function_type(_type_name), _attributes, _name, _value, _semicolon),
            // If there's no Vis, then we cant have a Vis
            <_type_name: FunctionTypeInternalNoReturn<"0">>  <_attributes: StateVariableAttributes<"0">>  <_name: Identifier>  <_value: (StateVariableDefinitionValue)?>  <_semicolon: Semicolon>  => new_state_variable_definition(new_type_name_function_type(_type_name), _attributes, _name, _value, _semicolon),
        
    };

