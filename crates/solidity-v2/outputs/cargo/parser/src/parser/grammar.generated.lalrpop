    };
    ConstructorAttributes: C::ConstructorAttributes = {
        <constructor_attribute: RepeatedAllowEmpty<<ConstructorAttribute>>>  => consumer.make_constructor_attributes(<>),
        
    };
    ConstructorAttribute: C::ConstructorAttribute = {
