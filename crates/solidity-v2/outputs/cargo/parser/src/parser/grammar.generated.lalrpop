// Making an Identifier inline generates an explosion of states, so DON'T
//
// We allow to pass parameters for certain tokens that are disallowed,
// this is an easy way to express "Any identifier except `X`" as `SomeIdentifier<"X">`
SomeIdentifier<Except>: C::Identifier = {

        <l:@L> L_AtKeyword_Unreserved <r:@L> if Except !~ "AtKeyword_Unreserved" => consumer.make_identifier(l..r, source),

        <l:@L> L_ErrorKeyword_Unreserved <r:@L> if Except !~ "ErrorKeyword_Unreserved" => consumer.make_identifier(l..r, source),

        <l:@L> L_FromKeyword_Unreserved <r:@L> if Except !~ "FromKeyword_Unreserved" => consumer.make_identifier(l..r, source),

        <l:@L> L_GlobalKeyword_Unreserved <r:@L> if Except !~ "GlobalKeyword_Unreserved" => consumer.make_identifier(l..r, source),

        <l:@L> L_Identifier <r:@L> if Except !~ "Identifier" => consumer.make_identifier(l..r, source),

        <l:@L> L_LayoutKeyword_Unreserved <r:@L> if Except !~ "LayoutKeyword_Unreserved" => consumer.make_identifier(l..r, source),

        <l:@L> L_RevertKeyword_Unreserved <r:@L> if Except !~ "RevertKeyword_Unreserved" => consumer.make_identifier(l..r, source),

        <l:@L> L_TransientKeyword_Unreserved <r:@L> if Except !~ "TransientKeyword_Unreserved" => consumer.make_identifier(l..r, source),

};
#[inline]
IfKeyword: C::IfKeyword = {

