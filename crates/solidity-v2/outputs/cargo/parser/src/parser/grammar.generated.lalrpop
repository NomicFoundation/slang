// TODO[4] These are the new tuples, we get a prototuple that can be a pattern/declaration
// or a tuple value, we then disambigguate

    // A ProtoTuple can match both a TupleExpression (ie, a tuple with expressions inside, separated by commas)
    // as well as a TuplePattern, which is a tuple with optional patterns or declarations inside, separated by commas.
    // Every Tuple is a TuplePattern, not the other way around, so we also make that distinction with the generics.

    ProtoTuple<Tuple>: ProtoTuple = {
        <_open_paren: OpenParen>  <_elements: ProtoTupleElements<Tuple>>  <_close_paren: CloseParen>  => new_proto_tuple(_open_paren, _elements, _close_paren),
    }

    
    ProtoTupleElements<Tuple>: Vec<ProtoTupleElement> = {
        // TODO: empty tuple

        // A single element can be True or False
        // Note that ProtoTupleElement<"False"> allows empty elements, we have to change that
        <_elem: ProtoTupleElement<"True">> if Tuple == "True" => vec![<>],
        <_elem: ProtoTupleElement<"False">> if Tuple == "False" => vec![<>],
        
        // A ProtoTuple only ProtoTupleElements<True> is a Tuple
        <mut _elems: ProtoTupleElements<"True">> Comma <_elem: ProtoTupleElement<"True">> if Tuple == "True" => {
            _elems.push(_elem);
            _elems
        },

        // 
        //<mut _elems: ProtoTupleElements<"True">> Comma if Tuple == "False" => {
        //    _elems.push(_elem);
        //    _elems
        //}

        <mut _elems: ProtoTupleElements<"False">> Comma <_elem: ProtoTupleElement<"False">> if Tuple == "False" => {
            _elems.push(_elem);
            _elems
        },

        <mut _elems: ProtoTupleElements<"True">> Comma <_elem: ProtoTupleElement<"False">> if Tuple == "False" => {
            _elems.push(_elem);
            _elems
        },

        <mut _elems: ProtoTupleElements<"False">> Comma <_elem: ProtoTupleElement<"True">> if Tuple == "False" => {
            _elems.push(_elem);
            _elems
        },


//        <_elems: ((<ProtoTupleElement<Tuple>> <(Comma <ProtoTupleElement<Tuple>>)*>))> => format!("{{ \"item\": \"Special\", \"name\": \"ProtoTupleElements\", \"_elems\": {} }}", format!("[{}, {}]", _elems.0, _elems.1.iter().join(", "))).unwrap_or("[]".into()),
    };

    ProtoTupleElement<Tuple>: ProtoTupleElement = {
        // A Tuple expression must be present and only be an identifier
        <_name: Expression> if Tuple == "True" => new_proto_tuple_element_expression(_name),

        <_decl: VariableDeclaration> if Tuple == "False" => new_proto_tuple_element_declaration(_decl),
        <_storage_location: StorageLocation> <_name: Identifier> if Tuple == "False" => new_proto_tuple_element_storage_location(_storage_location, _name),
        () if Tuple == "False" => new_proto_tuple_element_empty(),
    };
        
// ODOT

    HexNumberExpression: HexNumberExpression = {
// TODO This is just because the function is not prepared for 0.8.30
            <_literal: HexLiteral>  => new_hex_number_expression(<>, None),
// ODOT
        
    };

