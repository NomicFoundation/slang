        <private_keyword: PrivateKeyword>  => consumer.make_state_variable_attribute_private_keyword(<>),
        <public_keyword: PublicKeyword>  => consumer.make_state_variable_attribute_public_keyword(<>),
        <immutable_keyword: ImmutableKeyword>  => consumer.make_state_variable_attribute_immutable_keyword(<>),
