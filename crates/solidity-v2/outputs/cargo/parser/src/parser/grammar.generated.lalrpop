// Rules for section Definitions

// Rules for topic Contracts
    ContractDefinition: ContractDefinition = {
         
            <_abstract_keyword: (AbstractKeyword)?>  <_contract_keyword: ContractKeyword>  <_name: Identifier>  <_specifiers: ContractSpecifiers>  <_open_brace: OpenBrace>  <_members: ContractMembers>  <_close_brace: CloseBrace>  => new_contract_definition(<>),
        
