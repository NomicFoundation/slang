        <view_keyword: ViewKeyword>  => consumer.make_function_attribute_view_keyword(<>),
        <virtual_keyword: VirtualKeyword>  => consumer.make_function_attribute_virtual_keyword(<>),
        
    };
    OverrideSpecifier: C::OverrideSpecifier = {
