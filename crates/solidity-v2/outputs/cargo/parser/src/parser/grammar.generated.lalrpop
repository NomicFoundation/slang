// TODO[1] See the note at `StateVariableDefinition`, we're using this to count for
// used attributes
    StateVariableAttributes<Vis>: StateVariableAttributes = {
        // <_ConstantKeyword: ConstantKeyword> <_other: StateVariableAttributes<Vis, "True">> if Const == "False" => format!("{{ \"item\": \"Repeated\", \"name\": \"StateVariableAttributes\", \"_StateVariableAttribute\": {} }}", format!("[{}]", _StateVariableAttribute.join(", "))),

        <_InternalKeyword: InternalKeyword> <mut _other: StateVariableAttributes<"0">> if Vis ~~ "1|m" => {
            _other.elements.push(new_state_variable_attribute_internal_keyword(_InternalKeyword));
            _other
        },
        <_PrivateKeyword: PrivateKeyword>   <mut _other: StateVariableAttributes<"0">> if Vis ~~ "1|m" => {
            _other.elements.push(new_state_variable_attribute_private_keyword(_PrivateKeyword));
            _other
        },
        <_PublicKeyword: PublicKeyword>     <mut _other: StateVariableAttributes<"0">> if Vis ~~ "1|m" => {
            _other.elements.push(new_state_variable_attribute_public_keyword(_PublicKeyword));
            _other
        },

        () if Vis ~~ "0|m" => new_state_variable_attributes(vec![]),

    };
