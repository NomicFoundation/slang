    ReceiveFunctionAttribute: C::ReceiveFunctionAttribute = {
        <modifier_invocation: ModifierInvocation>  => consumer.make_receive_function_attribute_modifier_invocation(<>),
        <override_specifier: OverrideSpecifier>  => consumer.make_receive_function_attribute_override_specifier(<>),
        <external_keyword: ExternalKeyword>  => consumer.make_receive_function_attribute_external_keyword(<>),
        <payable_keyword: PayableKeyword>  => consumer.make_receive_function_attribute_payable_keyword(<>),
        <virtual_keyword: VirtualKeyword>  => consumer.make_receive_function_attribute_virtual_keyword(<>),
        
