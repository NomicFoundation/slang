// TODO[1]: Again with the attributes, we need to differentiate between a `FunctionType` that ends
// with a `returns` and one that ends with attributes, because the one that ends with attributes
// has problems in VariableDeclarationStatement
    FunctionType: FunctionType = {
        FunctionTypeInternalNoReturn<"m"> => <>,
        FunctionTypeInternalReturn => <>,
    };

    // We dont inline this to break a cycle between type names
    FunctionTypeInternalNoReturn<Vis>: FunctionType = {
            <_function_keyword: FunctionKeyword>  <_parameters: ParametersDeclaration>  <_attributes: FunctionTypeAttributes<Vis>>   => new_function_type(_function_keyword, _parameters, _attributes, None),
    };
    FunctionTypeInternalReturn: FunctionType = {
         
            <_function_keyword: FunctionKeyword>  <_parameters: ParametersDeclaration>  <_attributes: FunctionTypeAttributes<"m">>  <_returns: ReturnsDeclaration>  => new_function_type(_function_keyword, _parameters, _attributes, Some(_returns)),
        
    };
    FunctionTypeAttributes<Vis>: FunctionTypeAttributes = {
        <_InternalKeyword: InternalKeyword> <mut _other: FunctionTypeAttributes<"0">> if Vis ~~ "1|m" => {
            _other.elements.push(new_function_type_attribute_internal_keyword(_InternalKeyword));
            _other
        },
        <_ExternalKeyword: ExternalKeyword> <mut _other: FunctionTypeAttributes<"0">> if Vis ~~ "1|m" => {
            _other.elements.push(new_function_type_attribute_external_keyword(_ExternalKeyword));
            _other
        },
        <_PrivateKeyword: PrivateKeyword>   <mut _other: FunctionTypeAttributes<"0">> if Vis ~~ "1|m" => {
            _other.elements.push(new_function_type_attribute_private_keyword(_PrivateKeyword));
            _other
        },
        <_PublicKeyword: PublicKeyword>     <mut _other: FunctionTypeAttributes<"0">> if Vis ~~ "1|m" => {
            _other.elements.push(new_function_type_attribute_public_keyword(_PublicKeyword));
            _other
        },
        
        // <_PureKeyword: PureKeyword>         <_other: FunctionTypeAttributes<Vis, "True">> if Pure == "False" => format!("{{ \"item\": \"Repeated\", \"name\": \"FunctionTypeAttributes\", \"_PureKeyword\": {} }}", _PureKeyword),

        () if Vis ~~ "0|m" => new_function_type_attributes(vec![]),
        
    };
