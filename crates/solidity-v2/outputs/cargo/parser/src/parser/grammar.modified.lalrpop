    };
    YulLiteral: String = {
         
            <_YulTrueKeyword: YulTrueKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"YulLiteral\", \"_YulTrueKeyword\": {} }}", _YulTrueKeyword),
         
            <_YulFalseKeyword: YulFalseKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"YulLiteral\", \"_YulFalseKeyword\": {} }}", _YulFalseKeyword),
         
