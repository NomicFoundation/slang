// Rules for topic Yul Expressions
    YulExpression: String = {
        #[precedence(level="1")] 
            <_YulExpression: YulExpression>  <_open_paren: OpenParen>  <_arguments: YulArguments>  <_close_paren: CloseParen>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"YulExpression\", \"_YulExpression\": {}, \"_open_paren\": {}, \"_arguments\": {}, \"_close_paren\": {} }}", _YulExpression, _open_paren, _arguments, _close_paren),
        #[precedence(level="0")] 
            <_YulLiteral: YulLiteral>  => format!("{{ \"item\": \"Precedence-primary\", \"name\": \"YulExpression\", \"_YulLiteral\": {} }}", _YulLiteral),
        #[precedence(level="0")] 
            <_YulPath: YulPath>  => format!("{{ \"item\": \"Precedence-primary\", \"name\": \"YulExpression\", \"_YulPath\": {} }}", _YulPath),
        
    };
    #[inline]
    YulArguments: String = {
         
            <_YulExpression: ((<YulExpression> <(Comma <YulExpression>)*>))?>  => format!("{{ \"item\": \"Separated\", \"name\": \"YulArguments\", \"_YulExpression\": {} }}", _YulExpression.map(|x| format!("[{}, {}]", x.0, x.1.iter().join(", "))).unwrap_or("[]".into())),
        
    };
