// Rules for topic Strings
    #[inline]
    StringExpression: String = {
         
            <_StringLiterals: StringLiterals>  => format!("{{ \"item\": \"Variant\", \"name\": \"StringExpression\", \"_StringLiterals\": {} }}", _StringLiterals),
         
            <_HexStringLiterals: HexStringLiterals>  => format!("{{ \"item\": \"Variant\", \"name\": \"StringExpression\", \"_HexStringLiterals\": {} }}", _HexStringLiterals),
         
