// Rules for topic Punctuation
    




// Rules for section Definitions

// Rules for topic Contracts
#[inline]
    ContractDefinition: String = {
         
            <_abstract_keyword: (AbstractKeyword)?>  <_contract_keyword: ContractKeyword>  <_name: Identifier>  <_specifiers: ContractSpecifiers>  <_open_brace: OpenBrace>  <_members: ContractMembers>  <_close_brace: CloseBrace>  => format!("Struct(ContractDefinition)[{:?}, {:?}, {:?}, {:?}, {:?}, {:?}, {:?}]", _abstract_keyword, _contract_keyword, _name, _specifiers, _open_brace, _members, _close_brace),
        
    };
#[inline]
    ContractSpecifiers: String = {
         
            <_ContractSpecifier: (ContractSpecifier)*>  => "Repeated(ContractSpecifiers)[_ContractSpecifier]".to_string(),
        
    };
#[inline]
    ContractSpecifier: String = {
         
            <_InheritanceSpecifier: InheritanceSpecifier>  => format!("Variant(ContractSpecifier)[{:?}]", _InheritanceSpecifier),
         
            <_StorageLayoutSpecifier: StorageLayoutSpecifier>  => format!("Variant(ContractSpecifier)[{:?}]", _StorageLayoutSpecifier),
        
    };
#[inline]
    InheritanceSpecifier: String = {
         
            <_is_keyword: IsKeyword>  <_types: InheritanceTypes>  => format!("Struct(InheritanceSpecifier)[{:?}, {:?}]", _is_keyword, _types),
        
    };
#[inline]
    InheritanceTypes: String = {
         
            <_InheritanceType: (InheritanceType (Comma InheritanceType)*)>  => "Separated(InheritanceTypes)[_InheritanceType]".to_string(),
        
    };
#[inline]
    InheritanceType: String = {
         
            <_type_name: IdentifierPath>  <_arguments: (ArgumentsDeclaration)?>  => format!("Struct(InheritanceType)[{:?}, {:?}]", _type_name, _arguments),
        
    };
#[inline]
    StorageLayoutSpecifier: String = {
         
            <_layout_keyword: LayoutKeyword>  <_at_keyword: AtKeyword>  <_expression: Expression>  => format!("Struct(StorageLayoutSpecifier)[{:?}, {:?}, {:?}]", _layout_keyword, _at_keyword, _expression),
        
    };
#[inline]
    ContractMembers: String = {
         
            <_ContractMember: (ContractMember)*>  => "Repeated(ContractMembers)[_ContractMember]".to_string(),
        
    };
#[inline]
    ContractMember: String = {
         
            <_UsingDirective: UsingDirective>  => format!("Variant(ContractMember)[{:?}]", _UsingDirective),
         
            <_FunctionDefinition: FunctionDefinition>  => format!("Variant(ContractMember)[{:?}]", _FunctionDefinition),
         
            <_ConstructorDefinition: ConstructorDefinition>  => format!("Variant(ContractMember)[{:?}]", _ConstructorDefinition),
         
            <_ReceiveFunctionDefinition: ReceiveFunctionDefinition>  => format!("Variant(ContractMember)[{:?}]", _ReceiveFunctionDefinition),
         
            <_FallbackFunctionDefinition: FallbackFunctionDefinition>  => format!("Variant(ContractMember)[{:?}]", _FallbackFunctionDefinition),
         
            <_ModifierDefinition: ModifierDefinition>  => format!("Variant(ContractMember)[{:?}]", _ModifierDefinition),
         
            <_StructDefinition: StructDefinition>  => format!("Variant(ContractMember)[{:?}]", _StructDefinition),
         
            <_EnumDefinition: EnumDefinition>  => format!("Variant(ContractMember)[{:?}]", _EnumDefinition),
         
            <_EventDefinition: EventDefinition>  => format!("Variant(ContractMember)[{:?}]", _EventDefinition),
         
            <_ErrorDefinition: ErrorDefinition>  => format!("Variant(ContractMember)[{:?}]", _ErrorDefinition),
         
            <_UserDefinedValueTypeDefinition: UserDefinedValueTypeDefinition>  => format!("Variant(ContractMember)[{:?}]", _UserDefinedValueTypeDefinition),
         
            <_StateVariableDefinition: StateVariableDefinition>  => format!("Variant(ContractMember)[{:?}]", _StateVariableDefinition),
        
    };
    

// Rules for topic Interfaces
    InterfaceDefinition: String = {
         
            <_interface_keyword: InterfaceKeyword>  <_name: Identifier>  <_inheritance: (InheritanceSpecifier)?>  <_open_brace: OpenBrace>  <_members: InterfaceMembers>  <_close_brace: CloseBrace>  => format!("Struct(InterfaceDefinition)[{:?}, {:?}, {:?}, {:?}, {:?}, {:?}]", _interface_keyword, _name, _inheritance, _open_brace, _members, _close_brace),
        
    };
    InterfaceMembers: String = {
         
            <_ContractMember: (ContractMember)*>  => "Repeated(InterfaceMembers)[_ContractMember]".to_string(),
        
    };
    

// Rules for topic Libraries
    LibraryDefinition: String = {
         
            <_library_keyword: LibraryKeyword>  <_name: Identifier>  <_open_brace: OpenBrace>  <_members: LibraryMembers>  <_close_brace: CloseBrace>  => format!("Struct(LibraryDefinition)[{:?}, {:?}, {:?}, {:?}, {:?}]", _library_keyword, _name, _open_brace, _members, _close_brace),
        
    };
    LibraryMembers: String = {
         
            <_ContractMember: (ContractMember)*>  => "Repeated(LibraryMembers)[_ContractMember]".to_string(),
        
    };
    

// Rules for topic Structs
    StructDefinition: String = {
         
            <_struct_keyword: StructKeyword>  <_name: Identifier>  <_open_brace: OpenBrace>  <_members: StructMembers>  <_close_brace: CloseBrace>  => format!("Struct(StructDefinition)[{:?}, {:?}, {:?}, {:?}, {:?}]", _struct_keyword, _name, _open_brace, _members, _close_brace),
        
    };
    StructMembers: String = {
         
            <_StructMember: (StructMember)*>  => "Repeated(StructMembers)[_StructMember]".to_string(),
        
    };
    StructMember: String = {
         
            <_type_name: TypeName>  <_name: Identifier>  <_semicolon: Semicolon>  => format!("Struct(StructMember)[{:?}, {:?}, {:?}]", _type_name, _name, _semicolon),
        
    };
    

// Rules for topic Enums
    EnumDefinition: String = {
         
            <_enum_keyword: EnumKeyword>  <_name: Identifier>  <_open_brace: OpenBrace>  <_members: EnumMembers>  <_close_brace: CloseBrace>  => format!("Struct(EnumDefinition)[{:?}, {:?}, {:?}, {:?}, {:?}]", _enum_keyword, _name, _open_brace, _members, _close_brace),
        
    };
    EnumMembers: String = {
         
            <_Identifier: (Identifier (Comma Identifier)*)>  => "Separated(EnumMembers)[_Identifier]".to_string(),
        
    };
    

// Rules for topic Constants
    ConstantDefinition: String = {
         
            <_type_name: TypeName>  <_constant_keyword: ConstantKeyword>  <_name: Identifier>  <_equal: Equal>  <_value: Expression>  <_semicolon: Semicolon>  => format!("Struct(ConstantDefinition)[{:?}, {:?}, {:?}, {:?}, {:?}, {:?}]", _type_name, _constant_keyword, _name, _equal, _value, _semicolon),
        
    };
    

// Rules for topic State Variables
    StateVariableDefinition: String = {
         
            <_type_name: TypeName>  /*<_attributes: StateVariableAttributes> Removing to test conflicts*/  <_name: Identifier>  <_value: (StateVariableDefinitionValue)?>  <_semicolon: Semicolon>  => format!("Struct(StateVariableDefinition)[{:?}, {:?}, {:?}, {:?}, {:?}]", _type_name, _name, _name, _value, _semicolon),
        
    };
    StateVariableDefinitionValue: String = {
         
            <_equal: Equal>  <_value: Expression>  => format!("Struct(StateVariableDefinitionValue)[{:?}, {:?}]", _equal, _value),
        
    };
    StateVariableAttributes: String = {
         
            <_StateVariableAttribute: (StateVariableAttribute)*>  => "Repeated(StateVariableAttributes)[_StateVariableAttribute]".to_string(),
        
    };
    StateVariableAttribute: String = {
         
            <_OverrideSpecifier: OverrideSpecifier>  => format!("Variant(StateVariableAttribute)[{:?}]", _OverrideSpecifier),
         
            <_ConstantKeyword: ConstantKeyword>  => format!("Variant(StateVariableAttribute)[{:?}]", _ConstantKeyword),
         
            <_InternalKeyword: InternalKeyword>  => format!("Variant(StateVariableAttribute)[{:?}]", _InternalKeyword),
         
            <_PrivateKeyword: PrivateKeyword>  => format!("Variant(StateVariableAttribute)[{:?}]", _PrivateKeyword),
         
            <_PublicKeyword: PublicKeyword>  => format!("Variant(StateVariableAttribute)[{:?}]", _PublicKeyword),
         
            <_ImmutableKeyword: ImmutableKeyword>  => format!("Variant(StateVariableAttribute)[{:?}]", _ImmutableKeyword),
         
            <_TransientKeyword: TransientKeyword>  => format!("Variant(StateVariableAttribute)[{:?}]", _TransientKeyword),
        
    };
    

// Rules for topic Functions
    FunctionDefinition: String = {
         
            <_function_keyword: FunctionKeyword>  <_name: FunctionName>  <_parameters: ParametersDeclaration>  <_attributes: FunctionAttributes>  <_returns: (ReturnsDeclaration)?>  <_body: FunctionBody>  => format!("Struct(FunctionDefinition)[{:?}, {:?}, {:?}, {:?}, {:?}, {:?}]", _function_keyword, _name, _parameters, _attributes, _returns, _body),
        
    };
    FunctionName: String = {
         
            <_Identifier: Identifier>  => format!("Variant(FunctionName)[{:?}]", _Identifier),
         
            <_FallbackKeyword: FallbackKeyword>  => format!("Variant(FunctionName)[{:?}]", _FallbackKeyword),
         
            <_ReceiveKeyword: ReceiveKeyword>  => format!("Variant(FunctionName)[{:?}]", _ReceiveKeyword),
        
    };
    ParametersDeclaration: String = {
         
            <_open_paren: OpenParen>  <_parameters: Parameters>  <_close_paren: CloseParen>  => format!("Struct(ParametersDeclaration)[{:?}, {:?}, {:?}]", _open_paren, _parameters, _close_paren),
        
    };
    Parameters: String = {
         
            <_Parameter: (Parameter (Comma Parameter)*)>  => "Separated(Parameters)[_Parameter]".to_string(),
        
    };
    Parameter: String = {
         
            <_type_name: TypeName>  <_storage_location: (StorageLocation)?>  <_name: (Identifier)?>  => format!("Struct(Parameter)[{:?}, {:?}, {:?}]", _type_name, _storage_location, _name),
        
    };
    FunctionAttributes: String = {
         
            <_FunctionAttribute: (FunctionAttribute)*>  => "Repeated(FunctionAttributes)[_FunctionAttribute]".to_string(),
        
    };
    FunctionAttribute: String = {
         
            <_ModifierInvocation: ModifierInvocation>  => format!("Variant(FunctionAttribute)[{:?}]", _ModifierInvocation),
         
            <_OverrideSpecifier: OverrideSpecifier>  => format!("Variant(FunctionAttribute)[{:?}]", _OverrideSpecifier),
         
            <_ExternalKeyword: ExternalKeyword>  => format!("Variant(FunctionAttribute)[{:?}]", _ExternalKeyword),
         
            <_InternalKeyword: InternalKeyword>  => format!("Variant(FunctionAttribute)[{:?}]", _InternalKeyword),
         
            <_PayableKeyword: PayableKeyword>  => format!("Variant(FunctionAttribute)[{:?}]", _PayableKeyword),
         
            <_PrivateKeyword: PrivateKeyword>  => format!("Variant(FunctionAttribute)[{:?}]", _PrivateKeyword),
         
            <_PublicKeyword: PublicKeyword>  => format!("Variant(FunctionAttribute)[{:?}]", _PublicKeyword),
         
            <_PureKeyword: PureKeyword>  => format!("Variant(FunctionAttribute)[{:?}]", _PureKeyword),
         
            <_ViewKeyword: ViewKeyword>  => format!("Variant(FunctionAttribute)[{:?}]", _ViewKeyword),
         
            <_VirtualKeyword: VirtualKeyword>  => format!("Variant(FunctionAttribute)[{:?}]", _VirtualKeyword),
        
    };
    OverrideSpecifier: String = {
         
            <_override_keyword: OverrideKeyword>  <_overridden: (OverridePathsDeclaration)?>  => format!("Struct(OverrideSpecifier)[{:?}, {:?}]", _override_keyword, _overridden),
        
    };
    OverridePathsDeclaration: String = {
         
            <_open_paren: OpenParen>  <_paths: OverridePaths>  <_close_paren: CloseParen>  => format!("Struct(OverridePathsDeclaration)[{:?}, {:?}, {:?}]", _open_paren, _paths, _close_paren),
        
    };
    OverridePaths: String = {
         
            <_IdentifierPath: (IdentifierPath (Comma IdentifierPath)*)>  => "Separated(OverridePaths)[_IdentifierPath]".to_string(),
        
    };
    ReturnsDeclaration: String = {
         
            <_returns_keyword: ReturnsKeyword>  <_variables: ParametersDeclaration>  => format!("Struct(ReturnsDeclaration)[{:?}, {:?}]", _returns_keyword, _variables),
        
    };
    FunctionBody: String = {
         
            <_Block: Block>  => format!("Variant(FunctionBody)[{:?}]", _Block),
         
            <_Semicolon: Semicolon>  => format!("Variant(FunctionBody)[{:?}]", _Semicolon),
        
    };
    ConstructorDefinition: String = {
         
            <_constructor_keyword: ConstructorKeyword>  <_parameters: ParametersDeclaration>  <_attributes: ConstructorAttributes>  <_body: Block>  => format!("Struct(ConstructorDefinition)[{:?}, {:?}, {:?}, {:?}]", _constructor_keyword, _parameters, _attributes, _body),
        
    };
    ConstructorAttributes: String = {
         
            <_ConstructorAttribute: (ConstructorAttribute)*>  => "Repeated(ConstructorAttributes)[_ConstructorAttribute]".to_string(),
        
    };
    ConstructorAttribute: String = {
         
            <_ModifierInvocation: ModifierInvocation>  => format!("Variant(ConstructorAttribute)[{:?}]", _ModifierInvocation),
         
            <_InternalKeyword: InternalKeyword>  => format!("Variant(ConstructorAttribute)[{:?}]", _InternalKeyword),
         
            <_PayableKeyword: PayableKeyword>  => format!("Variant(ConstructorAttribute)[{:?}]", _PayableKeyword),
         
            <_PublicKeyword: PublicKeyword>  => format!("Variant(ConstructorAttribute)[{:?}]", _PublicKeyword),
        
    };
    FallbackFunctionDefinition: String = {
         
            <_fallback_keyword: FallbackKeyword>  <_parameters: ParametersDeclaration>  <_attributes: FallbackFunctionAttributes>  <_returns: (ReturnsDeclaration)?>  <_body: FunctionBody>  => format!("Struct(FallbackFunctionDefinition)[{:?}, {:?}, {:?}, {:?}, {:?}]", _fallback_keyword, _parameters, _attributes, _returns, _body),
        
    };
    FallbackFunctionAttributes: String = {
         
            <_FallbackFunctionAttribute: (FallbackFunctionAttribute)*>  => "Repeated(FallbackFunctionAttributes)[_FallbackFunctionAttribute]".to_string(),
        
    };
    FallbackFunctionAttribute: String = {
         
            <_ModifierInvocation: ModifierInvocation>  => format!("Variant(FallbackFunctionAttribute)[{:?}]", _ModifierInvocation),
         
            <_OverrideSpecifier: OverrideSpecifier>  => format!("Variant(FallbackFunctionAttribute)[{:?}]", _OverrideSpecifier),
         
            <_ExternalKeyword: ExternalKeyword>  => format!("Variant(FallbackFunctionAttribute)[{:?}]", _ExternalKeyword),
         
            <_PayableKeyword: PayableKeyword>  => format!("Variant(FallbackFunctionAttribute)[{:?}]", _PayableKeyword),
         
            <_PureKeyword: PureKeyword>  => format!("Variant(FallbackFunctionAttribute)[{:?}]", _PureKeyword),
         
            <_ViewKeyword: ViewKeyword>  => format!("Variant(FallbackFunctionAttribute)[{:?}]", _ViewKeyword),
         
            <_VirtualKeyword: VirtualKeyword>  => format!("Variant(FallbackFunctionAttribute)[{:?}]", _VirtualKeyword),
        
    };
    ReceiveFunctionDefinition: String = {
         
            <_receive_keyword: ReceiveKeyword>  <_parameters: ParametersDeclaration>  <_attributes: ReceiveFunctionAttributes>  <_body: FunctionBody>  => format!("Struct(ReceiveFunctionDefinition)[{:?}, {:?}, {:?}, {:?}]", _receive_keyword, _parameters, _attributes, _body),
        
    };
    ReceiveFunctionAttributes: String = {
         
            <_ReceiveFunctionAttribute: (ReceiveFunctionAttribute)*>  => "Repeated(ReceiveFunctionAttributes)[_ReceiveFunctionAttribute]".to_string(),
        
    };
    ReceiveFunctionAttribute: String = {
         
            <_ModifierInvocation: ModifierInvocation>  => format!("Variant(ReceiveFunctionAttribute)[{:?}]", _ModifierInvocation),
         
            <_OverrideSpecifier: OverrideSpecifier>  => format!("Variant(ReceiveFunctionAttribute)[{:?}]", _OverrideSpecifier),
         
            <_ExternalKeyword: ExternalKeyword>  => format!("Variant(ReceiveFunctionAttribute)[{:?}]", _ExternalKeyword),
         
            <_PayableKeyword: PayableKeyword>  => format!("Variant(ReceiveFunctionAttribute)[{:?}]", _PayableKeyword),
         
            <_VirtualKeyword: VirtualKeyword>  => format!("Variant(ReceiveFunctionAttribute)[{:?}]", _VirtualKeyword),
        
    };
    

// Rules for topic Modifiers
    ModifierDefinition: String = {
         
            <_modifier_keyword: ModifierKeyword>  <_name: Identifier>  <_parameters: (ParametersDeclaration)?>  <_attributes: ModifierAttributes>  <_body: FunctionBody>  => format!("Struct(ModifierDefinition)[{:?}, {:?}, {:?}, {:?}, {:?}]", _modifier_keyword, _name, _parameters, _attributes, _body),
        
    };
    ModifierAttributes: String = {
         
            <_ModifierAttribute: (ModifierAttribute)*>  => "Repeated(ModifierAttributes)[_ModifierAttribute]".to_string(),
        
    };
    ModifierAttribute: String = {
         
            <_OverrideSpecifier: OverrideSpecifier>  => format!("Variant(ModifierAttribute)[{:?}]", _OverrideSpecifier),
         
            <_VirtualKeyword: VirtualKeyword>  => format!("Variant(ModifierAttribute)[{:?}]", _VirtualKeyword),
        
    };
    ModifierInvocation: String = {
         
            <_name: IdentifierPath>  <_arguments: (ArgumentsDeclaration)?>  => format!("Struct(ModifierInvocation)[{:?}, {:?}]", _name, _arguments),
        
    };
    

// Rules for topic Events
    EventDefinition: String = {
         
            <_event_keyword: EventKeyword>  <_name: Identifier>  <_parameters: EventParametersDeclaration>  <_anonymous_keyword: (AnonymousKeyword)?>  <_semicolon: Semicolon>  => format!("Struct(EventDefinition)[{:?}, {:?}, {:?}, {:?}, {:?}]", _event_keyword, _name, _parameters, _anonymous_keyword, _semicolon),
        
    };
    EventParametersDeclaration: String = {
         
            <_open_paren: OpenParen>  <_parameters: EventParameters>  <_close_paren: CloseParen>  => format!("Struct(EventParametersDeclaration)[{:?}, {:?}, {:?}]", _open_paren, _parameters, _close_paren),
        
    };
    EventParameters: String = {
         
            <_EventParameter: (EventParameter (Comma EventParameter)*)>  => "Separated(EventParameters)[_EventParameter]".to_string(),
        
    };
    EventParameter: String = {
         
            <_type_name: TypeName>  <_indexed_keyword: (IndexedKeyword)?>  <_name: (Identifier)?>  => format!("Struct(EventParameter)[{:?}, {:?}, {:?}]", _type_name, _indexed_keyword, _name),
        
    };
    

// Rules for topic User Defined Value Types
    UserDefinedValueTypeDefinition: String = {
         
            <_type_keyword: TypeKeyword>  <_name: Identifier>  <_is_keyword: IsKeyword>  <_value_type: ElementaryType>  <_semicolon: Semicolon>  => format!("Struct(UserDefinedValueTypeDefinition)[{:?}, {:?}, {:?}, {:?}, {:?}]", _type_keyword, _name, _is_keyword, _value_type, _semicolon),
        
    };
    

// Rules for topic Errors
    ErrorDefinition: String = {
         
            <_error_keyword: ErrorKeyword>  <_name: Identifier>  <_members: ErrorParametersDeclaration>  <_semicolon: Semicolon>  => format!("Struct(ErrorDefinition)[{:?}, {:?}, {:?}, {:?}]", _error_keyword, _name, _members, _semicolon),
        
    };
    ErrorParametersDeclaration: String = {
         
            <_open_paren: OpenParen>  <_parameters: ErrorParameters>  <_close_paren: CloseParen>  => format!("Struct(ErrorParametersDeclaration)[{:?}, {:?}, {:?}]", _open_paren, _parameters, _close_paren),
        
    };
    ErrorParameters: String = {
         
            <_ErrorParameter: (ErrorParameter (Comma ErrorParameter)*)>  => "Separated(ErrorParameters)[_ErrorParameter]".to_string(),
        
    };
    ErrorParameter: String = {
         
            <_type_name: TypeName>  <_name: (Identifier)?>  => format!("Struct(ErrorParameter)[{:?}, {:?}]", _type_name, _name),
        
    };
    




// Rules for section Types

// Rules for topic Advanced Types
    TypeName: String = {
        // TODO: enable
        // It has problems with Access expression
        //#[precedence(level="1")] 
        //    <_TypeName: TypeName>  <_open_bracket: OpenBracket>  <_index: (Expression)?>  <_close_bracket: CloseBracket>  => format!("Precedence(ArrayTypeName)[{:?}]", _TypeName),
        #[precedence(level="0")] 
            <_FunctionType: FunctionType>  => format!("Precedence[{:?}]", _FunctionType),
        #[precedence(level="0")] 
            <_MappingType: MappingType>  => format!("Precedence[{:?}]", _MappingType),
        #[precedence(level="0")] 
            <_ElementaryType: ElementaryType>  => format!("Precedence[{:?}]", _ElementaryType),
        #[precedence(level="0")] 
            <_IdentifierPath: IdentifierPath>  => format!("Precedence[{:?}]", _IdentifierPath),
        
    };
    NewableTypeName: String = {
         
            <_NewableArrayType: NewableArrayType>  => format!("Variant(NewableTypeName)[{:?}]", _NewableArrayType),
         
            <_ElementaryType: ElementaryType>  => format!("Variant(NewableTypeName)[{:?}]", _ElementaryType),
         
            <_IdentifierPath: IdentifierPath>  => format!("Variant(NewableTypeName)[{:?}]", _IdentifierPath),
        
    };
    NewableArrayType: String = {
         
            <_type_name: TypeName>  <_open_bracket: OpenBracket>  <_close_bracket: CloseBracket>  => format!("Struct(NewableArrayType)[{:?}, {:?}, {:?}]", _type_name, _open_bracket, _close_bracket),
        
    };
    FunctionType: String = {
         
            <_function_keyword: FunctionKeyword>  <_parameters: ParametersDeclaration>  <_attributes: FunctionTypeAttributes>  <_returns: (ReturnsDeclaration)?>  => format!("Struct(FunctionType)[{:?}, {:?}, {:?}, {:?}]", _function_keyword, _parameters, _attributes, _returns),
        
    };
    FunctionTypeAttributes: String = {
         
            <_FunctionTypeAttribute: (FunctionTypeAttribute)*>  => "Repeated(FunctionTypeAttributes)[_FunctionTypeAttribute]".to_string(),
        
    };
    FunctionTypeAttribute: String = {
         
            <_InternalKeyword: InternalKeyword>  => format!("Variant(FunctionTypeAttribute)[{:?}]", _InternalKeyword),
         
            <_ExternalKeyword: ExternalKeyword>  => format!("Variant(FunctionTypeAttribute)[{:?}]", _ExternalKeyword),
         
            <_PrivateKeyword: PrivateKeyword>  => format!("Variant(FunctionTypeAttribute)[{:?}]", _PrivateKeyword),
         
            <_PublicKeyword: PublicKeyword>  => format!("Variant(FunctionTypeAttribute)[{:?}]", _PublicKeyword),
         
            <_PureKeyword: PureKeyword>  => format!("Variant(FunctionTypeAttribute)[{:?}]", _PureKeyword),
         
            <_ViewKeyword: ViewKeyword>  => format!("Variant(FunctionTypeAttribute)[{:?}]", _ViewKeyword),
         
            <_PayableKeyword: PayableKeyword>  => format!("Variant(FunctionTypeAttribute)[{:?}]", _PayableKeyword),
        
    };
    MappingType: String = {
         
            <_mapping_keyword: MappingKeyword>  <_open_paren: OpenParen>  <_key_type: MappingKey>  <_equal_greater_than: EqualGreaterThan>  <_value_type: MappingValue>  <_close_paren: CloseParen>  => format!("Struct(MappingType)[{:?}, {:?}, {:?}, {:?}, {:?}, {:?}]", _mapping_keyword, _open_paren, _key_type, _equal_greater_than, _value_type, _close_paren),
        
    };
    MappingKey: String = {
         
            <_key_type: MappingKeyType>  <_name: (Identifier)?>  => format!("Struct(MappingKey)[{:?}, {:?}]", _key_type, _name),
        
    };
    MappingKeyType: String = {
         
            <_ElementaryType: ElementaryType>  => format!("Variant(MappingKeyType)[{:?}]", _ElementaryType),
         
            <_IdentifierPath: IdentifierPath>  => format!("Variant(MappingKeyType)[{:?}]", _IdentifierPath),
        
    };
    MappingValue: String = {
         
            <_type_name: TypeName>  <_name: (Identifier)?>  => format!("Struct(MappingValue)[{:?}, {:?}]", _type_name, _name),
        
    };
    

// Rules for topic Elementary Types
    ElementaryType: String = {
         
            <_BoolKeyword: BoolKeyword>  => format!("Variant(ElementaryType)[{:?}]", _BoolKeyword),
         
            <_StringKeyword: StringKeyword>  => format!("Variant(ElementaryType)[{:?}]", _StringKeyword),
         
            <_AddressType: AddressType>  => format!("Variant(ElementaryType)[{:?}]", _AddressType),
         
            <_BytesKeyword: BytesKeyword>  => format!("Variant(ElementaryType)[{:?}]", _BytesKeyword),
         
            <_IntKeyword: IntKeyword>  => format!("Variant(ElementaryType)[{:?}]", _IntKeyword),
         
            <_UintKeyword: UintKeyword>  => format!("Variant(ElementaryType)[{:?}]", _UintKeyword),
         
            <_FixedKeyword: FixedKeyword>  => format!("Variant(ElementaryType)[{:?}]", _FixedKeyword),
         
            <_UfixedKeyword: UfixedKeyword>  => format!("Variant(ElementaryType)[{:?}]", _UfixedKeyword),
        
    };
    AddressType: String = {
         
            <_address_keyword: AddressKeyword>  <_payable_keyword: (PayableKeyword)?>  => format!("Struct(AddressType)[{:?}, {:?}]", _address_keyword, _payable_keyword),
        
    };
    




// Rules for section Statements

// Rules for topic Blocks
    Block: String = {
         
            <_open_brace: OpenBrace>  <_statements: Statements>  <_close_brace: CloseBrace>  => format!("Struct(Block)[{:?}, {:?}, {:?}]", _open_brace, _statements, _close_brace),
        
    };
    Statements: String = {
         
            <_Statement: (Statement)*>  => "Repeated(Statements)[_Statement]".to_string(),
        
    };
    // By default statements allos dangling `if`s
    Statement = _Statement<"True">;

        // A Statement that either allows (DI == "True") or disallows (DI == "False")
        // dangling `if`s
    _Statement<DI>: String = {
         
            <_IfStatement: IfStatement<DI>>  => format!("Variant(Statement)[{:?}]", _IfStatement),
         
            <_ForStatement: ForStatement<DI>>  => format!("Variant(Statement)[{:?}]", _ForStatement),
         
            <_WhileStatement: WhileStatement<DI>>  => format!("Variant(Statement)[{:?}]", _WhileStatement),
         
            <_DoWhileStatement: DoWhileStatement>  => format!("Variant(Statement)[{:?}]", _DoWhileStatement),
         
            <_ContinueStatement: ContinueStatement>  => format!("Variant(Statement)[{:?}]", _ContinueStatement),
         
            <_BreakStatement: BreakStatement>  => format!("Variant(Statement)[{:?}]", _BreakStatement),
            
            <_ReturnStatement: ReturnStatement>  => format!("Variant(Statement)[{:?}]", _ReturnStatement),
         
            <_EmitStatement: EmitStatement>  => format!("Variant(Statement)[{:?}]", _EmitStatement),
         
            <_TryStatement: TryStatement>  => format!("Variant(Statement)[{:?}]", _TryStatement),
         
            <_RevertStatement: RevertStatement>  => format!("Variant(Statement)[{:?}]", _RevertStatement),
         
            <_AssemblyStatement: AssemblyStatement>  => format!("Variant(Statement)[{:?}]", _AssemblyStatement),
         
            <_Block: Block>  => format!("Variant(Statement)[{:?}]", _Block),
         
            <_UncheckedBlock: UncheckedBlock>  => format!("Variant(Statement)[{:?}]", _UncheckedBlock),
         
            <_TupleDeconstructionStatement: TupleDeconstructionStatement>  => format!("Variant(Statement)[{:?}]", _TupleDeconstructionStatement),
         
            <_VariableDeclarationStatement: VariableDeclarationStatement>  => format!("Variant(Statement)[{:?}]", _VariableDeclarationStatement),
         
            <_ExpressionStatement: ExpressionStatement>  => format!("Variant(Statement)[{:?}]", _ExpressionStatement),
        
    };
    UncheckedBlock: String = {
         
            <_unchecked_keyword: UncheckedKeyword>  <_block: Block>  => format!("Struct(UncheckedBlock)[{:?}, {:?}]", _unchecked_keyword, _block),
        
    };
    ExpressionStatement: String = {
         
            <_expression: Expression>  <_semicolon: Semicolon>  => format!("Struct(ExpressionStatement)[{:?}, {:?}]", _expression, _semicolon),
        
    };
    AssemblyStatement: String = {
         
            <_assembly_keyword: AssemblyKeyword>  <_label: (StringLiteral)?>  <_flags: (AssemblyFlagsDeclaration)?>  <_body: YulBlock>  => format!("Struct(AssemblyStatement)[{:?}, {:?}, {:?}, {:?}]", _assembly_keyword, _label, _flags, _body),
        
    };
    AssemblyFlagsDeclaration: String = {
         
            <_open_paren: OpenParen>  <_flags: AssemblyFlags>  <_close_paren: CloseParen>  => format!("Struct(AssemblyFlagsDeclaration)[{:?}, {:?}, {:?}]", _open_paren, _flags, _close_paren),
        
    };
    AssemblyFlags: String = {
         
            <_StringLiteral: (StringLiteral (Comma StringLiteral)*)>  => "Separated(AssemblyFlags)[_StringLiteral]".to_string(),
        
    };
    

// Rules for topic Declaration Statements
    TupleDeconstructionStatement: String = {
         
         // We may face other issues here, but for now we need to handle Tuple deconstructions over general
         // tuples, otherwise we have some conflicts
             OpenParen <_elements: TupleDeconstructionElements> CloseParen <_equal: Equal>  <_expression: Expression>  <_semicolon: Semicolon>  => format!("Struct(TupleDeconstructionStatement)[{:?}, {:?}, {:?}, {:?}]", _elements, _equal, _expression, _semicolon),
        
    };

    // TODO: delete (unless we find a better way to remove the conflict between TupleDeconstructionStatement and TupleValue)
    TupleDeconstructionElements: String = {
         // A Tuple deconstruction element must have at least one member
            Comma* <_TupleDeconstructionElement: (TupleMember (Comma TupleMember?)*)>  => "Separated(TupleDeconstructionElements)[_TupleDeconstructionElement]".to_string(),
        
    };
    //TupleDeconstructionElement: String = {
    //     
    //        <_member: (TupleMember)?>  => format!("Struct(TupleDeconstructionElement)[{:?}]", _member),
    //    
    //};
    TupleMember: String = {
         
            <_TypedTupleMember: TypedTupleMember>  => format!("Variant(TupleMember)[{:?}]", _TypedTupleMember),
         
         // TODO: research if this is allowed, if so, enable
         // This is a tuple value assigned to an expression rather than a declaration
         // However, I'm not sure what's going on with the sotrage location bit, is this allowed?
         // I think at this moment we're missing a case like:
         // ```solidity
         // uint b;
         // (b, ) = (1, 2);
         // ```
            //<_UntypedTupleMember: UntypedTupleMember>  => format!("Variant(TupleMember)[{:?}]", _UntypedTupleMember),
        
    };
    TypedTupleMember: String = {
         
            <_type_name: TypeName>  <_storage_location: (StorageLocation)?>  <_name: Identifier>  => format!("Struct(TypedTupleMember)[{:?}, {:?}, {:?}]", _type_name, _storage_location, _name),
        
    };
    UntypedTupleMember: String = {
         
            <_storage_location: (StorageLocation)?>  <_name: Identifier>  => format!("Struct(UntypedTupleMember)[{:?}, {:?}]", _storage_location, _name),
        
    };
    VariableDeclarationStatement: String = {
         
            <_variable_type: VariableDeclarationType>  <_storage_location: (StorageLocation)?>  <_name: Identifier>  <_value: (VariableDeclarationValue)?>  <_semicolon: Semicolon>  => format!("Struct(VariableDeclarationStatement)[{:?}, {:?}, {:?}, {:?}, {:?}]", _variable_type, _storage_location, _name, _value, _semicolon),
        
    };
    VariableDeclarationType: String = {
         
            <_TypeName: TypeName>  => format!("Variant(VariableDeclarationType)[{:?}]", _TypeName),
        
    };
    VariableDeclarationValue: String = {
         
            <_equal: Equal>  <_expression: Expression>  => format!("Struct(VariableDeclarationValue)[{:?}, {:?}]", _equal, _expression),
        
    };
    StorageLocation: String = {
         
            <_MemoryKeyword: MemoryKeyword>  => format!("Variant(StorageLocation)[{:?}]", _MemoryKeyword),
         
            <_StorageKeyword: StorageKeyword>  => format!("Variant(StorageLocation)[{:?}]", _StorageKeyword),
         
            <_CallDataKeyword: CallDataKeyword>  => format!("Variant(StorageLocation)[{:?}]", _CallDataKeyword),
        
    };
    

// Rules for topic Control Statements
    IfStatement<DI>: String = {
         
         // IfStatement only allows dangling `if`s (ie without an else) if DI == "True"
            <_if_keyword: IfKeyword>  <_open_paren: OpenParen>  <_condition: Expression>  <_close_paren: CloseParen>  <_body: _Statement<"True">> if DI == "True" => format!("Struct(IfStatement)[{:?}, {:?}, {:?}, {:?}, {:?}]", _if_keyword, _open_paren, _condition, _close_paren, _body),
            // If there is an `else` branch, then the `if` statemente cannot have dangling `if`s
            <_if_keyword: IfKeyword>  <_open_paren: OpenParen>  <_condition: Expression>  <_close_paren: CloseParen>  <_body: _Statement<"False">>  <_else_keyword: ElseKeyword>  <_else_branch: _Statement<DI>>  => format!("Struct(IfStatement)[{:?}, {:?}, {:?}, {:?}, {:?}, {:?}]", _if_keyword, _open_paren, _condition, _close_paren, _body, _else_branch),
        
    };
    // TODO: delete once we're sure this works
    //ElseBranch<DI>: String = {
    //     
    //        <_else_keyword: ElseKeyword>  <_body: Statement<DI>>  => format!("Struct(ElseBranch)[{:?}, {:?}]", _else_keyword, _body),
    //    
    //};
    ForStatement<DI>: String = {
         
            <_for_keyword: ForKeyword>  <_open_paren: OpenParen>  <_initialization: ForStatementInitialization>  <_condition: ForStatementCondition>  <_iterator: (Expression)?>  <_close_paren: CloseParen>  <_body: _Statement<DI>>  => format!("Struct(ForStatement)[{:?}, {:?}, {:?}, {:?}, {:?}, {:?}, {:?}]", _for_keyword, _open_paren, _initialization, _condition, _iterator, _close_paren, _body),
        
    };
    ForStatementInitialization: String = {
         
            <_TupleDeconstructionStatement: TupleDeconstructionStatement>  => format!("Variant(ForStatementInitialization)[{:?}]", _TupleDeconstructionStatement),
         
            <_VariableDeclarationStatement: VariableDeclarationStatement>  => format!("Variant(ForStatementInitialization)[{:?}]", _VariableDeclarationStatement),
         
            <_ExpressionStatement: ExpressionStatement>  => format!("Variant(ForStatementInitialization)[{:?}]", _ExpressionStatement),
         
            <_Semicolon: Semicolon>  => format!("Variant(ForStatementInitialization)[{:?}]", _Semicolon),
        
    };
    ForStatementCondition: String = {
         
            <_ExpressionStatement: ExpressionStatement>  => format!("Variant(ForStatementCondition)[{:?}]", _ExpressionStatement),
         
            <_Semicolon: Semicolon>  => format!("Variant(ForStatementCondition)[{:?}]", _Semicolon),
        
    };
    WhileStatement<DI>: String = {
         
            <_while_keyword: WhileKeyword>  <_open_paren: OpenParen>  <_condition: Expression>  <_close_paren: CloseParen>  <_body: _Statement<DI>>  => format!("Struct(WhileStatement)[{:?}, {:?}, {:?}, {:?}, {:?}]", _while_keyword, _open_paren, _condition, _close_paren, _body),
        
    };
    DoWhileStatement: String = {
         
            <_do_keyword: DoKeyword>  <_body: Statement>  <_while_keyword: WhileKeyword>  <_open_paren: OpenParen>  <_condition: Expression>  <_close_paren: CloseParen>  <_semicolon: Semicolon>  => format!("Struct(DoWhileStatement)[{:?}, {:?}, {:?}, {:?}, {:?}, {:?}, {:?}]", _do_keyword, _body, _while_keyword, _open_paren, _condition, _close_paren, _semicolon),
        
    };
    ContinueStatement: String = {
         
            <_continue_keyword: ContinueKeyword>  <_semicolon: Semicolon>  => format!("Struct(ContinueStatement)[{:?}, {:?}]", _continue_keyword, _semicolon),
        
    };
    BreakStatement: String = {
         
            <_break_keyword: BreakKeyword>  <_semicolon: Semicolon>  => format!("Struct(BreakStatement)[{:?}, {:?}]", _break_keyword, _semicolon),
        
    };
    ReturnStatement: String = {
         
            <_return_keyword: ReturnKeyword>  <_expression: (Expression)?>  <_semicolon: Semicolon>  => format!("Struct(ReturnStatement)[{:?}, {:?}, {:?}]", _return_keyword, _expression, _semicolon),
        
    };
    EmitStatement: String = {
         
            <_emit_keyword: EmitKeyword>  <_event: IdentifierPath>  <_arguments: ArgumentsDeclaration>  <_semicolon: Semicolon>  => format!("Struct(EmitStatement)[{:?}, {:?}, {:?}, {:?}]", _emit_keyword, _event, _arguments, _semicolon),
        
    };
    

// Rules for topic Error Handling
    TryStatement: String = {
         
            <_try_keyword: TryKeyword>  <_expression: Expression>  <_returns: (ReturnsDeclaration)?>  <_body: Block>  <_catch_clauses: CatchClauses>  => format!("Struct(TryStatement)[{:?}, {:?}, {:?}, {:?}, {:?}]", _try_keyword, _expression, _returns, _body, _catch_clauses),
        
    };
    CatchClauses: String = {
         
            <_CatchClause: (CatchClause)+>  => "Repeated(CatchClauses)[_CatchClause]".to_string(),
        
    };
    CatchClause: String = {
         
            <_catch_keyword: CatchKeyword>  <_error: (CatchClauseError)?>  <_body: Block>  => format!("Struct(CatchClause)[{:?}, {:?}, {:?}]", _catch_keyword, _error, _body),
        
    };
    CatchClauseError: String = {
         
            <_name: (Identifier)?>  <_parameters: ParametersDeclaration>  => format!("Struct(CatchClauseError)[{:?}, {:?}]", _name, _parameters),
        
    };
    RevertStatement: String = {
         
            <_revert_keyword: RevertKeyword>  <_error: (IdentifierPath)?>  <_arguments: ArgumentsDeclaration>  <_semicolon: Semicolon>  => format!("Struct(RevertStatement)[{:?}, {:?}, {:?}, {:?}]", _revert_keyword, _error, _arguments, _semicolon),
        
    };
    




// Rules for section Expressions

// Rules for topic Base Expressions
    Expression: String = {
        #[precedence(level="1")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: Equal>  <_Expression_2: Expression>  => format!("Precedence(AssignmentExpression)[{:?}]", _Expression),
        #[precedence(level="1")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: BarEqual>  <_Expression_2: Expression>  => format!("Precedence(AssignmentExpression)[{:?}]", _Expression),
        #[precedence(level="1")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: PlusEqual>  <_Expression_2: Expression>  => format!("Precedence(AssignmentExpression)[{:?}]", _Expression),
        #[precedence(level="1")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: MinusEqual>  <_Expression_2: Expression>  => format!("Precedence(AssignmentExpression)[{:?}]", _Expression),
        #[precedence(level="1")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: CaretEqual>  <_Expression_2: Expression>  => format!("Precedence(AssignmentExpression)[{:?}]", _Expression),
        #[precedence(level="1")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: SlashEqual>  <_Expression_2: Expression>  => format!("Precedence(AssignmentExpression)[{:?}]", _Expression),
        #[precedence(level="1")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: PercentEqual>  <_Expression_2: Expression>  => format!("Precedence(AssignmentExpression)[{:?}]", _Expression),
        #[precedence(level="1")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: AsteriskEqual>  <_Expression_2: Expression>  => format!("Precedence(AssignmentExpression)[{:?}]", _Expression),
        #[precedence(level="1")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: AmpersandEqual>  <_Expression_2: Expression>  => format!("Precedence(AssignmentExpression)[{:?}]", _Expression),
        #[precedence(level="1")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: LessThanLessThanEqual>  <_Expression_2: Expression>  => format!("Precedence(AssignmentExpression)[{:?}]", _Expression),
        #[precedence(level="1")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: GreaterThanGreaterThanEqual>  <_Expression_2: Expression>  => format!("Precedence(AssignmentExpression)[{:?}]", _Expression),
        #[precedence(level="1")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: GreaterThanGreaterThanGreaterThanEqual>  <_Expression_2: Expression>  => format!("Precedence(AssignmentExpression)[{:?}]", _Expression),
        // TODO: Not really sure the associativity is correct, we need to check
        #[precedence(level="2")] #[assoc(side="right")] 
            <_Expression: Expression>  <_question_mark: QuestionMark>  <_true_expression: Expression>  <_colon: Colon>  <_false_expression: Expression>  => format!("Precedence(ConditionalExpression)[{:?}]", _Expression),
        #[precedence(level="3")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: BarBar>  <_Expression_2: Expression>  => format!("Precedence(OrExpression)[{:?}]", _Expression),
        #[precedence(level="4")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: AmpersandAmpersand>  <_Expression_2: Expression>  => format!("Precedence(AndExpression)[{:?}]", _Expression),
        #[precedence(level="5")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: EqualEqual>  <_Expression_2: Expression>  => format!("Precedence(EqualityExpression)[{:?}]", _Expression),
        #[precedence(level="5")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: BangEqual>  <_Expression_2: Expression>  => format!("Precedence(EqualityExpression)[{:?}]", _Expression),
        #[precedence(level="6")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: LessThan>  <_Expression_2: Expression>  => format!("Precedence(InequalityExpression)[{:?}]", _Expression),
        #[precedence(level="6")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: GreaterThan>  <_Expression_2: Expression>  => format!("Precedence(InequalityExpression)[{:?}]", _Expression),
        #[precedence(level="6")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: LessThanEqual>  <_Expression_2: Expression>  => format!("Precedence(InequalityExpression)[{:?}]", _Expression),
        #[precedence(level="6")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: GreaterThanEqual>  <_Expression_2: Expression>  => format!("Precedence(InequalityExpression)[{:?}]", _Expression),
        #[precedence(level="7")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: Bar>  <_Expression_2: Expression>  => format!("Precedence(BitwiseOrExpression)[{:?}]", _Expression),
        #[precedence(level="8")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: Caret>  <_Expression_2: Expression>  => format!("Precedence(BitwiseXorExpression)[{:?}]", _Expression),
        #[precedence(level="9")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: Ampersand>  <_Expression_2: Expression>  => format!("Precedence(BitwiseAndExpression)[{:?}]", _Expression),
        #[precedence(level="10")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: LessThanLessThan>  <_Expression_2: Expression>  => format!("Precedence(ShiftExpression)[{:?}]", _Expression),
        #[precedence(level="10")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: GreaterThanGreaterThan>  <_Expression_2: Expression>  => format!("Precedence(ShiftExpression)[{:?}]", _Expression),
        #[precedence(level="10")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: GreaterThanGreaterThanGreaterThan>  <_Expression_2: Expression>  => format!("Precedence(ShiftExpression)[{:?}]", _Expression),
        #[precedence(level="11")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: Plus>  <_Expression_2: Expression>  => format!("Precedence(AdditiveExpression)[{:?}]", _Expression),
        #[precedence(level="11")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: Minus>  <_Expression_2: Expression>  => format!("Precedence(AdditiveExpression)[{:?}]", _Expression),
        #[precedence(level="12")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: Asterisk>  <_Expression_2: Expression>  => format!("Precedence(MultiplicativeExpression)[{:?}]", _Expression),
        #[precedence(level="12")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: Slash>  <_Expression_2: Expression>  => format!("Precedence(MultiplicativeExpression)[{:?}]", _Expression),
        #[precedence(level="12")] #[assoc(side="left")] 
            <_Expression: Expression>  <_operator: Percent>  <_Expression_2: Expression>  => format!("Precedence(MultiplicativeExpression)[{:?}]", _Expression),
        #[precedence(level="13")] #[assoc(side="right")] 
            <_Expression: Expression>  <_operator: AsteriskAsterisk>  <_Expression_2: Expression>  => format!("Precedence(ExponentiationExpression)[{:?}]", _Expression),
        #[precedence(level="14")] 
            <_Expression: Expression>  <_operator: PlusPlus>  => format!("Precedence(PostfixExpression)[{:?}]", _Expression),
        #[precedence(level="14")] 
            <_Expression: Expression>  <_operator: MinusMinus>  => format!("Precedence(PostfixExpression)[{:?}]", _Expression),
        #[precedence(level="15")] 
            <_operator: PlusPlus>  <_Expression: Expression>  => format!("Precedence(PrefixExpression)[{:?}]", _Expression),
        #[precedence(level="15")] 
            <_operator: MinusMinus>  <_Expression: Expression>  => format!("Precedence(PrefixExpression)[{:?}]", _Expression),
        #[precedence(level="15")] 
            <_operator: Tilde>  <_Expression: Expression>  => format!("Precedence(PrefixExpression)[{:?}]", _Expression),
        #[precedence(level="15")] 
            <_operator: Bang>  <_Expression: Expression>  => format!("Precedence(PrefixExpression)[{:?}]", _Expression),
        #[precedence(level="15")] 
            <_operator: Minus>  <_Expression: Expression>  => format!("Precedence(PrefixExpression)[{:?}]", _Expression),
        #[precedence(level="15")] 
            <_operator: DeleteKeyword>  <_Expression: Expression>  => format!("Precedence(PrefixExpression)[{:?}]", _Expression),
        #[precedence(level="16")] 
            <_Expression: Expression>  <_arguments: ArgumentsDeclaration>  => format!("Precedence(FunctionCallExpression)[{:?}]", _Expression),
        // TODO: enable, doesn't work nicely with try statements
        // in particular try foo {...} ()
        //#[precedence(level="17")] 
        //    <_Expression: Expression>  <_open_brace: OpenBrace>  <_options: CallOptions> <_close_brace: CloseBrace>  => format!("Precedence(CallOptionsExpression)[{:?}]", _Expression),
        #[precedence(level="19")] 
            <_Expression: Expression>  <_open_bracket: OpenBracket>  <_start: (Expression)?>  <_end: (IndexAccessEnd)?>  <_close_bracket: CloseBracket>  => format!("Precedence(IndexAccessExpression)[{:?}]", _Expression),
            // Make sure this works, no longer treating member access as an expression
        #[precedence(level="0")] 
            <_NewExpression: IdentifierPath>  => format!("Precedence(IdentifierPath)[{:?}]", _NewExpression),
        #[precedence(level="0")] 
            <_NewExpression: NewExpression>  => format!("Precedence[{:?}]", _NewExpression),
        #[precedence(level="0")] 
            <_TupleExpression: TupleExpression>  => format!("Precedence[{:?}]", _TupleExpression),
        #[precedence(level="0")] 
            <_TypeExpression: TypeExpression>  => format!("Precedence[{:?}]", _TypeExpression),
        #[precedence(level="0")] 
            <_ArrayExpression: ArrayExpression>  => format!("Precedence[{:?}]", _ArrayExpression),
        #[precedence(level="0")] 
            <_HexNumberExpression: HexNumberExpression>  => format!("Precedence[{:?}]", _HexNumberExpression),
        #[precedence(level="0")] 
            <_DecimalNumberExpression: DecimalNumberExpression>  => format!("Precedence[{:?}]", _DecimalNumberExpression),
        #[precedence(level="0")] 
            <_StringExpression: StringExpression>  => format!("Precedence[{:?}]", _StringExpression),
        #[precedence(level="0")] 
            <_ElementaryType: ElementaryType>  => format!("Precedence[{:?}]", _ElementaryType),
        #[precedence(level="0")] 
            <_PayableKeyword: PayableKeyword>  => format!("Precedence[{:?}]", _PayableKeyword),
        #[precedence(level="0")] 
            <_ThisKeyword: ThisKeyword>  => format!("Precedence[{:?}]", _ThisKeyword),
        #[precedence(level="0")] 
            <_SuperKeyword: SuperKeyword>  => format!("Precedence[{:?}]", _SuperKeyword),
        #[precedence(level="0")] 
            <_TrueKeyword: TrueKeyword>  => format!("Precedence[{:?}]", _TrueKeyword),
        #[precedence(level="0")] 
            <_FalseKeyword: FalseKeyword>  => format!("Precedence[{:?}]", _FalseKeyword),
            // TODO: delete
            // it's taken care by the IdentifierPath
        //#[precedence(level="0")] 
        //    <_Identifier: Identifier>  => format!("Precedence[{:?}]", _Identifier),
        
    };
    IndexAccessEnd: String = {
         
            <_colon: Colon>  <_end: (Expression)?>  => format!("Struct(IndexAccessEnd)[{:?}, {:?}]", _colon, _end),
        
    };
    

// Rules for topic Function Calls
    ArgumentsDeclaration: String = {
         
            <_PositionalArgumentsDeclaration: PositionalArgumentsDeclaration>  => format!("Variant(ArgumentsDeclaration)[{:?}]", _PositionalArgumentsDeclaration),
         
            <_NamedArgumentsDeclaration: NamedArgumentsDeclaration>  => format!("Variant(ArgumentsDeclaration)[{:?}]", _NamedArgumentsDeclaration),
        
    };
    PositionalArgumentsDeclaration: String = {
         
            <_open_paren: OpenParen>  <_arguments: PositionalArguments>  <_close_paren: CloseParen>  => format!("Struct(PositionalArgumentsDeclaration)[{:?}, {:?}, {:?}]", _open_paren, _arguments, _close_paren),
        
    };
    PositionalArguments: String = {
         
            <_Expression: (Expression (Comma Expression)*)>  => "Separated(PositionalArguments)[_Expression]".to_string(),
        
    };
    NamedArgumentsDeclaration: String = {
         
            <_open_paren: OpenParen>  <_arguments: (NamedArgumentGroup)?>  <_close_paren: CloseParen>  => format!("Struct(NamedArgumentsDeclaration)[{:?}, {:?}, {:?}]", _open_paren, _arguments, _close_paren),
        
    };
    NamedArgumentGroup: String = {
         
            <_open_brace: OpenBrace>  <_arguments: NamedArguments>  <_close_brace: CloseBrace>  => format!("Struct(NamedArgumentGroup)[{:?}, {:?}, {:?}]", _open_brace, _arguments, _close_brace),
        
    };
    NamedArguments: String = {
         
            <_NamedArgument: (NamedArgument (Comma NamedArgument)*)>  => "Separated(NamedArguments)[_NamedArgument]".to_string(),
        
    };
    CallOptions: String = {
         
            <_NamedArgument: ((NamedArgument (Comma NamedArgument)*))?>  => "Separated(CallOptions)[_NamedArgument]".to_string(),
        
    };
    NamedArgument: String = {
         
            <_name: Identifier>  <_colon: Colon>  <_value: Expression>  => format!("Struct(NamedArgument)[{:?}, {:?}, {:?}]", _name, _colon, _value),
        
    };
    

// Rules for topic Primary Expressions
    TypeExpression: String = {
         
            <_type_keyword: TypeKeyword>  <_open_paren: OpenParen>  <_type_name: TypeName>  <_close_paren: CloseParen>  => format!("Struct(TypeExpression)[{:?}, {:?}, {:?}, {:?}]", _type_keyword, _open_paren, _type_name, _close_paren),
        
    };
    NewExpression: String = {
         
         // I think this is correct, it helps disambiguate between a new expression and a index access
            <_new_keyword: NewKeyword>  <_type_name: NewableTypeName> <pos: PositionalArgumentsDeclaration> => format!("Struct(NewExpression)[{:?}, {:?}, {:?}]", _new_keyword, _type_name, pos),
        
    };
    TupleExpression: String = {
         
            <_open_paren: OpenParen>  <_items: TupleValues?>  <_close_paren: CloseParen>  => format!("Struct(TupleExpression)[{:?}, {:?}, {:?}]", _open_paren, _items, _close_paren),
        
    };
    TupleValues: String = {
         
            <_TupleValue: (TupleValue (Comma TupleValue)*)>  => "Separated(TupleValues)[_TupleValue]".to_string(),
        
    };
    TupleValue: String = {
         
         // A tuple value is an actual value, not a deconstruction
            <_expression: (Expression)>  => format!("Struct(TupleValue)[{:?}]", _expression),
        
    };
    ArrayExpression: String = {
         
            <_open_bracket: OpenBracket>  <_items: ArrayValues>  <_close_bracket: CloseBracket>  => format!("Struct(ArrayExpression)[{:?}, {:?}, {:?}]", _open_bracket, _items, _close_bracket),
        
    };
    ArrayValues: String = {
         
            <_Expression: (Expression (Comma Expression)*)>  => "Separated(ArrayValues)[_Expression]".to_string(),
        
    };
    

// Rules for topic Numbers
    HexNumberExpression: String = {
         
            <_literal: HexLiteral>  => format!("Struct(HexNumberExpression)[{:?}]", _literal),
        
    };
    DecimalNumberExpression: String = {
         
            <_literal: DecimalLiteral>  <_unit: (NumberUnit)?>  => format!("Struct(DecimalNumberExpression)[{:?}, {:?}]", _literal, _unit),
        
    };
    NumberUnit: String = {
         
            <_WeiKeyword: WeiKeyword>  => format!("Variant(NumberUnit)[{:?}]", _WeiKeyword),
         
            <_GweiKeyword: GweiKeyword>  => format!("Variant(NumberUnit)[{:?}]", _GweiKeyword),
         
            <_EtherKeyword: EtherKeyword>  => format!("Variant(NumberUnit)[{:?}]", _EtherKeyword),
         
            <_SecondsKeyword: SecondsKeyword>  => format!("Variant(NumberUnit)[{:?}]", _SecondsKeyword),
         
            <_MinutesKeyword: MinutesKeyword>  => format!("Variant(NumberUnit)[{:?}]", _MinutesKeyword),
         
            <_HoursKeyword: HoursKeyword>  => format!("Variant(NumberUnit)[{:?}]", _HoursKeyword),
         
            <_DaysKeyword: DaysKeyword>  => format!("Variant(NumberUnit)[{:?}]", _DaysKeyword),
         
            <_WeeksKeyword: WeeksKeyword>  => format!("Variant(NumberUnit)[{:?}]", _WeeksKeyword),
        
    };
    

// Rules for topic Strings
    StringExpression: String = {
         
            <_StringLiterals: StringLiterals>  => format!("Variant(StringExpression)[{:?}]", _StringLiterals),
         
            <_HexStringLiterals: HexStringLiterals>  => format!("Variant(StringExpression)[{:?}]", _HexStringLiterals),
         
            <_UnicodeStringLiterals: UnicodeStringLiterals>  => format!("Variant(StringExpression)[{:?}]", _UnicodeStringLiterals),
        
    };
    StringLiterals: String = {
         
            <_StringLiteral: (StringLiteral)+>  => "Repeated(StringLiterals)[_StringLiteral]".to_string(),
        
    };
    StringLiteral: String = {
         
            <_SingleQuotedStringLiteral: SingleQuotedStringLiteral>  => format!("Variant(StringLiteral)[{:?}]", _SingleQuotedStringLiteral),
         
            <_DoubleQuotedStringLiteral: DoubleQuotedStringLiteral>  => format!("Variant(StringLiteral)[{:?}]", _DoubleQuotedStringLiteral),
        
    };
    HexStringLiterals: String = {
         
            <_HexStringLiteral: (HexStringLiteral)+>  => "Repeated(HexStringLiterals)[_HexStringLiteral]".to_string(),
        
    };
    HexStringLiteral: String = {
         
            <_SingleQuotedHexStringLiteral: SingleQuotedHexStringLiteral>  => format!("Variant(HexStringLiteral)[{:?}]", _SingleQuotedHexStringLiteral),
         
            <_DoubleQuotedHexStringLiteral: DoubleQuotedHexStringLiteral>  => format!("Variant(HexStringLiteral)[{:?}]", _DoubleQuotedHexStringLiteral),
        
    };
    UnicodeStringLiterals: String = {
         
            <_UnicodeStringLiteral: (UnicodeStringLiteral)+>  => "Repeated(UnicodeStringLiterals)[_UnicodeStringLiteral]".to_string(),
        
    };
    UnicodeStringLiteral: String = {
         
            <_SingleQuotedUnicodeStringLiteral: SingleQuotedUnicodeStringLiteral>  => format!("Variant(UnicodeStringLiteral)[{:?}]", _SingleQuotedUnicodeStringLiteral),
         
            <_DoubleQuotedUnicodeStringLiteral: DoubleQuotedUnicodeStringLiteral>  => format!("Variant(UnicodeStringLiteral)[{:?}]", _DoubleQuotedUnicodeStringLiteral),
        
    };
    

// Rules for topic Identifiers
    IdentifierPath: String = {
         
            <_Identifier: (Identifier (Period Identifier)*)>  => "Separated(IdentifierPath)[_Identifier]".to_string(),
        
    };
    




// Rules for section Yul

// Rules for topic Yul Statements
    YulBlock: String = {
         
            <_open_brace: OpenBrace>  <_statements: YulStatements>  <_close_brace: CloseBrace>  => format!("Struct(YulBlock)[{:?}, {:?}, {:?}]", _open_brace, _statements, _close_brace),
        
    };
    YulStatements: String = {
         
            <_YulStatement: (YulStatement)*>  => "Repeated(YulStatements)[_YulStatement]".to_string(),
        
    };
    YulStatement: String = {
         
            <_YulBlock: YulBlock>  => format!("Variant(YulStatement)[{:?}]", _YulBlock),
         
            <_YulFunctionDefinition: YulFunctionDefinition>  => format!("Variant(YulStatement)[{:?}]", _YulFunctionDefinition),
         
            <_YulIfStatement: YulIfStatement>  => format!("Variant(YulStatement)[{:?}]", _YulIfStatement),
         
            <_YulForStatement: YulForStatement>  => format!("Variant(YulStatement)[{:?}]", _YulForStatement),
         
            <_YulSwitchStatement: YulSwitchStatement>  => format!("Variant(YulStatement)[{:?}]", _YulSwitchStatement),
         
            <_YulLeaveStatement: YulLeaveStatement>  => format!("Variant(YulStatement)[{:?}]", _YulLeaveStatement),
         
            <_YulBreakStatement: YulBreakStatement>  => format!("Variant(YulStatement)[{:?}]", _YulBreakStatement),
         
            <_YulContinueStatement: YulContinueStatement>  => format!("Variant(YulStatement)[{:?}]", _YulContinueStatement),
         
            <_YulVariableAssignmentStatement: YulVariableAssignmentStatement>  => format!("Variant(YulStatement)[{:?}]", _YulVariableAssignmentStatement),
         
            <_YulVariableDeclarationStatement: YulVariableDeclarationStatement>  => format!("Variant(YulStatement)[{:?}]", _YulVariableDeclarationStatement),
         
            <_YulExpression: YulExpression>  => format!("Variant(YulStatement)[{:?}]", _YulExpression),
        
    };
    YulFunctionDefinition: String = {
         
            <_function_keyword: YulFunctionKeyword>  <_name: YulIdentifier>  <_parameters: YulParametersDeclaration>  <_returns: (YulReturnsDeclaration)?>  <_body: YulBlock>  => format!("Struct(YulFunctionDefinition)[{:?}, {:?}, {:?}, {:?}, {:?}]", _function_keyword, _name, _parameters, _returns, _body),
        
    };
    YulParametersDeclaration: String = {
         
            <_open_paren: OpenParen>  <_parameters: YulParameters>  <_close_paren: CloseParen>  => format!("Struct(YulParametersDeclaration)[{:?}, {:?}, {:?}]", _open_paren, _parameters, _close_paren),
        
    };
    YulParameters: String = {
         
            <_YulIdentifier: (YulIdentifier (Comma YulIdentifier)*)>  => "Separated(YulParameters)[_YulIdentifier]".to_string(),
        
    };
    YulReturnsDeclaration: String = {
         
            <_minus_greater_than: MinusGreaterThan>  <_variables: YulVariableNames>  => format!("Struct(YulReturnsDeclaration)[{:?}, {:?}]", _minus_greater_than, _variables),
        
    };
    YulVariableNames: String = {
         
            <_YulIdentifier: (YulIdentifier (Comma YulIdentifier)*)>  => "Separated(YulVariableNames)[_YulIdentifier]".to_string(),
        
    };
    YulVariableDeclarationStatement: String = {
         
            <_let_keyword: YulLetKeyword>  <_variables: YulVariableNames>  <_value: (YulVariableDeclarationValue)?>  => format!("Struct(YulVariableDeclarationStatement)[{:?}, {:?}, {:?}]", _let_keyword, _variables, _value),
        
    };
    YulVariableDeclarationValue: String = {
         
            <_assignment: YulAssignmentOperator>  <_expression: YulExpression>  => format!("Struct(YulVariableDeclarationValue)[{:?}, {:?}]", _assignment, _expression),
        
    };
    YulVariableAssignmentStatement: String = {
         
            <_variables: YulPaths>  <_assignment: YulAssignmentOperator>  <_expression: YulExpression>  => format!("Struct(YulVariableAssignmentStatement)[{:?}, {:?}, {:?}]", _variables, _assignment, _expression),
        
    };
    YulAssignmentOperator: String = {
         
            <_ColonEqual: ColonEqual>  => format!("Variant(YulAssignmentOperator)[{:?}]", _ColonEqual),
        
    };
    YulIfStatement: String = {
         
            <_if_keyword: YulIfKeyword>  <_condition: YulExpression>  <_body: YulBlock>  => format!("Struct(YulIfStatement)[{:?}, {:?}, {:?}]", _if_keyword, _condition, _body),
        
    };
    YulForStatement: String = {
         
            <_for_keyword: YulForKeyword>  <_initialization: YulBlock>  <_condition: YulExpression>  <_iterator: YulBlock>  <_body: YulBlock>  => format!("Struct(YulForStatement)[{:?}, {:?}, {:?}, {:?}, {:?}]", _for_keyword, _initialization, _condition, _iterator, _body),
        
    };
    YulSwitchStatement: String = {
         
            <_switch_keyword: YulSwitchKeyword>  <_expression: YulExpression>  <_cases: YulSwitchCases>  => format!("Struct(YulSwitchStatement)[{:?}, {:?}, {:?}]", _switch_keyword, _expression, _cases),
        
    };
    YulSwitchCases: String = {
         
            <_YulSwitchCase: (YulSwitchCase)+>  => "Repeated(YulSwitchCases)[_YulSwitchCase]".to_string(),
        
    };
    YulSwitchCase: String = {
         
            <_YulDefaultCase: YulDefaultCase>  => format!("Variant(YulSwitchCase)[{:?}]", _YulDefaultCase),
         
            <_YulValueCase: YulValueCase>  => format!("Variant(YulSwitchCase)[{:?}]", _YulValueCase),
        
    };
    YulDefaultCase: String = {
         
            <_default_keyword: YulDefaultKeyword>  <_body: YulBlock>  => format!("Struct(YulDefaultCase)[{:?}, {:?}]", _default_keyword, _body),
        
    };
    YulValueCase: String = {
         
            <_case_keyword: YulCaseKeyword>  <_value: YulLiteral>  <_body: YulBlock>  => format!("Struct(YulValueCase)[{:?}, {:?}, {:?}]", _case_keyword, _value, _body),
        
    };
    YulLeaveStatement: String = {
         
            <_leave_keyword: YulLeaveKeyword>  => format!("Struct(YulLeaveStatement)[{:?}]", _leave_keyword),
        
    };
    YulBreakStatement: String = {
         
            <_break_keyword: YulBreakKeyword>  => format!("Struct(YulBreakStatement)[{:?}]", _break_keyword),
        
    };
    YulContinueStatement: String = {
         
            <_continue_keyword: YulContinueKeyword>  => format!("Struct(YulContinueStatement)[{:?}]", _continue_keyword),
        
    };
    

// Rules for topic Yul Expressions
    YulExpression: String = {
        #[precedence(level="1")] 
            <_YulExpression: YulExpression>  <_open_paren: OpenParen>  <_arguments: YulArguments>  <_close_paren: CloseParen>  => format!("Precedence(YulFunctionCallExpression)[{:?}]", _YulExpression),
        #[precedence(level="0")] 
            <_YulLiteral: YulLiteral>  => format!("Precedence[{:?}]", _YulLiteral),
        #[precedence(level="0")] 
            <_YulPath: YulPath>  => format!("Precedence[{:?}]", _YulPath),
        
    };
    YulArguments: String = {
         
            <_YulExpression: (YulExpression (Comma YulExpression)*)>  => "Separated(YulArguments)[_YulExpression]".to_string(),
        
    };
    YulPaths: String = {
         
            <_YulPath: (YulPath (Comma YulPath)*)>  => "Separated(YulPaths)[_YulPath]".to_string(),
        
    };
    YulPath: String = {
         
            <_YulIdentifier: (YulIdentifier (Period YulIdentifier)*)>  => "Separated(YulPath)[_YulIdentifier]".to_string(),
        
    };
    YulLiteral: String = {
         
            <_YulTrueKeyword: YulTrueKeyword>  => format!("Variant(YulLiteral)[{:?}]", _YulTrueKeyword),
         
            <_YulFalseKeyword: YulFalseKeyword>  => format!("Variant(YulLiteral)[{:?}]", _YulFalseKeyword),
         
            <_YulDecimalLiteral: YulDecimalLiteral>  => format!("Variant(YulLiteral)[{:?}]", _YulDecimalLiteral),
         
            <_YulHexLiteral: YulHexLiteral>  => format!("Variant(YulLiteral)[{:?}]", _YulHexLiteral),
         
            <_HexStringLiteral: HexStringLiteral>  => format!("Variant(YulLiteral)[{:?}]", _HexStringLiteral),
         
            <_StringLiteral: StringLiteral>  => format!("Variant(YulLiteral)[{:?}]", _StringLiteral),
        
    };
    

// Rules for topic Yul Keywords
    #[inline]
