    #[inline]
    YulLeaveStatement: String = {
         
            <_leave_keyword: YulLeaveKeyword>  => format!("{{ \"item\": \"Struct\", \"name\": \"YulLeaveStatement\", \"_leave_keyword\": {} }}", _leave_keyword),
        
