// Rules for topic Punctuation
    




// Rules for section Definitions

// Rules for topic Contracts
    #[inline]
    ContractDefinition: String = {
         
            <_abstract_keyword: (AbstractKeyword)?>  <_contract_keyword: ContractKeyword>  <_name: Identifier>  <_specifiers: ContractSpecifiers>  <_open_brace: OpenBrace>  <_members: ContractMembers>  <_close_brace: CloseBrace>  => format!("{{ \"item\": \"Struct\", \"name\": \"ContractDefinition\", \"_abstract_keyword\": {}, \"_contract_keyword\": {}, \"_name\": {}, \"_specifiers\": {}, \"_open_brace\": {}, \"_members\": {}, \"_close_brace\": {} }}", _abstract_keyword.unwrap_or("\"\"".into()), _contract_keyword, _name, _specifiers, _open_brace, _members, _close_brace),
        
    };
    #[inline]
    ContractSpecifiers: String = {
         
            <_ContractSpecifier: (<ContractSpecifier>)*>  => format!("{{ \"item\": \"Repeated\", \"name\": \"ContractSpecifiers\", \"_ContractSpecifier\": {} }}", format!("[{}]", _ContractSpecifier.join(", "))),
        
    };
    #[inline]
    ContractSpecifier: String = {
         
            <_InheritanceSpecifier: InheritanceSpecifier>  => format!("{{ \"item\": \"Variant\", \"name\": \"ContractSpecifier\", \"_InheritanceSpecifier\": {} }}", _InheritanceSpecifier),
         
            <_StorageLayoutSpecifier: StorageLayoutSpecifier>  => format!("{{ \"item\": \"Variant\", \"name\": \"ContractSpecifier\", \"_StorageLayoutSpecifier\": {} }}", _StorageLayoutSpecifier),
        
    };
    InheritanceSpecifier: String = {
         
            <_is_keyword: IsKeyword>  <_types: InheritanceTypes>  => format!("{{ \"item\": \"Struct\", \"name\": \"InheritanceSpecifier\", \"_is_keyword\": {}, \"_types\": {} }}", _is_keyword, _types),
        
    };
    #[inline]
    InheritanceTypes: String = {
         
            <_InheritanceType: (<InheritanceType> <(Comma <InheritanceType>)*>)>  => format!("{{ \"item\": \"Separated\", \"name\": \"InheritanceTypes\", \"_InheritanceType\": {} }}", format!("[{}, {}]", _InheritanceType.0, _InheritanceType.1.join(", "))),
        
    };
    #[inline]
    InheritanceType: String = {
         
            <_type_name: IdentifierPath>  <_arguments: (ArgumentsDeclaration)?>  => format!("{{ \"item\": \"Struct\", \"name\": \"InheritanceType\", \"_type_name\": {}, \"_arguments\": {} }}", _type_name, _arguments.unwrap_or("\"\"".into())),
        
    };
    #[inline]
    StorageLayoutSpecifier: String = {
         
            <_layout_keyword: LayoutKeyword>  <_at_keyword: AtKeyword>  <_expression: Expression>  => format!("{{ \"item\": \"Struct\", \"name\": \"StorageLayoutSpecifier\", \"_layout_keyword\": {}, \"_at_keyword\": {}, \"_expression\": {} }}", _layout_keyword, _at_keyword, _expression),
        
    };
    #[inline]
    ContractMembers: String = {
         
            <_ContractMember: (<ContractMember>)*>  => format!("{{ \"item\": \"Repeated\", \"name\": \"ContractMembers\", \"_ContractMember\": {} }}", format!("[{}]", _ContractMember.join(", "))),
        
    };
        // Maybe this needs to be inlined
    ContractMember: String = {
         
            <_UsingDirective: UsingDirective>  => format!("{{ \"item\": \"Variant\", \"name\": \"ContractMember\", \"_UsingDirective\": {} }}", _UsingDirective),
         
            <_FunctionDefinition: FunctionDefinition>  => format!("{{ \"item\": \"Variant\", \"name\": \"ContractMember\", \"_FunctionDefinition\": {} }}", _FunctionDefinition),
         
            <_ConstructorDefinition: ConstructorDefinition>  => format!("{{ \"item\": \"Variant\", \"name\": \"ContractMember\", \"_ConstructorDefinition\": {} }}", _ConstructorDefinition),
         
            <_ReceiveFunctionDefinition: ReceiveFunctionDefinition>  => format!("{{ \"item\": \"Variant\", \"name\": \"ContractMember\", \"_ReceiveFunctionDefinition\": {} }}", _ReceiveFunctionDefinition),
         
            <_FallbackFunctionDefinition: FallbackFunctionDefinition>  => format!("{{ \"item\": \"Variant\", \"name\": \"ContractMember\", \"_FallbackFunctionDefinition\": {} }}", _FallbackFunctionDefinition),
         
            <_ModifierDefinition: ModifierDefinition>  => format!("{{ \"item\": \"Variant\", \"name\": \"ContractMember\", \"_ModifierDefinition\": {} }}", _ModifierDefinition),
         
            <_StructDefinition: StructDefinition>  => format!("{{ \"item\": \"Variant\", \"name\": \"ContractMember\", \"_StructDefinition\": {} }}", _StructDefinition),
         
            <_EnumDefinition: EnumDefinition>  => format!("{{ \"item\": \"Variant\", \"name\": \"ContractMember\", \"_EnumDefinition\": {} }}", _EnumDefinition),
         
            <_EventDefinition: EventDefinition>  => format!("{{ \"item\": \"Variant\", \"name\": \"ContractMember\", \"_EventDefinition\": {} }}", _EventDefinition),
         
            <_ErrorDefinition: ErrorDefinition>  => format!("{{ \"item\": \"Variant\", \"name\": \"ContractMember\", \"_ErrorDefinition\": {} }}", _ErrorDefinition),
         
            <_UserDefinedValueTypeDefinition: UserDefinedValueTypeDefinition>  => format!("{{ \"item\": \"Variant\", \"name\": \"ContractMember\", \"_UserDefinedValueTypeDefinition\": {} }}", _UserDefinedValueTypeDefinition),
         
            <_StateVariableDefinition: StateVariableDefinition>  => format!("{{ \"item\": \"Variant\", \"name\": \"ContractMember\", \"_StateVariableDefinition\": {} }}", _StateVariableDefinition),
        
    };
    

// Rules for topic Interfaces
    #[inline]
    InterfaceDefinition: String = {
         
            <_interface_keyword: InterfaceKeyword>  <_name: Identifier>  <_inheritance: (InheritanceSpecifier)?>  <_open_brace: OpenBrace>  <_members: InterfaceMembers>  <_close_brace: CloseBrace>  => format!("{{ \"item\": \"Struct\", \"name\": \"InterfaceDefinition\", \"_interface_keyword\": {}, \"_name\": {}, \"_inheritance\": {}, \"_open_brace\": {}, \"_members\": {}, \"_close_brace\": {} }}", _interface_keyword, _name, _inheritance.unwrap_or("\"\"".into()), _open_brace, _members, _close_brace),
        
    };
    #[inline]
    InterfaceMembers: String = {
         
            <_ContractMember: (<ContractMember>)*>  => format!("{{ \"item\": \"Repeated\", \"name\": \"InterfaceMembers\", \"_ContractMember\": {} }}", format!("[{}]", _ContractMember.join(", "))),
        
    };
    

// Rules for topic Libraries
    #[inline]
    LibraryDefinition: String = {
         
            <_library_keyword: LibraryKeyword>  <_name: Identifier>  <_open_brace: OpenBrace>  <_members: LibraryMembers>  <_close_brace: CloseBrace>  => format!("{{ \"item\": \"Struct\", \"name\": \"LibraryDefinition\", \"_library_keyword\": {}, \"_name\": {}, \"_open_brace\": {}, \"_members\": {}, \"_close_brace\": {} }}", _library_keyword, _name, _open_brace, _members, _close_brace),
        
    };
    #[inline]
    LibraryMembers: String = {
         
            <_ContractMember: (<ContractMember>)*>  => format!("{{ \"item\": \"Repeated\", \"name\": \"LibraryMembers\", \"_ContractMember\": {} }}", format!("[{}]", _ContractMember.join(", "))),
        
    };
    

// Rules for topic Structs
    StructDefinition: String = {
         
            <_struct_keyword: StructKeyword>  <_name: Identifier>  <_open_brace: OpenBrace>  <_members: StructMembers>  <_close_brace: CloseBrace>  => format!("{{ \"item\": \"Struct\", \"name\": \"StructDefinition\", \"_struct_keyword\": {}, \"_name\": {}, \"_open_brace\": {}, \"_members\": {}, \"_close_brace\": {} }}", _struct_keyword, _name, _open_brace, _members, _close_brace),
        
    };
    #[inline]
    StructMembers: String = {
         
            <_StructMember: (<StructMember>)*>  => format!("{{ \"item\": \"Repeated\", \"name\": \"StructMembers\", \"_StructMember\": {} }}", format!("[{}]", _StructMember.join(", "))),
        
    };
    #[inline]
    StructMember: String = {
         
            <_type_name: TypeName>  <_name: Identifier>  <_semicolon: Semicolon>  => format!("{{ \"item\": \"Struct\", \"name\": \"StructMember\", \"_type_name\": {}, \"_name\": {}, \"_semicolon\": {} }}", _type_name, _name, _semicolon),
        
    };
    

// Rules for topic Enums
    EnumDefinition: String = {
         
            <_enum_keyword: EnumKeyword>  <_name: Identifier>  <_open_brace: OpenBrace>  <_members: EnumMembers>  <_close_brace: CloseBrace>  => format!("{{ \"item\": \"Struct\", \"name\": \"EnumDefinition\", \"_enum_keyword\": {}, \"_name\": {}, \"_open_brace\": {}, \"_members\": {}, \"_close_brace\": {} }}", _enum_keyword, _name, _open_brace, _members, _close_brace),
        
    };
    #[inline]
    EnumMembers: String = {
         
            <_Identifier: ((<Identifier> <(Comma <Identifier>)*>))?>  => format!("{{ \"item\": \"Separated\", \"name\": \"EnumMembers\", \"_Identifier\": {} }}", _Identifier.map(|x| format!("[{}, {}]", x.0, x.1.join(", "))).unwrap_or("[]".into())),
        
    };
    

// Rules for topic Constants
    #[inline]
    ConstantDefinition: String = {
         
            <_type_name: TypeName>  <_constant_keyword: ConstantKeyword>  <_name: Identifier>  <_equal: Equal>  <_value: Expression>  <_semicolon: Semicolon>  => format!("{{ \"item\": \"Struct\", \"name\": \"ConstantDefinition\", \"_type_name\": {}, \"_constant_keyword\": {}, \"_name\": {}, \"_equal\": {}, \"_value\": {}, \"_semicolon\": {} }}", _type_name, _constant_keyword, _name, _equal, _value, _semicolon),
        
    };
    

// Rules for topic State Variables
    #[inline]
    StateVariableDefinition: String = {
         
                // TODO: enable
            //<_type_name: TypeName>  /*<_attributes: StateVariableAttributes> Removing to test conflicts*/  <_name: Identifier>  <_value: (StateVariableDefinitionValue)?>  <_semicolon: Semicolon>  => format!("{{ \"item\": \"Struct\", \"name\": \"StateVariableDefinition\", \"_type_name\": {}, \"_attributes\": {}, \"_name\": {}, \"_value\": {}, \"_semicolon\": {} }}", _type_name, _attributes, _name, _value.unwrap_or("\"\"".into()), _semicolon),


         // If we're not using functions, then we can have all attributes
            <_type_name: TypeNameInternal<"False">>  <_attributes: StateVariableAttributes<"m">>  <_name: Identifier>  <_value: (StateVariableDefinitionValue)?>  <_semicolon: Semicolon>  => format!("{{ \"item\": \"Struct\", \"name\": \"StateVariableDefinition\", \"_type_name\": {}, \"_attributes\": {}, \"_name\": {}, \"_value\": {}, \"_semicolon\": {} }}", _type_name, _attributes, _name, _value.unwrap_or("\"\"".into()), _semicolon),
            // Otherwise, the fun begins

            // If the there is a return, the visibility doesnt really matter, it's ignored. 
            // So we can either have or not have a vis
            <_type_name: FunctionTypeInternalReturn>  <_attributes: StateVariableAttributes<"m">>  <_name: Identifier>  <_value: (StateVariableDefinitionValue)?>  <_semicolon: Semicolon>  => format!("{{ \"item\": \"Struct\", \"name\": \"StateVariableDefinition\", \"_type_name\": {}, \"_attributes\": {}, \"_name\": {}, \"_value\": {}, \"_semicolon\": {} }}", _type_name, _attributes, _name, _value.unwrap_or("\"\"".into()), _semicolon),

            // If there is no return, then we need to check the visibility
            // If there's a Vis then we can have a Vis
            <_type_name: FunctionTypeInternalNoReturn<"1">>  <_attributes: StateVariableAttributes<"m">>  <_name: Identifier>  <_value: (StateVariableDefinitionValue)?>  <_semicolon: Semicolon>  => format!("{{ \"item\": \"Struct\", \"name\": \"StateVariableDefinition\", \"_type_name\": {}, \"_attributes\": {}, \"_name\": {}, \"_value\": {}, \"_semicolon\": {} }}", _type_name, _attributes, _name, _value.unwrap_or("\"\"".into()), _semicolon),
            // If there's no Vis, then we cant have a Vis
            <_type_name: FunctionTypeInternalNoReturn<"0">>  <_attributes: StateVariableAttributes<"0">>  <_name: Identifier>  <_value: (StateVariableDefinitionValue)?>  <_semicolon: Semicolon>  => format!("{{ \"item\": \"Struct\", \"name\": \"StateVariableDefinition\", \"_type_name\": {}, \"_attributes\": {}, \"_name\": {}, \"_value\": {}, \"_semicolon\": {} }}", _type_name, _attributes, _name, _value.unwrap_or("\"\"".into()), _semicolon),
        
    };
    #[inline]
    StateVariableDefinitionValue: String = {
         
            <_equal: Equal>  <_value: Expression>  => format!("{{ \"item\": \"Struct\", \"name\": \"StateVariableDefinitionValue\", \"_equal\": {}, \"_value\": {} }}", _equal, _value),
        
    };
    #[inline]
    StateVariableAttributes<Vis>: String = {
        // <_ConstantKeyword: ConstantKeyword> <_other: StateVariableAttributes<Vis, "True">> if Const == "False" => format!("{{ \"item\": \"Repeated\", \"name\": \"StateVariableAttributes\", \"_StateVariableAttribute\": {} }}", format!("[{}]", _StateVariableAttribute.join(", "))),

        <_InternalKeyword: InternalKeyword> <_other: StateVariableAttributes<"0">> if Vis ~~ "1|m" => format!("{{ \"item\": \"Repeated\", \"name\": \"StateVariableAttributes\", \"_InternalKeyword\": {},  \"_other\": {} }}", _InternalKeyword, format!("[{}]", _other.join(", "))),
        <_PrivateKeyword: PrivateKeyword>   <_other: StateVariableAttributes<"0">> if Vis ~~ "1|m" => format!("{{ \"item\": \"Repeated\", \"name\": \"StateVariableAttributes\", \"_PrivateKeyword\": {},  \"_other\": {} }}", _PrivateKeyword, format!("[{}]", _other.join(", "))),
        <_PublicKeyword: PublicKeyword>     <_other: StateVariableAttributes<"0">> if Vis ~~ "1|m" => format!("{{ \"item\": \"Repeated\", \"name\": \"StateVariableAttributes\", \"_PublicKeyword\": {},  \"_other\": {} }}", _PublicKeyword, format!("[{}]", _other.join(", "))),

        () if Vis ~~ "0|m" => format!("{{ \"item\": \"Repeated\", \"name\": \"StateVariableAttributes\" }}"),

    };
    /*
    #[inline]
    StateVariableAttribute: String = {
         
            <_OverrideSpecifier: OverrideSpecifier>  => format!("{{ \"item\": \"Variant\", \"name\": \"StateVariableAttribute\", \"_OverrideSpecifier\": {} }}", _OverrideSpecifier),
         
            <_ConstantKeyword: ConstantKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"StateVariableAttribute\", \"_ConstantKeyword\": {} }}", _ConstantKeyword),
         
            <_InternalKeyword: InternalKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"StateVariableAttribute\", \"_InternalKeyword\": {} }}", _InternalKeyword),
         
            <_PrivateKeyword: PrivateKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"StateVariableAttribute\", \"_PrivateKeyword\": {} }}", _PrivateKeyword),
         
            <_PublicKeyword: PublicKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"StateVariableAttribute\", \"_PublicKeyword\": {} }}", _PublicKeyword),
         
            <_ImmutableKeyword: ImmutableKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"StateVariableAttribute\", \"_ImmutableKeyword\": {} }}", _ImmutableKeyword),
         
            <_TransientKeyword: TransientKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"StateVariableAttribute\", \"_TransientKeyword\": {} }}", _TransientKeyword),
        
    };
    */
    

// Rules for topic Functions
    FunctionDefinition: String = {
         
            <_function_keyword: FunctionKeyword>  <_name: FunctionName>  <_parameters: ParametersDeclaration>  <_attributes: FunctionAttributes>  <_returns: (ReturnsDeclaration)?>  <_body: FunctionBody>  => format!("{{ \"item\": \"Struct\", \"name\": \"FunctionDefinition\", \"_function_keyword\": {}, \"_name\": {}, \"_parameters\": {}, \"_attributes\": {}, \"_returns\": {}, \"_body\": {} }}", _function_keyword, _name, _parameters, _attributes, _returns.unwrap_or("\"\"".into()), _body),
        
    };
    #[inline]
    FunctionName: String = {
         
            <_Identifier: Identifier>  => format!("{{ \"item\": \"Variant\", \"name\": \"FunctionName\", \"_Identifier\": {} }}", _Identifier),
         
            <_FallbackKeyword: FallbackKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"FunctionName\", \"_FallbackKeyword\": {} }}", _FallbackKeyword),
         
            <_ReceiveKeyword: ReceiveKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"FunctionName\", \"_ReceiveKeyword\": {} }}", _ReceiveKeyword),
        
    };
    ParametersDeclaration: String = {
         
            <_open_paren: OpenParen>  <_parameters: Parameters>  <_close_paren: CloseParen>  => format!("{{ \"item\": \"Struct\", \"name\": \"ParametersDeclaration\", \"_open_paren\": {}, \"_parameters\": {}, \"_close_paren\": {} }}", _open_paren, _parameters, _close_paren),
        
    };
    #[inline]
    Parameters: String = {
         
            <_Parameter: ((<Parameter> <(Comma <Parameter>)*>))?>  => format!("{{ \"item\": \"Separated\", \"name\": \"Parameters\", \"_Parameter\": {} }}", _Parameter.map(|x| format!("[{}, {}]", x.0, x.1.join(", "))).unwrap_or("[]".into())),
        
    };
    #[inline]
    Parameter: String = {
         
            <_type_name: TypeName>  <_storage_location: (StorageLocation)?>  <_name: (Identifier)?>  => format!("{{ \"item\": \"Struct\", \"name\": \"Parameter\", \"_type_name\": {}, \"_storage_location\": {}, \"_name\": {} }}", _type_name, _storage_location.unwrap_or("\"\"".into()), _name.unwrap_or("\"\"".into())),
        
    };
    #[inline]
    FunctionAttributes: String = {
         
            <_FunctionAttribute: (<FunctionAttribute>)*>  => format!("{{ \"item\": \"Repeated\", \"name\": \"FunctionAttributes\", \"_FunctionAttribute\": {} }}", format!("[{}]", _FunctionAttribute.join(", "))),
        
    };
    #[inline]
    FunctionAttribute: String = {
         
            <_ModifierInvocation: ModifierInvocation>  => format!("{{ \"item\": \"Variant\", \"name\": \"FunctionAttribute\", \"_ModifierInvocation\": {} }}", _ModifierInvocation),
         
            <_OverrideSpecifier: OverrideSpecifier>  => format!("{{ \"item\": \"Variant\", \"name\": \"FunctionAttribute\", \"_OverrideSpecifier\": {} }}", _OverrideSpecifier),
         
            <_ExternalKeyword: ExternalKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"FunctionAttribute\", \"_ExternalKeyword\": {} }}", _ExternalKeyword),
         
            <_InternalKeyword: InternalKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"FunctionAttribute\", \"_InternalKeyword\": {} }}", _InternalKeyword),
         
            <_PayableKeyword: PayableKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"FunctionAttribute\", \"_PayableKeyword\": {} }}", _PayableKeyword),
         
            <_PrivateKeyword: PrivateKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"FunctionAttribute\", \"_PrivateKeyword\": {} }}", _PrivateKeyword),
         
            <_PublicKeyword: PublicKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"FunctionAttribute\", \"_PublicKeyword\": {} }}", _PublicKeyword),
         
            <_PureKeyword: PureKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"FunctionAttribute\", \"_PureKeyword\": {} }}", _PureKeyword),
         
            <_ViewKeyword: ViewKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"FunctionAttribute\", \"_ViewKeyword\": {} }}", _ViewKeyword),
         
            <_VirtualKeyword: VirtualKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"FunctionAttribute\", \"_VirtualKeyword\": {} }}", _VirtualKeyword),
        
    };
    OverrideSpecifier: String = {
         
            <_override_keyword: OverrideKeyword>  <_overridden: (OverridePathsDeclaration)?>  => format!("{{ \"item\": \"Struct\", \"name\": \"OverrideSpecifier\", \"_override_keyword\": {}, \"_overridden\": {} }}", _override_keyword, _overridden.unwrap_or("\"\"".into())),
        
    };
    #[inline]
    OverridePathsDeclaration: String = {
         
            <_open_paren: OpenParen>  <_paths: OverridePaths>  <_close_paren: CloseParen>  => format!("{{ \"item\": \"Struct\", \"name\": \"OverridePathsDeclaration\", \"_open_paren\": {}, \"_paths\": {}, \"_close_paren\": {} }}", _open_paren, _paths, _close_paren),
        
    };
    #[inline]
    OverridePaths: String = {
         
            <_IdentifierPath: (<IdentifierPath> <(Comma <IdentifierPath>)*>)>  => format!("{{ \"item\": \"Separated\", \"name\": \"OverridePaths\", \"_IdentifierPath\": {} }}", format!("[{}, {}]", _IdentifierPath.0, _IdentifierPath.1.join(", "))),
        
    };
    ReturnsDeclaration: String = {
         
            <_returns_keyword: ReturnsKeyword>  <_variables: ParametersDeclaration>  => format!("{{ \"item\": \"Struct\", \"name\": \"ReturnsDeclaration\", \"_returns_keyword\": {}, \"_variables\": {} }}", _returns_keyword, _variables),
        
    };
    FunctionBody: String = {
         
            <_Block: Block>  => format!("{{ \"item\": \"Variant\", \"name\": \"FunctionBody\", \"_Block\": {} }}", _Block),
         
            <_Semicolon: Semicolon>  => format!("{{ \"item\": \"Variant\", \"name\": \"FunctionBody\", \"_Semicolon\": {} }}", _Semicolon),
        
    };
    #[inline]
    ConstructorDefinition: String = {
         
            <_constructor_keyword: ConstructorKeyword>  <_parameters: ParametersDeclaration>  <_attributes: ConstructorAttributes>  <_body: Block>  => format!("{{ \"item\": \"Struct\", \"name\": \"ConstructorDefinition\", \"_constructor_keyword\": {}, \"_parameters\": {}, \"_attributes\": {}, \"_body\": {} }}", _constructor_keyword, _parameters, _attributes, _body),
        
    };
    #[inline]
    ConstructorAttributes: String = {
         
            <_ConstructorAttribute: (<ConstructorAttribute>)*>  => format!("{{ \"item\": \"Repeated\", \"name\": \"ConstructorAttributes\", \"_ConstructorAttribute\": {} }}", format!("[{}]", _ConstructorAttribute.join(", "))),
        
    };
    #[inline]
    ConstructorAttribute: String = {
         
            <_ModifierInvocation: ModifierInvocation>  => format!("{{ \"item\": \"Variant\", \"name\": \"ConstructorAttribute\", \"_ModifierInvocation\": {} }}", _ModifierInvocation),
         
            <_InternalKeyword: InternalKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"ConstructorAttribute\", \"_InternalKeyword\": {} }}", _InternalKeyword),
         
            <_PayableKeyword: PayableKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"ConstructorAttribute\", \"_PayableKeyword\": {} }}", _PayableKeyword),
         
            <_PublicKeyword: PublicKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"ConstructorAttribute\", \"_PublicKeyword\": {} }}", _PublicKeyword),
        
    };
    #[inline]
    FallbackFunctionDefinition: String = {
         
            <_fallback_keyword: FallbackKeyword>  <_parameters: ParametersDeclaration>  <_attributes: FallbackFunctionAttributes>  <_returns: (ReturnsDeclaration)?>  <_body: FunctionBody>  => format!("{{ \"item\": \"Struct\", \"name\": \"FallbackFunctionDefinition\", \"_fallback_keyword\": {}, \"_parameters\": {}, \"_attributes\": {}, \"_returns\": {}, \"_body\": {} }}", _fallback_keyword, _parameters, _attributes, _returns.unwrap_or("\"\"".into()), _body),
        
    };
    #[inline]
    FallbackFunctionAttributes: String = {
         
            <_FallbackFunctionAttribute: (<FallbackFunctionAttribute>)*>  => format!("{{ \"item\": \"Repeated\", \"name\": \"FallbackFunctionAttributes\", \"_FallbackFunctionAttribute\": {} }}", format!("[{}]", _FallbackFunctionAttribute.join(", "))),
        
    };
    #[inline]
    FallbackFunctionAttribute: String = {
         
            <_ModifierInvocation: ModifierInvocation>  => format!("{{ \"item\": \"Variant\", \"name\": \"FallbackFunctionAttribute\", \"_ModifierInvocation\": {} }}", _ModifierInvocation),
         
            <_OverrideSpecifier: OverrideSpecifier>  => format!("{{ \"item\": \"Variant\", \"name\": \"FallbackFunctionAttribute\", \"_OverrideSpecifier\": {} }}", _OverrideSpecifier),
         
            <_ExternalKeyword: ExternalKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"FallbackFunctionAttribute\", \"_ExternalKeyword\": {} }}", _ExternalKeyword),
         
            <_PayableKeyword: PayableKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"FallbackFunctionAttribute\", \"_PayableKeyword\": {} }}", _PayableKeyword),
         
            <_PureKeyword: PureKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"FallbackFunctionAttribute\", \"_PureKeyword\": {} }}", _PureKeyword),
         
            <_ViewKeyword: ViewKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"FallbackFunctionAttribute\", \"_ViewKeyword\": {} }}", _ViewKeyword),
         
            <_VirtualKeyword: VirtualKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"FallbackFunctionAttribute\", \"_VirtualKeyword\": {} }}", _VirtualKeyword),
        
    };
    #[inline]
    ReceiveFunctionDefinition: String = {
         
            <_receive_keyword: ReceiveKeyword>  <_parameters: ParametersDeclaration>  <_attributes: ReceiveFunctionAttributes>  <_body: FunctionBody>  => format!("{{ \"item\": \"Struct\", \"name\": \"ReceiveFunctionDefinition\", \"_receive_keyword\": {}, \"_parameters\": {}, \"_attributes\": {}, \"_body\": {} }}", _receive_keyword, _parameters, _attributes, _body),
        
    };
    #[inline]
    ReceiveFunctionAttributes: String = {
         
            <_ReceiveFunctionAttribute: (<ReceiveFunctionAttribute>)*>  => format!("{{ \"item\": \"Repeated\", \"name\": \"ReceiveFunctionAttributes\", \"_ReceiveFunctionAttribute\": {} }}", format!("[{}]", _ReceiveFunctionAttribute.join(", "))),
        
    };
    #[inline]
    ReceiveFunctionAttribute: String = {
         
            <_ModifierInvocation: ModifierInvocation>  => format!("{{ \"item\": \"Variant\", \"name\": \"ReceiveFunctionAttribute\", \"_ModifierInvocation\": {} }}", _ModifierInvocation),
         
            <_OverrideSpecifier: OverrideSpecifier>  => format!("{{ \"item\": \"Variant\", \"name\": \"ReceiveFunctionAttribute\", \"_OverrideSpecifier\": {} }}", _OverrideSpecifier),
         
            <_ExternalKeyword: ExternalKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"ReceiveFunctionAttribute\", \"_ExternalKeyword\": {} }}", _ExternalKeyword),
         
            <_PayableKeyword: PayableKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"ReceiveFunctionAttribute\", \"_PayableKeyword\": {} }}", _PayableKeyword),
         
            <_VirtualKeyword: VirtualKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"ReceiveFunctionAttribute\", \"_VirtualKeyword\": {} }}", _VirtualKeyword),
        
    };
    

// Rules for topic Modifiers
    #[inline]
    ModifierDefinition: String = {
         
            <_modifier_keyword: ModifierKeyword>  <_name: Identifier>  <_parameters: (ParametersDeclaration)?>  <_attributes: ModifierAttributes>  <_body: FunctionBody>  => format!("{{ \"item\": \"Struct\", \"name\": \"ModifierDefinition\", \"_modifier_keyword\": {}, \"_name\": {}, \"_parameters\": {}, \"_attributes\": {}, \"_body\": {} }}", _modifier_keyword, _name, _parameters.unwrap_or("\"\"".into()), _attributes, _body),
        
    };
    #[inline]
    ModifierAttributes: String = {
         
            <_ModifierAttribute: (<ModifierAttribute>)*>  => format!("{{ \"item\": \"Repeated\", \"name\": \"ModifierAttributes\", \"_ModifierAttribute\": {} }}", format!("[{}]", _ModifierAttribute.join(", "))),
        
    };
    #[inline]
    ModifierAttribute: String = {
         
            <_OverrideSpecifier: OverrideSpecifier>  => format!("{{ \"item\": \"Variant\", \"name\": \"ModifierAttribute\", \"_OverrideSpecifier\": {} }}", _OverrideSpecifier),
         
            <_VirtualKeyword: VirtualKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"ModifierAttribute\", \"_VirtualKeyword\": {} }}", _VirtualKeyword),
        
    };
    ModifierInvocation: String = {
         
            <_name: IdentifierPath>  <_arguments: (ArgumentsDeclaration)?>  => format!("{{ \"item\": \"Struct\", \"name\": \"ModifierInvocation\", \"_name\": {}, \"_arguments\": {} }}", _name, _arguments.unwrap_or("\"\"".into())),
        
    };
    

// Rules for topic Events
    EventDefinition: String = {
         
            <_event_keyword: EventKeyword>  <_name: Identifier>  <_parameters: EventParametersDeclaration>  <_anonymous_keyword: (AnonymousKeyword)?>  <_semicolon: Semicolon>  => format!("{{ \"item\": \"Struct\", \"name\": \"EventDefinition\", \"_event_keyword\": {}, \"_name\": {}, \"_parameters\": {}, \"_anonymous_keyword\": {}, \"_semicolon\": {} }}", _event_keyword, _name, _parameters, _anonymous_keyword.unwrap_or("\"\"".into()), _semicolon),
        
    };
    #[inline]
    EventParametersDeclaration: String = {
         
            <_open_paren: OpenParen>  <_parameters: EventParameters>  <_close_paren: CloseParen>  => format!("{{ \"item\": \"Struct\", \"name\": \"EventParametersDeclaration\", \"_open_paren\": {}, \"_parameters\": {}, \"_close_paren\": {} }}", _open_paren, _parameters, _close_paren),
        
    };
    #[inline]
    EventParameters: String = {
         
            <_EventParameter: ((<EventParameter> <(Comma <EventParameter>)*>))?>  => format!("{{ \"item\": \"Separated\", \"name\": \"EventParameters\", \"_EventParameter\": {} }}", _EventParameter.map(|x| format!("[{}, {}]", x.0, x.1.join(", "))).unwrap_or("[]".into())),
        
    };
    #[inline]
    EventParameter: String = {
         
            <_type_name: TypeName>  <_indexed_keyword: (IndexedKeyword)?>  <_name: (Identifier)?>  => format!("{{ \"item\": \"Struct\", \"name\": \"EventParameter\", \"_type_name\": {}, \"_indexed_keyword\": {}, \"_name\": {} }}", _type_name, _indexed_keyword.unwrap_or("\"\"".into()), _name.unwrap_or("\"\"".into())),
        
    };
    

// Rules for topic User Defined Value Types
    UserDefinedValueTypeDefinition: String = {
         
            <_type_keyword: TypeKeyword>  <_name: Identifier>  <_is_keyword: IsKeyword>  <_value_type: ElementaryType>  <_semicolon: Semicolon>  => format!("{{ \"item\": \"Struct\", \"name\": \"UserDefinedValueTypeDefinition\", \"_type_keyword\": {}, \"_name\": {}, \"_is_keyword\": {}, \"_value_type\": {}, \"_semicolon\": {} }}", _type_keyword, _name, _is_keyword, _value_type, _semicolon),
        
    };
    

// Rules for topic Errors
    ErrorDefinition: String = {
         
            <_error_keyword: ErrorKeyword>  <_name: Identifier>  <_members: ErrorParametersDeclaration>  <_semicolon: Semicolon>  => format!("{{ \"item\": \"Struct\", \"name\": \"ErrorDefinition\", \"_error_keyword\": {}, \"_name\": {}, \"_members\": {}, \"_semicolon\": {} }}", _error_keyword, _name, _members, _semicolon),
        
    };
    #[inline]
    ErrorParametersDeclaration: String = {
         
            <_open_paren: OpenParen>  <_parameters: ErrorParameters>  <_close_paren: CloseParen>  => format!("{{ \"item\": \"Struct\", \"name\": \"ErrorParametersDeclaration\", \"_open_paren\": {}, \"_parameters\": {}, \"_close_paren\": {} }}", _open_paren, _parameters, _close_paren),
        
    };
    #[inline]
    ErrorParameters: String = {
         
            <_ErrorParameter: ((<ErrorParameter> <(Comma <ErrorParameter>)*>))?>  => format!("{{ \"item\": \"Separated\", \"name\": \"ErrorParameters\", \"_ErrorParameter\": {} }}", _ErrorParameter.map(|x| format!("[{}, {}]", x.0, x.1.join(", "))).unwrap_or("[]".into())),
        
    };
    #[inline]
    ErrorParameter: String = {
         
            <_type_name: TypeName>  <_name: (Identifier)?>  => format!("{{ \"item\": \"Struct\", \"name\": \"ErrorParameter\", \"_type_name\": {}, \"_name\": {} }}", _type_name, _name.unwrap_or("\"\"".into())),
        
    };
    




// Rules for section Types

// Rules for topic Advanced Types

#[inline]
TypeName = TypeNameInternal<"True">;

// Inlining here makes it a lot slower, think twice
    TypeNameInternal<Func>: String = {
        // TODO: enable
        // It has problems with Access expression
            //<_TypeName: TypeName0>  <_open_bracket: OpenBracket>  <_index: (Expression)?>  <_close_bracket: CloseBracket>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"TypeName\", \"_TypeName\": {}, \"_open_bracket\": {}, \"_index\": {}, \"_close_bracket\": {} }}", _TypeName, _open_bracket, _index.unwrap_or("\"\"".into()), _close_bracket),
                        <_TypeName: TypeName0<Func>>  => _TypeName,

    }

#[inline]
    TypeName0<Func>: String = {
            <_FunctionType: FunctionType> if Func == "True" => format!("{{ \"item\": \"Precedence-primary\", \"name\": \"TypeName\", \"_FunctionType\": {} }}", _FunctionType),
            <_MappingType: MappingType>  => format!("{{ \"item\": \"Precedence-primary\", \"name\": \"TypeName\", \"_MappingType\": {} }}", _MappingType),
            <_ElementaryType: ElementaryType>  => format!("{{ \"item\": \"Precedence-primary\", \"name\": \"TypeName\", \"_ElementaryType\": {} }}", _ElementaryType),
            <_IdentifierPath: IdentifierPath>  => format!("{{ \"item\": \"Precedence-primary\", \"name\": \"TypeName\", \"_IdentifierPath\": {} }}", _IdentifierPath),
        
    };

    #[inline]
    NewableTypeName: String = {
         
            <_NewableArrayType: NewableArrayType>  => format!("{{ \"item\": \"Variant\", \"name\": \"NewableTypeName\", \"_NewableArrayType\": {} }}", _NewableArrayType),
         
            <_ElementaryType: ElementaryType>  => format!("{{ \"item\": \"Variant\", \"name\": \"NewableTypeName\", \"_ElementaryType\": {} }}", _ElementaryType),
         
            <_IdentifierPath: IdentifierPath>  => format!("{{ \"item\": \"Variant\", \"name\": \"NewableTypeName\", \"_IdentifierPath\": {} }}", _IdentifierPath),
        
    };
    #[inline]
    NewableArrayType: String = {
         
            <_type_name: TypeName>  <_open_bracket: OpenBracket>  <_close_bracket: CloseBracket>  => format!("{{ \"item\": \"Struct\", \"name\": \"NewableArrayType\", \"_type_name\": {}, \"_open_bracket\": {}, \"_close_bracket\": {} }}", _type_name, _open_bracket, _close_bracket),
        
    };

    FunctionType: String = {
        FunctionTypeInternalNoReturn<"m"> => <>,
        FunctionTypeInternalReturn => <>,
    };

    // We dont inline this to break a cycle between type names
    FunctionTypeInternalNoReturn<Vis>: String = {
            <_function_keyword: FunctionKeyword>  <_parameters: ParametersDeclaration>  <_attributes: FunctionTypeAttributes<Vis>>   => format!("{{ \"item\": \"Struct\", \"name\": \"FunctionType\", \"_function_keyword\": {}, \"_parameters\": {}, \"_attributes\": {} }}", _function_keyword, _parameters, _attributes),
    };
    FunctionTypeInternalReturn: String = {
         
            <_function_keyword: FunctionKeyword>  <_parameters: ParametersDeclaration>  <_attributes: FunctionTypeAttributes<"m">>  <_returns: ReturnsDeclaration>  => format!("{{ \"item\": \"Struct\", \"name\": \"FunctionType\", \"_function_keyword\": {}, \"_parameters\": {}, \"_attributes\": {}, \"_returns\": {} }}", _function_keyword, _parameters, _attributes, _returns),
        
    };
    #[inline]
    FunctionTypeAttributes<Vis>: String = {
        <_InternalKeyword: InternalKeyword> <_other: FunctionTypeAttributes<"0">> if Vis ~~ "1|m" => format!("{{ \"item\": \"Repeated\", \"name\": \"FunctionTypeAttributes\", \"_InternalKeyword\": {} }}", _InternalKeyword),
        <_ExternalKeyword: ExternalKeyword> <_other: FunctionTypeAttributes<"0">> if Vis ~~ "1|m" => format!("{{ \"item\": \"Repeated\", \"name\": \"FunctionTypeAttributes\", \"_ExternalKeyword\": {} }}", _ExternalKeyword),
        <_PrivateKeyword: PrivateKeyword>   <_other: FunctionTypeAttributes<"0">> if Vis ~~ "1|m" => format!("{{ \"item\": \"Repeated\", \"name\": \"FunctionTypeAttributes\", \"_PrivateKeyword\": {} }}", _PrivateKeyword),
        <_PublicKeyword: PublicKeyword>     <_other: FunctionTypeAttributes<"0">> if Vis ~~ "1|m" => format!("{{ \"item\": \"Repeated\", \"name\": \"FunctionTypeAttributes\", \"_PublicKeyword\": {} }}", _PublicKeyword),
        
        // <_PureKeyword: PureKeyword>         <_other: FunctionTypeAttributes<Vis, "True">> if Pure == "False" => format!("{{ \"item\": \"Repeated\", \"name\": \"FunctionTypeAttributes\", \"_PureKeyword\": {} }}", _PureKeyword),

        () if Vis ~~ "0|m" => format!("{{ \"item\": \"Repeated\", \"name\": \"FunctionTypeAttributes\" }}"),
        
    };
    /*
    #[inline]
    FunctionTypeAttribute: String = {
         
            <_InternalKeyword: InternalKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"FunctionTypeAttribute\", \"_InternalKeyword\": {} }}", _InternalKeyword),
         
            <_ExternalKeyword: ExternalKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"FunctionTypeAttribute\", \"_ExternalKeyword\": {} }}", _ExternalKeyword),
         
            <_PrivateKeyword: PrivateKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"FunctionTypeAttribute\", \"_PrivateKeyword\": {} }}", _PrivateKeyword),
         
            <_PublicKeyword: PublicKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"FunctionTypeAttribute\", \"_PublicKeyword\": {} }}", _PublicKeyword),
         
            <_PureKeyword: PureKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"FunctionTypeAttribute\", \"_PureKeyword\": {} }}", _PureKeyword),
         
            <_ViewKeyword: ViewKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"FunctionTypeAttribute\", \"_ViewKeyword\": {} }}", _ViewKeyword),
         
            <_PayableKeyword: PayableKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"FunctionTypeAttribute\", \"_PayableKeyword\": {} }}", _PayableKeyword),
        
    };
    */
    // We dont inline this to break a cycle between type names
    MappingType: String = {
         
            <_mapping_keyword: MappingKeyword>  <_open_paren: OpenParen>  <_key_type: MappingKey>  <_equal_greater_than: EqualGreaterThan>  <_value_type: MappingValue>  <_close_paren: CloseParen>  => format!("{{ \"item\": \"Struct\", \"name\": \"MappingType\", \"_mapping_keyword\": {}, \"_open_paren\": {}, \"_key_type\": {}, \"_equal_greater_than\": {}, \"_value_type\": {}, \"_close_paren\": {} }}", _mapping_keyword, _open_paren, _key_type, _equal_greater_than, _value_type, _close_paren),
        
    };
    #[inline]
    MappingKey: String = {
         
            <_key_type: MappingKeyType>  <_name: (Identifier)?>  => format!("{{ \"item\": \"Struct\", \"name\": \"MappingKey\", \"_key_type\": {}, \"_name\": {} }}", _key_type, _name.unwrap_or("\"\"".into())),
        
    };
    #[inline]
    MappingKeyType: String = {
         
            <_ElementaryType: ElementaryType>  => format!("{{ \"item\": \"Variant\", \"name\": \"MappingKeyType\", \"_ElementaryType\": {} }}", _ElementaryType),
         
            <_IdentifierPath: IdentifierPath>  => format!("{{ \"item\": \"Variant\", \"name\": \"MappingKeyType\", \"_IdentifierPath\": {} }}", _IdentifierPath),
        
    };
    #[inline]
    MappingValue: String = {
         
            <_type_name: TypeName>  <_name: (Identifier)?>  => format!("{{ \"item\": \"Struct\", \"name\": \"MappingValue\", \"_type_name\": {}, \"_name\": {} }}", _type_name, _name.unwrap_or("\"\"".into())),
        
    };
    

// Rules for topic Elementary Types
    ElementaryType: String = {
         
            <_BoolKeyword: BoolKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"ElementaryType\", \"_BoolKeyword\": {} }}", _BoolKeyword),
         
            <_StringKeyword: StringKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"ElementaryType\", \"_StringKeyword\": {} }}", _StringKeyword),
         
            <_AddressType: AddressType>  => format!("{{ \"item\": \"Variant\", \"name\": \"ElementaryType\", \"_AddressType\": {} }}", _AddressType),
         
            <_BytesKeyword: BytesKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"ElementaryType\", \"_BytesKeyword\": {} }}", _BytesKeyword),
         
            <_IntKeyword: IntKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"ElementaryType\", \"_IntKeyword\": {} }}", _IntKeyword),
         
            <_UintKeyword: UintKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"ElementaryType\", \"_UintKeyword\": {} }}", _UintKeyword),
         
            <_FixedKeyword: FixedKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"ElementaryType\", \"_FixedKeyword\": {} }}", _FixedKeyword),
         
            <_UfixedKeyword: UfixedKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"ElementaryType\", \"_UfixedKeyword\": {} }}", _UfixedKeyword),
        
    };
    #[inline]
    AddressType: String = {
         
            <_address_keyword: AddressKeyword>  <_payable_keyword: (PayableKeyword)?>  => format!("{{ \"item\": \"Struct\", \"name\": \"AddressType\", \"_address_keyword\": {}, \"_payable_keyword\": {} }}", _address_keyword, _payable_keyword.unwrap_or("\"\"".into())),
        
    };
    




// Rules for section Statements

// Rules for topic Blocks
    Block: String = {
         
            <_open_brace: OpenBrace>  <_statements: Statements>  <_close_brace: CloseBrace>  => format!("{{ \"item\": \"Struct\", \"name\": \"Block\", \"_open_brace\": {}, \"_statements\": {}, \"_close_brace\": {} }}", _open_brace, _statements, _close_brace),
        
    };
    #[inline]
    Statements: String = {
         
            <_Statement: (<Statement>)*>  => format!("{{ \"item\": \"Repeated\", \"name\": \"Statements\", \"_Statement\": {} }}", format!("[{}]", _Statement.join(", "))),
        
    };
        // By default statements allos dangling `if`s
    Statement = _Statement<"True">;
         
        // A Statement that either allows (DI == "True") or disallows (DI == "False")
        // dangling `if`s
    _Statement<DI>: String = {
         
            <_IfStatement: IfStatement<DI>>  => format!("{{ \"item\": \"Variant\", \"name\": \"Statement\", \"_IfStatement\": {} }}", _IfStatement),
         
            <_ForStatement: ForStatement<DI>>  => format!("{{ \"item\": \"Variant\", \"name\": \"Statement\", \"_ForStatement\": {} }}", _ForStatement),
         
            <_WhileStatement: WhileStatement<DI>>  => format!("{{ \"item\": \"Variant\", \"name\": \"Statement\", \"_WhileStatement\": {} }}", _WhileStatement),
         
            <_DoWhileStatement: DoWhileStatement>  => format!("{{ \"item\": \"Variant\", \"name\": \"Statement\", \"_DoWhileStatement\": {} }}", _DoWhileStatement),
         
            <_ContinueStatement: ContinueStatement>  => format!("{{ \"item\": \"Variant\", \"name\": \"Statement\", \"_ContinueStatement\": {} }}", _ContinueStatement),
         
            <_BreakStatement: BreakStatement>  => format!("{{ \"item\": \"Variant\", \"name\": \"Statement\", \"_BreakStatement\": {} }}", _BreakStatement),
         
            <_ReturnStatement: ReturnStatement>  => format!("{{ \"item\": \"Variant\", \"name\": \"Statement\", \"_ReturnStatement\": {} }}", _ReturnStatement),
         
            <_EmitStatement: EmitStatement>  => format!("{{ \"item\": \"Variant\", \"name\": \"Statement\", \"_EmitStatement\": {} }}", _EmitStatement),
         
            <_TryStatement: TryStatement>  => format!("{{ \"item\": \"Variant\", \"name\": \"Statement\", \"_TryStatement\": {} }}", _TryStatement),
         
            <_RevertStatement: RevertStatement>  => format!("{{ \"item\": \"Variant\", \"name\": \"Statement\", \"_RevertStatement\": {} }}", _RevertStatement),
         
            <_AssemblyStatement: AssemblyStatement>  => format!("{{ \"item\": \"Variant\", \"name\": \"Statement\", \"_AssemblyStatement\": {} }}", _AssemblyStatement),
         
            <_Block: Block>  => format!("{{ \"item\": \"Variant\", \"name\": \"Statement\", \"_Block\": {} }}", _Block),
         
            <_UncheckedBlock: UncheckedBlock>  => format!("{{ \"item\": \"Variant\", \"name\": \"Statement\", \"_UncheckedBlock\": {} }}", _UncheckedBlock),
         
            <_TupleDeconstructionStatement: TupleDeconstructionStatement>  => format!("{{ \"item\": \"Variant\", \"name\": \"Statement\", \"_TupleDeconstructionStatement\": {} }}", _TupleDeconstructionStatement),
         
            <_VariableDeclarationStatement: VariableDeclarationStatement>  => format!("{{ \"item\": \"Variant\", \"name\": \"Statement\", \"_VariableDeclarationStatement\": {} }}", _VariableDeclarationStatement),
         
            <_ExpressionStatement: ExpressionStatement>  => format!("{{ \"item\": \"Variant\", \"name\": \"Statement\", \"_ExpressionStatement\": {} }}", _ExpressionStatement),
        
    };
    #[inline]
    UncheckedBlock: String = {
         
            <_unchecked_keyword: UncheckedKeyword>  <_block: Block>  => format!("{{ \"item\": \"Struct\", \"name\": \"UncheckedBlock\", \"_unchecked_keyword\": {}, \"_block\": {} }}", _unchecked_keyword, _block),
        
    };
    ExpressionStatement: String = {
         
            <_expression: Expression>  <_semicolon: Semicolon>  => format!("{{ \"item\": \"Struct\", \"name\": \"ExpressionStatement\", \"_expression\": {}, \"_semicolon\": {} }}", _expression, _semicolon),
        
    };
    #[inline]
    AssemblyStatement: String = {
         
            <_assembly_keyword: AssemblyKeyword>  <_label: (StringLiteral)?>  <_flags: (AssemblyFlagsDeclaration)?>  <_body: YulBlock>  => format!("{{ \"item\": \"Struct\", \"name\": \"AssemblyStatement\", \"_assembly_keyword\": {}, \"_label\": {}, \"_flags\": {}, \"_body\": {} }}", _assembly_keyword, _label.unwrap_or("\"\"".into()), _flags.unwrap_or("\"\"".into()), _body),
        
    };
    #[inline]
    AssemblyFlagsDeclaration: String = {
         
            <_open_paren: OpenParen>  <_flags: AssemblyFlags>  <_close_paren: CloseParen>  => format!("{{ \"item\": \"Struct\", \"name\": \"AssemblyFlagsDeclaration\", \"_open_paren\": {}, \"_flags\": {}, \"_close_paren\": {} }}", _open_paren, _flags, _close_paren),
        
    };
    #[inline]
    AssemblyFlags: String = {
         
            <_StringLiteral: (<StringLiteral> <(Comma <StringLiteral>)*>)>  => format!("{{ \"item\": \"Separated\", \"name\": \"AssemblyFlags\", \"_StringLiteral\": {} }}", format!("[{}, {}]", _StringLiteral.0, _StringLiteral.1.join(", "))),
        
    };
    

// Rules for topic Declaration Statements
    TupleDeconstructionStatement: String = {
         
        // We may face other issues here, but for now we need to handle Tuple deconstructions over general
         // tuples, otherwise we have some conflicts
            <_open_paren: OpenParen>  <_elements: TupleDeconstructionElements>  <_close_paren: CloseParen>  <_equal: Equal>  <_expression: Expression>  <_semicolon: Semicolon>  => format!("{{ \"item\": \"Struct\", \"name\": \"TupleDeconstructionStatement\", \"_open_paren\": {}, \"_elements\": {}, \"_close_paren\": {}, \"_equal\": {}, \"_expression\": {}, \"_semicolon\": {} }}", _open_paren, _elements, _close_paren, _equal, _expression, _semicolon),
        
    };

    // TODO: delete (unless we find a better way to remove the conflict between TupleDeconstructionStatement and TupleValue)
    #[inline]
    TupleDeconstructionElements: String = {
         // A Tuple deconstruction element must have at least one member
         // TODO: The action needs to be coded bu hand
            Comma* <_TupleDeconstructionElement: (<TupleMember> <(Comma (<TupleMember>)?)*>)>  => format!("{{ \"item\": \"Separated\", \"name\": \"TupleDeconstructionElements\", \"_TupleDeconstructionElement\": {} }}", format!("[{}, {}]", _TupleDeconstructionElement.0, _TupleDeconstructionElement.1.join(", "))),
        
    };
    //#[inline]
    //TupleDeconstructionElement: String = {
    //     
    //        <_member: (TupleMember)?>  => format!("{{ \"item\": \"Struct\", \"name\": \"TupleDeconstructionElement\", \"_member\": {} }}", _member.unwrap_or("\"\"".into())),
    //    
    //};
    #[inline]
    TupleMember: String = {
         
            <_TypedTupleMember: TypedTupleMember>  => format!("{{ \"item\": \"Variant\", \"name\": \"TupleMember\", \"_TypedTupleMember\": {} }}", _TypedTupleMember),
         
         // TODO: research if this is allowed, if so, enable
         // This is a tuple value assigned to an expression rather than a declaration
         // However, I'm not sure what's going on with the sotrage location bit, is this allowed?
         // I think at this moment we're missing a case like:
         // ```solidity
         // uint b;
         // (b, ) = (1, 2);
         // ```
            //<_UntypedTupleMember: UntypedTupleMember>  => format!("{{ \"item\": \"Variant\", \"name\": \"TupleMember\", \"_UntypedTupleMember\": {} }}", _UntypedTupleMember),
        
    };
    #[inline]
    TypedTupleMember: String = {
         
            <_type_name: TypeName>  <_storage_location: (StorageLocation)?>  <_name: Identifier>  => format!("{{ \"item\": \"Struct\", \"name\": \"TypedTupleMember\", \"_type_name\": {}, \"_storage_location\": {}, \"_name\": {} }}", _type_name, _storage_location.unwrap_or("\"\"".into()), _name),
        
    };
    #[inline]
    UntypedTupleMember: String = {
         
            <_storage_location: (StorageLocation)?>  <_name: Identifier>  => format!("{{ \"item\": \"Struct\", \"name\": \"UntypedTupleMember\", \"_storage_location\": {}, \"_name\": {} }}", _storage_location.unwrap_or("\"\"".into()), _name),
        
    };
    VariableDeclarationStatement: String = {
         
            <_variable_type: VariableDeclarationType>  <_storage_location: (StorageLocation)?>  <_name: Identifier>  <_value: (VariableDeclarationValue)?>  <_semicolon: Semicolon>  => format!("{{ \"item\": \"Struct\", \"name\": \"VariableDeclarationStatement\", \"_variable_type\": {}, \"_storage_location\": {}, \"_name\": {}, \"_value\": {}, \"_semicolon\": {} }}", _variable_type, _storage_location.unwrap_or("\"\"".into()), _name, _value.unwrap_or("\"\"".into()), _semicolon),
        
    };
    #[inline]
    VariableDeclarationType: String = {
         
            <_TypeName: TypeName>  => format!("{{ \"item\": \"Variant\", \"name\": \"VariableDeclarationType\", \"_TypeName\": {} }}", _TypeName),
        
    };
    #[inline]
    VariableDeclarationValue: String = {
         
            <_equal: Equal>  <_expression: Expression>  => format!("{{ \"item\": \"Struct\", \"name\": \"VariableDeclarationValue\", \"_equal\": {}, \"_expression\": {} }}", _equal, _expression),
        
    };
    StorageLocation: String = {
         
            <_MemoryKeyword: MemoryKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"StorageLocation\", \"_MemoryKeyword\": {} }}", _MemoryKeyword),
         
            <_StorageKeyword: StorageKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"StorageLocation\", \"_StorageKeyword\": {} }}", _StorageKeyword),
         
            <_CallDataKeyword: CallDataKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"StorageLocation\", \"_CallDataKeyword\": {} }}", _CallDataKeyword),
        
    };
    

// Rules for topic Control Statements
// Maybe inline, check
    IfStatement<DI>: String = {
         
         // IfStatement only allows dangling `if`s (ie without an else) if DI == "True"
            <_if_keyword: IfKeyword>  <_open_paren: OpenParen>  <_condition: Expression>  <_close_paren: CloseParen>  <_body: _Statement<"True">> if DI == "True"  => format!("{{ \"item\": \"Struct\", \"name\": \"IfStatement\", \"_if_keyword\": {}, \"_open_paren\": {}, \"_condition\": {}, \"_close_paren\": {}, \"_body\": {} }}", _if_keyword, _open_paren, _condition, _close_paren, _body),

            // If there is an `else` branch, then the `if` statemente cannot have dangling `if`s
            <_if_keyword: IfKeyword>  <_open_paren: OpenParen>  <_condition: Expression>  <_close_paren: CloseParen>  <_body: _Statement<"False">>  ElseKeyword  <_else_branch: _Statement<DI>>  => format!("{{ \"item\": \"Struct\", \"name\": \"IfStatement\", \"_if_keyword\": {}, \"_open_paren\": {}, \"_condition\": {}, \"_close_paren\": {}, \"_body\": {}, \"_else_branch\": {} }}", _if_keyword, _open_paren, _condition, _close_paren, _body, _else_branch),
        
    };
    // TODO: delete once we're sure this works
    // #[inline]
    //ElseBranch<DI>: String = {
    //         
    //        <_else_keyword: ElseKeyword>  <_body: _Statement<DI>>  => format!("{{ \"item\": \"Struct\", \"name\": \"ElseBranch\", \"_else_keyword\": {}, \"_body\": {} }}", _else_keyword, _body),
    //        
    //};

    // TODO Maybe inline
    ForStatement<DI>: String = {
         
            <_for_keyword: ForKeyword>  <_open_paren: OpenParen>  <_initialization: ForStatementInitialization>  <_condition: ForStatementCondition>  <_iterator: (Expression)?>  <_close_paren: CloseParen>  <_body: _Statement<DI>>  => format!("{{ \"item\": \"Struct\", \"name\": \"ForStatement\", \"_for_keyword\": {}, \"_open_paren\": {}, \"_initialization\": {}, \"_condition\": {}, \"_iterator\": {}, \"_close_paren\": {}, \"_body\": {} }}", _for_keyword, _open_paren, _initialization, _condition, _iterator.unwrap_or("\"\"".into()), _close_paren, _body),
        
    };
    #[inline]
    ForStatementInitialization: String = {
         
            <_TupleDeconstructionStatement: TupleDeconstructionStatement>  => format!("{{ \"item\": \"Variant\", \"name\": \"ForStatementInitialization\", \"_TupleDeconstructionStatement\": {} }}", _TupleDeconstructionStatement),
         
            <_VariableDeclarationStatement: VariableDeclarationStatement>  => format!("{{ \"item\": \"Variant\", \"name\": \"ForStatementInitialization\", \"_VariableDeclarationStatement\": {} }}", _VariableDeclarationStatement),
         
            <_ExpressionStatement: ExpressionStatement>  => format!("{{ \"item\": \"Variant\", \"name\": \"ForStatementInitialization\", \"_ExpressionStatement\": {} }}", _ExpressionStatement),
         
            <_Semicolon: Semicolon>  => format!("{{ \"item\": \"Variant\", \"name\": \"ForStatementInitialization\", \"_Semicolon\": {} }}", _Semicolon),
        
    };
    #[inline]
    ForStatementCondition: String = {
         
            <_ExpressionStatement: ExpressionStatement>  => format!("{{ \"item\": \"Variant\", \"name\": \"ForStatementCondition\", \"_ExpressionStatement\": {} }}", _ExpressionStatement),
         
            <_Semicolon: Semicolon>  => format!("{{ \"item\": \"Variant\", \"name\": \"ForStatementCondition\", \"_Semicolon\": {} }}", _Semicolon),
        
    };
    // TODO maybe inline
    WhileStatement<DI>: String = {
         
            <_while_keyword: WhileKeyword>  <_open_paren: OpenParen>  <_condition: Expression>  <_close_paren: CloseParen>  <_body: _Statement<DI>>  => format!("{{ \"item\": \"Struct\", \"name\": \"WhileStatement\", \"_while_keyword\": {}, \"_open_paren\": {}, \"_condition\": {}, \"_close_paren\": {}, \"_body\": {} }}", _while_keyword, _open_paren, _condition, _close_paren, _body),
        
    };
    #[inline]
    DoWhileStatement: String = {
         
            <_do_keyword: DoKeyword>  <_body: Statement>  <_while_keyword: WhileKeyword>  <_open_paren: OpenParen>  <_condition: Expression>  <_close_paren: CloseParen>  <_semicolon: Semicolon>  => format!("{{ \"item\": \"Struct\", \"name\": \"DoWhileStatement\", \"_do_keyword\": {}, \"_body\": {}, \"_while_keyword\": {}, \"_open_paren\": {}, \"_condition\": {}, \"_close_paren\": {}, \"_semicolon\": {} }}", _do_keyword, _body, _while_keyword, _open_paren, _condition, _close_paren, _semicolon),
        
    };
    #[inline]
    ContinueStatement: String = {
         
            <_continue_keyword: ContinueKeyword>  <_semicolon: Semicolon>  => format!("{{ \"item\": \"Struct\", \"name\": \"ContinueStatement\", \"_continue_keyword\": {}, \"_semicolon\": {} }}", _continue_keyword, _semicolon),
        
    };
    #[inline]
    BreakStatement: String = {
         
            <_break_keyword: BreakKeyword>  <_semicolon: Semicolon>  => format!("{{ \"item\": \"Struct\", \"name\": \"BreakStatement\", \"_break_keyword\": {}, \"_semicolon\": {} }}", _break_keyword, _semicolon),
        
    };
    #[inline]
    ReturnStatement: String = {
         
            <_return_keyword: ReturnKeyword>  <_expression: (Expression)?>  <_semicolon: Semicolon>  => format!("{{ \"item\": \"Struct\", \"name\": \"ReturnStatement\", \"_return_keyword\": {}, \"_expression\": {}, \"_semicolon\": {} }}", _return_keyword, _expression.unwrap_or("\"\"".into()), _semicolon),
        
    };
    #[inline]
    EmitStatement: String = {
         
            <_emit_keyword: EmitKeyword>  <_event: IdentifierPath>  <_arguments: ArgumentsDeclaration>  <_semicolon: Semicolon>  => format!("{{ \"item\": \"Struct\", \"name\": \"EmitStatement\", \"_emit_keyword\": {}, \"_event\": {}, \"_arguments\": {}, \"_semicolon\": {} }}", _emit_keyword, _event, _arguments, _semicolon),
        
    };
    

// Rules for topic Error Handling
    #[inline]
    TryStatement: String = {
         
            <_try_keyword: TryKeyword>  <_expression: Expression>  <_returns: (ReturnsDeclaration)?>  <_body: Block>  <_catch_clauses: CatchClauses>  => format!("{{ \"item\": \"Struct\", \"name\": \"TryStatement\", \"_try_keyword\": {}, \"_expression\": {}, \"_returns\": {}, \"_body\": {}, \"_catch_clauses\": {} }}", _try_keyword, _expression, _returns.unwrap_or("\"\"".into()), _body, _catch_clauses),
        
    };
    #[inline]
    CatchClauses: String = {
         
            <_CatchClause: (<CatchClause>)+>  => format!("{{ \"item\": \"Repeated\", \"name\": \"CatchClauses\", \"_CatchClause\": {} }}", format!("[{}]", _CatchClause.join(", "))),
        
    };
    #[inline]
    CatchClause: String = {
         
            <_catch_keyword: CatchKeyword>  <_error: (CatchClauseError)?>  <_body: Block>  => format!("{{ \"item\": \"Struct\", \"name\": \"CatchClause\", \"_catch_keyword\": {}, \"_error\": {}, \"_body\": {} }}", _catch_keyword, _error.unwrap_or("\"\"".into()), _body),
        
    };
    #[inline]
    CatchClauseError: String = {
         
            <_name: (Identifier)?>  <_parameters: ParametersDeclaration>  => format!("{{ \"item\": \"Struct\", \"name\": \"CatchClauseError\", \"_name\": {}, \"_parameters\": {} }}", _name.unwrap_or("\"\"".into()), _parameters),
        
    };
    #[inline]
    RevertStatement: String = {
         
            <_revert_keyword: RevertKeyword>  <_error: (IdentifierPath)?>  <_arguments: ArgumentsDeclaration>  <_semicolon: Semicolon>  => format!("{{ \"item\": \"Struct\", \"name\": \"RevertStatement\", \"_revert_keyword\": {}, \"_error\": {}, \"_arguments\": {}, \"_semicolon\": {} }}", _revert_keyword, _error.unwrap_or("\"\"".into()), _arguments, _semicolon),
        
    };
    




// Rules for section Expressions

// Rules for topic Base Expressions

// Ident is a variable to check whether this expression allows identifier paths or not
// The problem comes from a.b.c, this can be either an identifier path or a member access, we should
// always prefer identifier paths
    Expression0<Ident>: String = {
            <_IdentifierPath: IdentifierPath> if Ident == "True" => format!("{{ \"item\": \"Precedence-primary\", \"name\": \"Expression\", \"_IdentifierPath\": {} }}", _IdentifierPath),
            <_NewExpression: NewExpression>  => format!("{{ \"item\": \"Precedence-primary\", \"name\": \"Expression\", \"_NewExpression\": {} }}", _NewExpression),
            <_TupleExpression: TupleExpression>  => format!("{{ \"item\": \"Precedence-primary\", \"name\": \"Expression\", \"_TupleExpression\": {} }}", _TupleExpression),
            <_TypeExpression: TypeExpression>  => format!("{{ \"item\": \"Precedence-primary\", \"name\": \"Expression\", \"_TypeExpression\": {} }}", _TypeExpression),
            <_ArrayExpression: ArrayExpression>  => format!("{{ \"item\": \"Precedence-primary\", \"name\": \"Expression\", \"_ArrayExpression\": {} }}", _ArrayExpression),
            <_HexNumberExpression: HexNumberExpression>  => format!("{{ \"item\": \"Precedence-primary\", \"name\": \"Expression\", \"_HexNumberExpression\": {} }}", _HexNumberExpression),
            <_DecimalNumberExpression: DecimalNumberExpression>  => format!("{{ \"item\": \"Precedence-primary\", \"name\": \"Expression\", \"_DecimalNumberExpression\": {} }}", _DecimalNumberExpression),
            <_StringExpression: StringExpression>  => format!("{{ \"item\": \"Precedence-primary\", \"name\": \"Expression\", \"_StringExpression\": {} }}", _StringExpression),
            <_ElementaryType: ElementaryType>  => format!("{{ \"item\": \"Precedence-primary\", \"name\": \"Expression\", \"_ElementaryType\": {} }}", _ElementaryType),
            <_PayableKeyword: PayableKeyword>  => format!("{{ \"item\": \"Precedence-primary\", \"name\": \"Expression\", \"_PayableKeyword\": {} }}", _PayableKeyword),
            <_ThisKeyword: ThisKeyword>  => format!("{{ \"item\": \"Precedence-primary\", \"name\": \"Expression\", \"_ThisKeyword\": {} }}", _ThisKeyword),
            <_SuperKeyword: SuperKeyword>  => format!("{{ \"item\": \"Precedence-primary\", \"name\": \"Expression\", \"_SuperKeyword\": {} }}", _SuperKeyword),
            <_TrueKeyword: TrueKeyword>  => format!("{{ \"item\": \"Precedence-primary\", \"name\": \"Expression\", \"_TrueKeyword\": {} }}", _TrueKeyword),
            <_FalseKeyword: FalseKeyword>  => format!("{{ \"item\": \"Precedence-primary\", \"name\": \"Expression\", \"_FalseKeyword\": {} }}", _FalseKeyword),
            // TODO: delete
            // it's taken care by the IdentifierPath
        //#[precedence(level="0")] 
            //<_Identifier: Identifier>  => format!("{{ \"item\": \"Precedence-primary\", \"name\": \"Expression\", \"_Identifier\": {} }}", _Identifier),

        
    };
    Expression1<Ident>: String = {
            <_Expression: Expression1<"True">>  <_operator: Equal>  <_Expression_2: Expression0<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            <_Expression: Expression1<"True">>  <_operator: BarEqual>  <_Expression_2: Expression0<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            <_Expression: Expression1<"True">>  <_operator: PlusEqual>  <_Expression_2: Expression0<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            <_Expression: Expression1<"True">>  <_operator: MinusEqual>  <_Expression_2: Expression0<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            <_Expression: Expression1<"True">>  <_operator: CaretEqual>  <_Expression_2: Expression0<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            <_Expression: Expression1<"True">>  <_operator: SlashEqual>  <_Expression_2: Expression0<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            <_Expression: Expression1<"True">>  <_operator: PercentEqual>  <_Expression_2: Expression0<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            <_Expression: Expression1<"True">>  <_operator: AsteriskEqual>  <_Expression_2: Expression0<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            <_Expression: Expression1<"True">>  <_operator: AmpersandEqual>  <_Expression_2: Expression0<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            <_Expression: Expression1<"True">>  <_operator: LessThanLessThanEqual>  <_Expression_2: Expression0<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            <_Expression: Expression1<"True">>  <_operator: GreaterThanGreaterThanEqual>  <_Expression_2: Expression0<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            <_Expression: Expression1<"True">>  <_operator: GreaterThanGreaterThanGreaterThanEqual>  <_Expression_2: Expression0<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            Expression0<Ident> => <>,
    };



    Expression2<Ident>: String = {
        // TODO: Not really sure the associativity is correct, we need to check

            <_Expression: Expression1<"True">>  <_question_mark: QuestionMark>  <_true_expression: Expression2<"True">>  <_colon: Colon>  <_false_expression: Expression2<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_question_mark\": {}, \"_true_expression\": {}, \"_colon\": {}, \"_false_expression\": {} }}", _Expression, _question_mark, _true_expression, _colon, _false_expression),
                Expression1<Ident> => <>,
    };
    Expression3<Ident>: String = {
            <_Expression: Expression3<"True">>  <_operator: BarBar>  <_Expression_2: Expression2<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            Expression2<Ident> => <>,
    };
    Expression4<Ident>: String = {
            <_Expression: Expression4<"True">>  <_operator: AmpersandAmpersand>  <_Expression_2: Expression3<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            Expression3<Ident> => <>,
    };
    Expression5<Ident>: String = {
            <_Expression: Expression5<"True">>  <_operator: EqualEqual>  <_Expression_2: Expression4<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            <_Expression: Expression5<"True">>  <_operator: BangEqual>  <_Expression_2: Expression4<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            Expression4<Ident> => <>,
    };
    Expression6<Ident>: String = {
            <_Expression: Expression6<"True">>  <_operator: LessThan>  <_Expression_2: Expression5<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            <_Expression: Expression6<"True">>  <_operator: GreaterThan>  <_Expression_2: Expression5<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            <_Expression: Expression6<"True">>  <_operator: LessThanEqual>  <_Expression_2: Expression5<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            <_Expression: Expression6<"True">>  <_operator: GreaterThanEqual>  <_Expression_2: Expression5<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            Expression5<Ident> => <>,
    };
    Expression7<Ident>: String = {
            <_Expression: Expression7<"True">>  <_operator: Bar>  <_Expression_2: Expression6<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            Expression6<Ident> => <>,
    };
    Expression8<Ident>: String = {
            <_Expression: Expression8<"True">>  <_operator: Caret>  <_Expression_2: Expression7<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            Expression7<Ident> => <>,
    };
    Expression9<Ident>: String = {
            <_Expression: Expression9<"True">>  <_operator: Ampersand>  <_Expression_2: Expression8<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            Expression8<Ident> => <>,
    };
    Expression10<Ident>: String = {
            <_Expression: Expression10<"True">>  <_operator: LessThanLessThan>  <_Expression_2: Expression9<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            <_Expression: Expression10<"True">>  <_operator: GreaterThanGreaterThan>  <_Expression_2: Expression9<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            <_Expression: Expression10<"True">>  <_operator: GreaterThanGreaterThanGreaterThan>  <_Expression_2: Expression9<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            Expression9<Ident> => <>,
    };
    Expression11<Ident>: String = {
            <_Expression: Expression11<"True">>  <_operator: Plus>  <_Expression_2: Expression10<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            <_Expression: Expression11<"True">>  <_operator: Minus>  <_Expression_2: Expression10<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            Expression10<Ident> => <>,
    };
    Expression12<Ident>: String = {
            <_Expression: Expression12<"True">>  <_operator: Asterisk>  <_Expression_2: Expression11<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            <_Expression: Expression12<"True">>  <_operator: Slash>  <_Expression_2: Expression11<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            <_Expression: Expression12<"True">>  <_operator: Percent>  <_Expression_2: Expression11<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            Expression11<Ident> => <>,
    };
    Expression13<Ident>: String = {
            <_Expression: Expression12<"True">>  <_operator: AsteriskAsterisk>  <_Expression_2: Expression13<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {}, \"_Expression_2\": {} }}", _Expression, _operator, _Expression_2),
            Expression12<Ident> => <>,
    };
    Expression14<Ident>: String = {
            <_Expression: Expression14<"True">>  <_operator: PlusPlus>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {} }}", _Expression, _operator),
            <_Expression: Expression14<"True">>  <_operator: MinusMinus>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_operator\": {} }}", _Expression, _operator),
            Expression13<Ident> => <>,
    };
    Expression15<Ident>: String = {
            <_operator: PlusPlus>  <_Expression: Expression15<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_operator\": {}, \"_Expression\": {} }}", _operator, _Expression),
            <_operator: MinusMinus>  <_Expression: Expression15<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_operator\": {}, \"_Expression\": {} }}", _operator, _Expression),
            <_operator: Tilde>  <_Expression: Expression15<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_operator\": {}, \"_Expression\": {} }}", _operator, _Expression),
            <_operator: Bang>  <_Expression: Expression15<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_operator\": {}, \"_Expression\": {} }}", _operator, _Expression),
            <_operator: Minus>  <_Expression: Expression15<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_operator\": {}, \"_Expression\": {} }}", _operator, _Expression),
            <_operator: DeleteKeyword>  <_Expression: Expression15<Ident>>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_operator\": {}, \"_Expression\": {} }}", _operator, _Expression),
            Expression14<Ident> => <>,
    };
    Expression16<Ident>: String = {
            // This sets it back to "True" since there's a separator now, is this reasonable?
            <_Expression: Expression16<"True">>  <_arguments: ArgumentsDeclaration>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_arguments\": {} }}", _Expression, _arguments),
            Expression15<Ident> => <>,
    };
    Expression17<Ident>: String = {
        // TODO: enable, doesn't work nicely with try statements
        // in particular try foo {...} ()
            //<_Expression: Expression16>  <_open_brace: OpenBrace>  <_options: CallOptions>  <_close_brace: CloseBrace>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_open_brace\": {}, \"_options\": {}, \"_close_brace\": {} }}", _Expression, _open_brace, _options, _close_brace),
            Expression16<Ident> => <>,
    };
    Expression18<Ident>: String = {
            <_Expression: Expression18<"False">>  <_period: Period>  <_member: Identifier>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_period\": {}, \"_member\": {} }}", _Expression, _period, _member),
            Expression17<Ident> => <>,
    };

    Expression19: String = {
            <_Expression: Expression19>  <_open_bracket: OpenBracket>  <_start: (Expression19)?>  <_end: (IndexAccessEnd)?>  <_close_bracket: CloseBracket>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"Expression\", \"_Expression\": {}, \"_open_bracket\": {}, \"_start\": {}, \"_end\": {}, \"_close_bracket\": {} }}", _Expression, _open_bracket, _start.unwrap_or("\"\"".into()), _end.unwrap_or("\"\"".into()), _close_bracket),
            Expression18<"True"> => <>,
    };

    #[inline]
    Expression = Expression19;
        
    #[inline]
    IndexAccessEnd: String = {
         
            <_colon: Colon>  <_end: (Expression)?>  => format!("{{ \"item\": \"Struct\", \"name\": \"IndexAccessEnd\", \"_colon\": {}, \"_end\": {} }}", _colon, _end.unwrap_or("\"\"".into())),
        
    };
    

// Rules for topic Function Calls
    ArgumentsDeclaration: String = {
         
            <_PositionalArgumentsDeclaration: PositionalArgumentsDeclaration>  => format!("{{ \"item\": \"Variant\", \"name\": \"ArgumentsDeclaration\", \"_PositionalArgumentsDeclaration\": {} }}", _PositionalArgumentsDeclaration),
         
         // TODO: enable
                // Some strange conflict
            //<_NamedArgumentsDeclaration: NamedArgumentsDeclaration>  => format!("{{ \"item\": \"Variant\", \"name\": \"ArgumentsDeclaration\", \"_NamedArgumentsDeclaration\": {} }}", _NamedArgumentsDeclaration),
        
    };
    #[inline]
    PositionalArgumentsDeclaration: String = {
         
            <_open_paren: OpenParen>  <_arguments: PositionalArguments>  <_close_paren: CloseParen>  => format!("{{ \"item\": \"Struct\", \"name\": \"PositionalArgumentsDeclaration\", \"_open_paren\": {}, \"_arguments\": {}, \"_close_paren\": {} }}", _open_paren, _arguments, _close_paren),
        
    };
    #[inline]
    PositionalArguments: String = {
         
            <_Expression: ((<Expression> <(Comma <Expression>)*>))?>  => format!("{{ \"item\": \"Separated\", \"name\": \"PositionalArguments\", \"_Expression\": {} }}", _Expression.map(|x| format!("[{}, {}]", x.0, x.1.join(", "))).unwrap_or("[]".into())),
        
    };
    #[inline]
    NamedArgumentsDeclaration: String = {
         
            <_open_paren: OpenParen>  <_arguments: NamedArgumentGroup>  <_close_paren: CloseParen>  => format!("{{ \"item\": \"Struct\", \"name\": \"NamedArgumentsDeclaration\", \"_open_paren\": {}, \"_arguments\": {}, \"_close_paren\": {} }}", _open_paren, _arguments, _close_paren),
        
    };
    #[inline]
    NamedArgumentGroup: String = {
         
            <_open_brace: OpenBrace>  <_arguments: (NamedArguments)?>  <_close_brace: CloseBrace>  => format!("{{ \"item\": \"Struct\", \"name\": \"NamedArgumentGroup\", \"_open_brace\": {}, \"_arguments\": {}, \"_close_brace\": {} }}", _open_brace, _arguments.unwrap_or("\"\"".into()), _close_brace),
        
    };
    #[inline]
    NamedArguments: String = {
         
            <_NamedArgument: ((<NamedArgument> <(Comma <NamedArgument>)*>))?>  => format!("{{ \"item\": \"Separated\", \"name\": \"NamedArguments\", \"_NamedArgument\": {} }}", _NamedArgument.map(|x| format!("[{}, {}]", x.0, x.1.join(", "))).unwrap_or("[]".into())),
        
    };
    #[inline]
    CallOptions: String = {
         
            <_NamedArgument: (<NamedArgument> <(Comma <NamedArgument>)*>)>  => format!("{{ \"item\": \"Separated\", \"name\": \"CallOptions\", \"_NamedArgument\": {} }}", format!("[{}, {}]", _NamedArgument.0, _NamedArgument.1.join(", "))),
        
    };
    NamedArgument: String = {
         
            <_name: Identifier>  <_colon: Colon>  <_value: Expression>  => format!("{{ \"item\": \"Struct\", \"name\": \"NamedArgument\", \"_name\": {}, \"_colon\": {}, \"_value\": {} }}", _name, _colon, _value),
        
    };
    

// Rules for topic Primary Expressions
    #[inline]
    TypeExpression: String = {
         
            <_type_keyword: TypeKeyword>  <_open_paren: OpenParen>  <_type_name: TypeName>  <_close_paren: CloseParen>  => format!("{{ \"item\": \"Struct\", \"name\": \"TypeExpression\", \"_type_keyword\": {}, \"_open_paren\": {}, \"_type_name\": {}, \"_close_paren\": {} }}", _type_keyword, _open_paren, _type_name, _close_paren),
        
    };
    #[inline]
    NewExpression: String = {
         
         // I think Adding the arguments here is correct, it helps disambiguate between a new expression and a index access
         // TODO: Check if the newable type name makes sense
         // TODO I dont think it makes sense, since you may want a new expression that is not invoked (i think)
            <_new_keyword: NewKeyword>  <_type_name: NewableTypeName> <pos: PositionalArgumentsDeclaration> => format!("{{ \"item\": \"Struct\", \"name\": \"NewExpression\", \"_new_keyword\": {}, \"_type_name\": {}, \"pos\": {} }}", _new_keyword, _type_name, pos),
        
    };
    #[inline]
    TupleExpression: String = {
         
            <_open_paren: OpenParen>  <_items: TupleValues?>  <_close_paren: CloseParen>  => format!("{{ \"item\": \"Struct\", \"name\": \"TupleExpression\", \"_open_paren\": {}, \"_items\": {}, \"_close_paren\": {} }}", _open_paren, _items.unwrap_or("\"\"".into()), _close_paren),
        
    };
    #[inline]
    TupleValues: String = {
         
            <_TupleValue: (<TupleValue> <(Comma <TupleValue>)*>)>  => format!("{{ \"item\": \"Separated\", \"name\": \"TupleValues\", \"_TupleValue\": {} }}", format!("[{}, {}]", _TupleValue.0, _TupleValue.1.join(", "))),
        
    };
    #[inline]
    TupleValue: String = {
         
                  // A tuple value is an actual value, not a deconstruction
            <_expression: (Expression)>  => format!("{{ \"item\": \"Struct\", \"name\": \"TupleValue\", \"_expression\": {} }}", _expression),
        
    };
    #[inline]
    ArrayExpression: String = {
         
            <_open_bracket: OpenBracket>  <_items: ArrayValues>  <_close_bracket: CloseBracket>  => format!("{{ \"item\": \"Struct\", \"name\": \"ArrayExpression\", \"_open_bracket\": {}, \"_items\": {}, \"_close_bracket\": {} }}", _open_bracket, _items, _close_bracket),
        
    };
    #[inline]
    ArrayValues: String = {
         
            <_Expression: (<Expression> <(Comma <Expression>)*>)>  => format!("{{ \"item\": \"Separated\", \"name\": \"ArrayValues\", \"_Expression\": {} }}", format!("[{}, {}]", _Expression.0, _Expression.1.join(", "))),
        
    };
    

// Rules for topic Numbers
    #[inline]
    HexNumberExpression: String = {
         
            <_literal: HexLiteral>  => format!("{{ \"item\": \"Struct\", \"name\": \"HexNumberExpression\", \"_literal\": {} }}", _literal),
        
    };
    #[inline]
    DecimalNumberExpression: String = {
         
            <_literal: DecimalLiteral>  <_unit: (NumberUnit)?>  => format!("{{ \"item\": \"Struct\", \"name\": \"DecimalNumberExpression\", \"_literal\": {}, \"_unit\": {} }}", _literal, _unit.unwrap_or("\"\"".into())),
        
    };
    NumberUnit: String = {
         
            <_WeiKeyword: WeiKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"NumberUnit\", \"_WeiKeyword\": {} }}", _WeiKeyword),
         
            <_GweiKeyword: GweiKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"NumberUnit\", \"_GweiKeyword\": {} }}", _GweiKeyword),
         
            <_EtherKeyword: EtherKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"NumberUnit\", \"_EtherKeyword\": {} }}", _EtherKeyword),
         
            <_SecondsKeyword: SecondsKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"NumberUnit\", \"_SecondsKeyword\": {} }}", _SecondsKeyword),
         
            <_MinutesKeyword: MinutesKeyword>  => format!("{{ \"item\": \"Variant\", \"name\": \"NumberUnit\", \"_MinutesKeyword\": {} }}", _MinutesKeyword),
         
