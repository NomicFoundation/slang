    };
    




// Rules for section Yul

// Rules for topic Yul Statements
    YulBlock: String = {
         
            <_open_brace: OpenBrace>  <_statements: YulStatements>  <_close_brace: CloseBrace>  => format!("{{ \"item\": \"Struct\", \"name\": \"YulBlock\", \"_open_brace\": {}, \"_statements\": {}, \"_close_brace\": {} }}", _open_brace, _statements, _close_brace),
        
    };
    #[inline]
    YulStatements: String = {
         
            <_YulStatement: (<YulStatement>)*>  => format!("{{ \"item\": \"Repeated\", \"name\": \"YulStatements\", \"_YulStatement\": {} }}", format!("[{}]", _YulStatement.join(", "))),
        
    };
    #[inline]
    YulStatement: String = {
         
            <_YulBlock: YulBlock>  => format!("{{ \"item\": \"Variant\", \"name\": \"YulStatement\", \"_YulBlock\": {} }}", _YulBlock),
         
            <_YulFunctionDefinition: YulFunctionDefinition>  => format!("{{ \"item\": \"Variant\", \"name\": \"YulStatement\", \"_YulFunctionDefinition\": {} }}", _YulFunctionDefinition),
         
            <_YulIfStatement: YulIfStatement>  => format!("{{ \"item\": \"Variant\", \"name\": \"YulStatement\", \"_YulIfStatement\": {} }}", _YulIfStatement),
         
            <_YulForStatement: YulForStatement>  => format!("{{ \"item\": \"Variant\", \"name\": \"YulStatement\", \"_YulForStatement\": {} }}", _YulForStatement),
         
            <_YulSwitchStatement: YulSwitchStatement>  => format!("{{ \"item\": \"Variant\", \"name\": \"YulStatement\", \"_YulSwitchStatement\": {} }}", _YulSwitchStatement),
         
            <_YulLeaveStatement: YulLeaveStatement>  => format!("{{ \"item\": \"Variant\", \"name\": \"YulStatement\", \"_YulLeaveStatement\": {} }}", _YulLeaveStatement),
         
            <_YulBreakStatement: YulBreakStatement>  => format!("{{ \"item\": \"Variant\", \"name\": \"YulStatement\", \"_YulBreakStatement\": {} }}", _YulBreakStatement),
         
            <_YulContinueStatement: YulContinueStatement>  => format!("{{ \"item\": \"Variant\", \"name\": \"YulStatement\", \"_YulContinueStatement\": {} }}", _YulContinueStatement),
         
            <_YulVariableAssignmentStatement: YulVariableAssignmentStatement>  => format!("{{ \"item\": \"Variant\", \"name\": \"YulStatement\", \"_YulVariableAssignmentStatement\": {} }}", _YulVariableAssignmentStatement),
         
            <_YulVariableDeclarationStatement: YulVariableDeclarationStatement>  => format!("{{ \"item\": \"Variant\", \"name\": \"YulStatement\", \"_YulVariableDeclarationStatement\": {} }}", _YulVariableDeclarationStatement),
         
            <_YulExpression: YulExpression>  => format!("{{ \"item\": \"Variant\", \"name\": \"YulStatement\", \"_YulExpression\": {} }}", _YulExpression),
        
    };
    #[inline]
    YulFunctionDefinition: String = {
         
            <_function_keyword: YulFunctionKeyword>  <_name: YulIdentifier>  <_parameters: YulParametersDeclaration>  <_returns: (YulReturnsDeclaration)?>  <_body: YulBlock>  => format!("{{ \"item\": \"Struct\", \"name\": \"YulFunctionDefinition\", \"_function_keyword\": {}, \"_name\": {}, \"_parameters\": {}, \"_returns\": {}, \"_body\": {} }}", _function_keyword, _name, _parameters, _returns.unwrap_or("\"\"".into()), _body),
        
    };
    #[inline]
    YulParametersDeclaration: String = {
         
            <_open_paren: OpenParen>  <_parameters: YulParameters>  <_close_paren: CloseParen>  => format!("{{ \"item\": \"Struct\", \"name\": \"YulParametersDeclaration\", \"_open_paren\": {}, \"_parameters\": {}, \"_close_paren\": {} }}", _open_paren, _parameters, _close_paren),
        
    };
    #[inline]
    YulParameters: String = {
         
            <_YulIdentifier: ((<YulIdentifier> <(Comma <YulIdentifier>)*>))?>  => format!("{{ \"item\": \"Separated\", \"name\": \"YulParameters\", \"_YulIdentifier\": {} }}", _YulIdentifier.map(|x| format!("[{}, {}]", x.0, x.1.join(", "))).unwrap_or("[]".into())),
        
    };
    #[inline]
    YulReturnsDeclaration: String = {
         
            <_minus_greater_than: MinusGreaterThan>  <_variables: YulVariableNames>  => format!("{{ \"item\": \"Struct\", \"name\": \"YulReturnsDeclaration\", \"_minus_greater_than\": {}, \"_variables\": {} }}", _minus_greater_than, _variables),
        
    };
    YulVariableNames: String = {
         
            <_YulIdentifier: (<YulIdentifier> <(Comma <YulIdentifier>)*>)>  => format!("{{ \"item\": \"Separated\", \"name\": \"YulVariableNames\", \"_YulIdentifier\": {} }}", format!("[{}, {}]", _YulIdentifier.0, _YulIdentifier.1.join(", "))),
        
    };
    #[inline]
    YulVariableDeclarationStatement: String = {
         
            <_let_keyword: YulLetKeyword>  <_variables: YulVariableNames>  <_value: (YulVariableDeclarationValue)?>  => format!("{{ \"item\": \"Struct\", \"name\": \"YulVariableDeclarationStatement\", \"_let_keyword\": {}, \"_variables\": {}, \"_value\": {} }}", _let_keyword, _variables, _value.unwrap_or("\"\"".into())),
        
    };
    #[inline]
    YulVariableDeclarationValue: String = {
         
            <_assignment: YulAssignmentOperator>  <_expression: YulExpression>  => format!("{{ \"item\": \"Struct\", \"name\": \"YulVariableDeclarationValue\", \"_assignment\": {}, \"_expression\": {} }}", _assignment, _expression),
        
    };
    #[inline]
    YulVariableAssignmentStatement: String = {
         
            <_variables: YulPaths>  <_assignment: YulAssignmentOperator>  <_expression: YulExpression>  => format!("{{ \"item\": \"Struct\", \"name\": \"YulVariableAssignmentStatement\", \"_variables\": {}, \"_assignment\": {}, \"_expression\": {} }}", _variables, _assignment, _expression),
        
    };
    YulAssignmentOperator: String = {
         
            <_ColonEqual: ColonEqual>  => format!("{{ \"item\": \"Variant\", \"name\": \"YulAssignmentOperator\", \"_ColonEqual\": {} }}", _ColonEqual),
        
    };
    #[inline]
    YulIfStatement: String = {
         
            <_if_keyword: YulIfKeyword>  <_condition: YulExpression>  <_body: YulBlock>  => format!("{{ \"item\": \"Struct\", \"name\": \"YulIfStatement\", \"_if_keyword\": {}, \"_condition\": {}, \"_body\": {} }}", _if_keyword, _condition, _body),
        
    };
    #[inline]
    YulForStatement: String = {
         
            <_for_keyword: YulForKeyword>  <_initialization: YulBlock>  <_condition: YulExpression>  <_iterator: YulBlock>  <_body: YulBlock>  => format!("{{ \"item\": \"Struct\", \"name\": \"YulForStatement\", \"_for_keyword\": {}, \"_initialization\": {}, \"_condition\": {}, \"_iterator\": {}, \"_body\": {} }}", _for_keyword, _initialization, _condition, _iterator, _body),
        
    };
    #[inline]
    YulSwitchStatement: String = {
         
            <_switch_keyword: YulSwitchKeyword>  <_expression: YulExpression>  <_cases: YulSwitchCases>  => format!("{{ \"item\": \"Struct\", \"name\": \"YulSwitchStatement\", \"_switch_keyword\": {}, \"_expression\": {}, \"_cases\": {} }}", _switch_keyword, _expression, _cases),
        
    };
    #[inline]
    YulSwitchCases: String = {
         
            <_YulSwitchCase: (<YulSwitchCase>)+>  => format!("{{ \"item\": \"Repeated\", \"name\": \"YulSwitchCases\", \"_YulSwitchCase\": {} }}", format!("[{}]", _YulSwitchCase.join(", "))),
        
    };
    #[inline]
    YulSwitchCase: String = {
         
            <_YulDefaultCase: YulDefaultCase>  => format!("{{ \"item\": \"Variant\", \"name\": \"YulSwitchCase\", \"_YulDefaultCase\": {} }}", _YulDefaultCase),
         
            <_YulValueCase: YulValueCase>  => format!("{{ \"item\": \"Variant\", \"name\": \"YulSwitchCase\", \"_YulValueCase\": {} }}", _YulValueCase),
        
    };
    #[inline]
    YulDefaultCase: String = {
         
            <_default_keyword: YulDefaultKeyword>  <_body: YulBlock>  => format!("{{ \"item\": \"Struct\", \"name\": \"YulDefaultCase\", \"_default_keyword\": {}, \"_body\": {} }}", _default_keyword, _body),
        
    };
    #[inline]
    YulValueCase: String = {
         
            <_case_keyword: YulCaseKeyword>  <_value: YulLiteral>  <_body: YulBlock>  => format!("{{ \"item\": \"Struct\", \"name\": \"YulValueCase\", \"_case_keyword\": {}, \"_value\": {}, \"_body\": {} }}", _case_keyword, _value, _body),
        
    };
    #[inline]
    YulLeaveStatement: String = {
         
            <_leave_keyword: YulLeaveKeyword>  => format!("{{ \"item\": \"Struct\", \"name\": \"YulLeaveStatement\", \"_leave_keyword\": {} }}", _leave_keyword),
        
    };
    #[inline]
    YulBreakStatement: String = {
         
            <_break_keyword: YulBreakKeyword>  => format!("{{ \"item\": \"Struct\", \"name\": \"YulBreakStatement\", \"_break_keyword\": {} }}", _break_keyword),
        
    };
    #[inline]
    YulContinueStatement: String = {
         
            <_continue_keyword: YulContinueKeyword>  => format!("{{ \"item\": \"Struct\", \"name\": \"YulContinueStatement\", \"_continue_keyword\": {} }}", _continue_keyword),
        
    };
    

// Rules for topic Yul Expressions
    YulExpression: String = {
        #[precedence(level="1")] 
            <_YulExpression: YulExpression>  <_open_paren: OpenParen>  <_arguments: YulArguments>  <_close_paren: CloseParen>  => format!("{{ \"item\": \"Precedence-Operator\", \"name\": \"YulExpression\", \"_YulExpression\": {}, \"_open_paren\": {}, \"_arguments\": {}, \"_close_paren\": {} }}", _YulExpression, _open_paren, _arguments, _close_paren),
        #[precedence(level="0")] 
            <_YulLiteral: YulLiteral>  => format!("{{ \"item\": \"Precedence-primary\", \"name\": \"YulExpression\", \"_YulLiteral\": {} }}", _YulLiteral),
        #[precedence(level="0")] 
            <_YulPath: YulPath>  => format!("{{ \"item\": \"Precedence-primary\", \"name\": \"YulExpression\", \"_YulPath\": {} }}", _YulPath),
        
    };
    #[inline]
    YulArguments: String = {
         
            <_YulExpression: ((<YulExpression> <(Comma <YulExpression>)*>))?>  => format!("{{ \"item\": \"Separated\", \"name\": \"YulArguments\", \"_YulExpression\": {} }}", _YulExpression.map(|x| format!("[{}, {}]", x.0, x.1.join(", "))).unwrap_or("[]".into())),
        
    };
    #[inline]
    YulPaths: String = {
         
            <_YulPath: (<YulPath> <(Comma <YulPath>)*>)>  => format!("{{ \"item\": \"Separated\", \"name\": \"YulPaths\", \"_YulPath\": {} }}", format!("[{}, {}]", _YulPath.0, _YulPath.1.join(", "))),
        
    };
