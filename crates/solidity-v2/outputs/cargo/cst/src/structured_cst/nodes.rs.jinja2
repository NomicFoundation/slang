  {%- set target = model.structured_cst_model -%}
#![allow(non_camel_case_types)]
#![allow(dead_code)]
#![allow(unused_variables)]
#![allow(clippy::too_many_arguments)]

use std::ops::Range;
use std::rc::Rc;

use crate::separated::SeparatedList;


// TODO(v2):
// - (perf) don't use terminals that are not needed
// - (feat) visitor/traversal/serializer
// - (feat) span information, where applicable
// - (feat) Use `new` impl methods instead of free functions:
// ```
// impl YulUncheckedKeyword {
//   pub fn new(...) {
//     ...
//   }
// }
// ```


//
// Sequences:
//
// Note: All sequences are wrapped in Rc, this keeps sizes down and avoids recursive types
{% for parent_type, sequence in target.sequences %}
  pub type {{ parent_type }} = Rc<{{ parent_type }}Struct>;

  #[derive(Clone, Debug, PartialEq)]
  pub struct {{ parent_type }}Struct {
    {%- for field in sequence.fields %}
      pub {{ field.label | snake_case }}:
        {%- if field.is_optional -%}
          Option<{{ field.field_type.name }}>,
        {%- else -%}
          {{ field.field_type.name }},
        {%- endif -%}
    {% endfor -%}
  }

  pub fn new_{{ parent_type | snake_case }}({% for field in sequence.fields -%}
      {{ field.label | snake_case }}: {% if field.is_optional %}Option<{% endif %}{{ field.field_type.name }}{% if field.is_optional %}>{% endif %},
    {%- endfor %}) -> {{ parent_type }} {
      Rc::new({{ parent_type }}Struct {
        {%- for field in sequence.fields %}
          {{ field.label | snake_case }},
        {%- endfor -%}
      })
  }

{% endfor %}

//
// Choices:
//
// Note: We create a constructor function for each variant
{% for parent_type, choice in target.choices %}
  #[derive(Clone, Debug, PartialEq)]
  pub enum {{ parent_type }} {
    {% for variant in choice.variants -%}
      {{ variant.variant_type.name }}({{ variant.variant_type.name }}),
    {%- endfor -%}
  }

  {% for variant in choice.variants %}
    pub fn new_{{ parent_type | snake_case }}_{{ variant.variant_type.name | snake_case }}(element: {{ variant.variant_type.name }}) -> {{ parent_type }} {
      {{ parent_type }}::{{ variant.variant_type.name }}(element)
    }
  {% endfor %}
{% endfor %}

//
// Repeated & Separated
//
{% for parent_type, collection in target.collections %}
  {% if collection.separator_type -%}
  {# ── Separated: newtype around SeparatedList with Deref ── #}
  #[derive(Clone, Debug, PartialEq)]
  pub struct {{ parent_type }}(pub SeparatedList<{{ collection.item_type.name }}, {{ collection.separator_type.name }}>);

  impl std::ops::Deref for {{ parent_type }} {
      type Target = SeparatedList<{{ collection.item_type.name }}, {{ collection.separator_type.name }}>;
      fn deref(&self) -> &Self::Target { &self.0 }
  }

  impl std::ops::DerefMut for {{ parent_type }} {
      fn deref_mut(&mut self) -> &mut Self::Target { &mut self.0 }
  }

  pub fn new_{{ parent_type | snake_case }}(list: SeparatedList<{{ collection.item_type.name }}, {{ collection.separator_type.name }}>) -> {{ parent_type }} {
      {{ parent_type }}(list)
  }
  {%- else -%}
  #[derive(Clone, Debug, PartialEq)]
  pub struct {{ parent_type }} {
      pub elements: Vec<{{ collection.item_type.name }}>,
  }

  impl {{ parent_type }} {
      pub fn elements(&self) -> impl DoubleEndedIterator<Item = &{{ collection.item_type.name }}> {
          self.elements.iter()
      }
  }

  pub fn new_{{ parent_type | snake_case }}(elements: Vec<{{ collection.item_type.name }}>) -> {{ parent_type }} {
      {{ parent_type }} { elements }
  }
  {%- endif %}

{% endfor %}

//
// Terminals
//
// Note: _source is unused on the constructor methods, but kept for uniformity with other constructors
// and because it may be needed in the future
{% for parent_type in target.terminals %}
#[derive(Clone, Debug, PartialEq)]
  pub struct {{ parent_type }} {
    pub range: Range<usize>,
  }

  pub fn new_{{ parent_type | snake_case }}(range: Range<usize>, _source: &str) -> {{ parent_type }} {
    {{ parent_type }} { range }
  }
{% endfor %}
