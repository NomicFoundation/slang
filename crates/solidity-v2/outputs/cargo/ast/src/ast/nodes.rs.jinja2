{%- set target = model.ir_language_model.target -%}
#![allow(unused)]
use std::ops::Range;
use std::sync::Arc;

use slang_solidity_v2_common::files::FileId;
use slang_solidity_v2_common::nodes::NodeId;
use slang_solidity_v2_ir::ir;
use slang_solidity_v2_semantic::context::SemanticContext;
use super::types::Type;

//
// Sequences
//

{% for parent_type, sequence in target.sequences %}
  pub type {{ parent_type }} = Arc<{{ parent_type }}Struct>;

  pub struct {{ parent_type }}Struct {
    pub(crate) ir_node: ir::{{ parent_type }},
    pub(crate) semantic: Arc<SemanticContext>,
  }

  pub fn create_{{ parent_type | snake_case }}(
    ir_node: &ir::{{ parent_type }},
    semantic: &Arc<SemanticContext>,
  ) -> {{ parent_type }} {
    Arc::new({{ parent_type }}Struct {
      ir_node: Arc::clone(ir_node),
      semantic: Arc::clone(semantic),
    })
  }

  impl {{ parent_type }}Struct {
    pub fn node_id(&self) -> NodeId {
      self.ir_node.id()
    }
    {% for field in sequence.fields -%}
      {% if field.is_optional %}
        {% if field.field_type.kind == "External" %}
          pub fn {{ field.label }}(&self) -> bool {
            self.ir_node.{{ field.label }}
          }
        {% else %}
          pub fn {{ field.label }}(&self) -> Option<{{ field.field_type.name }}> {
            self.ir_node.{{ field.label }}.as_ref().map(|ir_node| {
              create_{{ field.field_type.name | snake_case }}(ir_node, &self.semantic)
            })
          }
        {% endif %}
      {% else %} {# not field.is_optional #}
        pub fn {{ field.label }}(&self) -> {{ field.field_type.name }} {
          create_{{ field.field_type.name | snake_case }}(&self.ir_node.{{ field.label }}, &self.semantic)
        }
      {% endif %}
    {% endfor %}

    pub fn get_type(&self) -> Option<Type> {
      Type::try_create_for_node_id(self.ir_node.id(), &self.semantic)
    }

    pub fn get_file_id(&self) -> &FileId {
        self.semantic.file_id_from_node_id(self.ir_node.id())
    }

    pub fn get_text_range(&self) -> &Range<usize> {
        &self.ir_node.range
    }
  }

{% endfor %}

//
// Choices
//

{% for parent_type, choice in target.choices %}
  pub enum {{ parent_type }} {
    {% for variant in choice.variants -%}
      {{ variant.name }}
      {%- if variant.kind != "External" -%}
        ({{ variant.name }})
      {%- endif -%}
      ,
    {%- endfor -%}
  }

  #[allow(clippy::too_many_lines)]
  #[allow(clippy::trivially_copy_pass_by_ref)]
  pub(crate) fn create_{{ parent_type | snake_case }}(
    ir_node: &ir::{{ parent_type }},
    semantic: &Arc<SemanticContext>,
  ) -> {{ parent_type }}{
    match ir_node {
      {% for variant in choice.variants -%}
        ir::{{ parent_type }}::{{ variant.name }}
        {%- if variant.kind == "Collection" -%}
          (nodes) => {{ parent_type }}::{{ variant.name }}(
            create_{{ variant.name | snake_case }}(nodes, semantic)
          ),
        {%- elif variant.kind != "External" -%}
          (variant) => {{ parent_type }}::{{ variant.name }}(
            create_{{ variant.name | snake_case }}(variant, semantic)
          ),
        {%- else -%}
          => {{ parent_type }}::{{ variant.name }},
        {%- endif -%}
      {%- endfor %}
    }
  }

{% endfor %}

//
// Repeated & Separated
//

{% for parent_type, collection in target.collections -%}
  pub type {{ parent_type }} = Arc<{{ parent_type }}Struct>;

  pub(crate) fn create_{{ parent_type | snake_case }}(
    nodes: &[ir::{{ collection.item_type.name }}],
    semantic: &Arc<SemanticContext>,
  ) -> {{ parent_type }} {
    Arc::new({{ parent_type }}Struct {
      ir_nodes: nodes.to_vec(),
      semantic: Arc::clone(semantic),
    })
  }

  pub struct {{ parent_type }}Struct {
    pub(crate) ir_nodes: Vec<ir::{{ collection.item_type.name }}>,
    pub(crate) semantic: Arc<SemanticContext>,
  }

  impl {{ parent_type }}Struct {
    pub fn iter(&self) -> impl Iterator<Item = {{ collection.item_type.name }}> + use<'_> {
      self.ir_nodes
          .iter()
          .map(|ir_node| create_{{ collection.item_type.name | snake_case }}(ir_node, &self.semantic))
    }

    pub fn len(&self) -> usize {
      self.ir_nodes.len()
    }

    pub fn is_empty(&self) -> bool {
      self.ir_nodes.is_empty()
    }
  }
{% endfor %}

//
// Terminals
//

{% for terminal_type, terminal in target.terminals %}
  pub type {{ terminal_type }} = Arc<{{ terminal_type }}Struct>;

  pub struct {{ terminal_type }}Struct {
    pub(crate) ir_node: ir::{{ terminal_type }},
    pub(crate) semantic: Arc<SemanticContext>,
  }

  pub(crate) fn create_{{ terminal_type | snake_case }}(
    ir_node: &ir::{{ terminal_type }},
    semantic: &Arc<SemanticContext>,
  ) -> {{ terminal_type }} {
    Arc::new({{ terminal_type }}Struct {
      ir_node: Arc::clone(ir_node),
      semantic: Arc::clone(semantic),
    })
  }

  impl {{ terminal_type }}Struct {
    pub fn node_id(&self) -> NodeId {
      self.ir_node.id()
    }

      pub fn unparse(&self) -> &str {
        self.ir_node.unparse()
      }

    pub fn get_type(&self) -> Option<Type> {
      Type::try_create_for_node_id(self.ir_node.id(), &self.semantic)
    }

    pub fn get_file_id(&self) -> &FileId {
        self.semantic.file_id_from_node_id(self.ir_node.id())
    }

    pub fn get_text_range(&self) -> &Range<usize> {
        &self.ir_node.range
    }
  }
{% endfor %}
