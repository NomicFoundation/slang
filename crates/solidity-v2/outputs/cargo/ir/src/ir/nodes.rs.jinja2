{%- set target = model.ir_language_model.target -%}
#![allow(non_camel_case_types)]

use std::rc::Rc;
use std::ops::Range;
use std::vec::Vec;

pub(super) use slang_solidity_v2_common::nodes::NodeId;

//
// Sequences
//

{% for parent_type, sequence in target.sequences %}
  pub type {{ parent_type }} = Rc<{{ parent_type }}Struct>;

  #[derive(Debug)]
  pub struct {{ parent_type }}Struct {
    pub(crate) id: NodeId,
    pub range: Range<usize>,
    {%- for field in sequence.fields %}
      pub {{ field.label | snake_case }}:
      {%- if field.field_type.kind == "UniqueTerminal" -%}
        {%- if field.is_optional -%}
          bool,
        {%- else -%}
          {{ throw(message="Cannot generate sequence field for non-optional unique terminal") }},
        {%- endif -%}
      {%- else -%}
        {%- if field.is_optional -%}
          Option<{{ field.field_type.name }}>,
        {%- else -%}
          {{ field.field_type.name }},
        {%- endif -%}
      {%- endif -%}
    {% endfor -%}
  }

  impl {{ parent_type }}Struct {
    pub fn id(&self) -> NodeId {
      self.id
    }
  }

{% endfor %}

//
// Choices
//

{% for parent_type, choice in target.choices %}
  #[derive(Clone, Debug)]
  pub enum {{ parent_type }} {
    {% for variant in choice.variants -%}
      {{ variant.name }}
      {%- if variant.kind != "UniqueTerminal" -%}
        ({{ variant.name }})
      {%- endif -%}
      ,
    {%- endfor -%}
  }
{% endfor %}

//
// Repeated & Separated
//

{% for parent_type, collection in target.collections %}
  pub type {{ parent_type }} = Vec<
    {{ collection.item_type.name }}
  >;
{% endfor %}

//
// Non-unique Terminals
//

{% for terminal_type, terminal in target.terminals %}
  {% if not terminal.is_unique %}
    pub type {{ terminal_type }} = Rc<{{ terminal_type }}Struct>;

    #[derive(Clone, Debug, Eq, PartialEq)]
    pub struct {{ terminal_type }}Struct {
      pub(crate) id: NodeId,
      pub range: Range<usize>,
      pub text: String,
    }

    impl {{ terminal_type }}Struct {
      pub fn id(&self) -> NodeId {
        self.id
      }

      pub fn unparse(&self) -> &str {
        &self.text
      }
    }
  {% endif %}
{% endfor %}
